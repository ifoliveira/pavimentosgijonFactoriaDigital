{% extends 'base.html.twig' %}

{% block title %}Editar precio{% endblock %}
{% block cabecera %}Editar precio{% endblock %}

{% block breadcrumb %}
  <li class="breadcrumb-item"><a href="{{ path('admin_precios_index') }}">Precios</a></li>
  <li class="breadcrumb-item active">Editar</li>
{% endblock %}

{% block body %}

  <div class="row">
    <div class="col-sm-12 col-lg-6">
      <div class="card">
        <div class="card-body">

          <h4 class="card-title">{{ precio.descripcion }}</h4>
          <p class="text-muted small">Clave: {{ precio.clave }} · {{ precio.tipoReforma }}</p>
          <hr>

          <form method="post">
            <div class="mb-3">
              <label class="form-label">Precio (€)</label>
              <input
                type="number"
                name="valor"
                value="{{ precio.valor }}"
                step="0.01"
                min="0"
                class="form-control"
                autofocus
              >
            </div>

            <div class="form-group mt-3">
              <button type="submit" class="btn btn-info waves-effect waves-light">
                Guardar
              </button>
              <a href="{{ path('admin_precios_index') }}" class="btn btn-secondary ml-2">
                Cancelar
              </a>
            </div>
          </form>

        </div>
      </div>
    </div>
  </div>

{% endblock %}