{% extends 'base.html.twig' %}

{% block title %}Tickets{% endblock %}
{% block cabecera %}Tickets{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Tickets</li>{% endblock %}

{% block body %}

    {# ---- Tabla 1: tickets con señal pendiente ---- #}
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Tickets con señal pendiente</h4>
                    <div class="table-responsive">
                        <table id="default_order" class="table table-striped table-bordered display" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Fecha</th>
                                    <th>Importe Total</th>
                                    <th>Pendiente</th>
                                    <th>Ticket</th>
                                    <th>Presupuesto</th>
                                    <th>Fecha y hora</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for cestar in cestasnal %}
                                    {% set pagado = 0 %}
                                    {% for pagos in cestar.pagos %}
                                        {% set pagado = pagos.importePg + pagado %}
                                    {% endfor %}
                                    <tr>
                                        <td>{{ cestar.id }}</td>
                                        <td>{{ cestar.fechaCs ? cestar.fechaCs|date('Y-m-d') : '' }}</td>
                                        <td class="text-right">{{ cestar.importeTotCs|format_currency('EUR', locale='es') }}</td>
                                        <td class="text-right">{{ (cestar.importeTotCs - pagado)|format_currency('EUR', locale='es') }}</td>
                                        <td>
                                            <a href="/Tickets/{{ cestar.numticketCs }}" target="_blank">{{ cestar.numticketCs }}</a>
                                        </td>
                                        <td>
                                            {% if cestar.prespuestoCs is not null %}
                                                <a href="{{ path('presupuestos_show', {id: cestar.prespuestoCs}) }}" target="_blank">
                                                    {{ cestar.prespuestoCs.clientePe.direccionCl }}
                                                </a>
                                            {% endif %}
                                        </td>
                                        <td>{{ cestar.timestampCs ? cestar.timestampCs|date('Y-m-d H:i:s') : '' }}</td>
                                        <td>
                                            <a class="text-inverse pr-2" data-toggle="tooltip" title="Añadir Pago"
                                               name="cerrar_senal"
                                               id="{{ cestar.id }}"
                                               data-importe="{{ (cestar.importeTotCs - pagado) }}"
                                               data-url="{{ path('cestas_finalizar', {'id': cestar.id}) }}">
                                                <i class="ti-money"></i>
                                            </a>
                                            <a href="{{ path('cesta_tipopago', {'id': cestar.id}) }}" class="text-inverse pr-2"
                                               data-toggle="tooltip" title="Cambiar tipo pago">
                                                <i class="ti-exchange-vertical"></i>
                                            </a>
                                            <a class="text-inverse pr-2" data-toggle="tooltip" title="Borrar cesta"
                                               name="delete_detalle" id="{{ cestar.id }}">
                                                <i class="ti-trash"></i>
                                            </a>
                                            {% for detalle in cestar.getdetallecesta|slice(0, 1) %}
                                                <a href="{{ path('detallecesta_show', {'id': detalle.getId}) }}" class="text-inverse pr-2"
                                                   data-toggle="tooltip" title="Ver ticket">
                                                    <i class="ti-eye"></i>
                                                </a>
                                            {% endfor %}
                                            <a class="text-inverse pr-2" data-toggle="tooltip" title="Imprimir ticket"
                                               name="imprimirticket"
                                               data-url="{{ path('ticketpdf', {'id': cestar.id}) }}">
                                                <i class="ti-printer"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ---- Tabla 2: todos los tickets ---- #}
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Tickets</h4>
                    <div class="table-responsive">
                        <table id="default_order2" class="table table-striped table-bordered display" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Fecha</th>
                                    <th>Importe Total</th>
                                    <th>Tipo Pago</th>
                                    <th>Ticket</th>
                                    <th>Presupuesto</th>
                                    <th>Fecha y hora</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for cesta in cestas %}
                                    <tr>
                                        <td>{{ cesta.id }}</td>
                                        <td>{{ cesta.fechaCs ? cesta.fechaCs|date('Y-m-d') : '' }}</td>
                                        <td class="text-right">{{ cesta.importeTotCs|format_currency('EUR', locale='es') }}</td>
                                        <td>{{ cesta.tipopagoCs }}</td>
                                        <td>
                                            <a href="/Tickets/{{ cesta.numticketCs }}" target="_blank">{{ cesta.numticketCs }}</a>
                                        </td>
                                        <td>
                                            {% if cesta.prespuestoCs is not null %}
                                                <a href="{{ path('presupuestos_show', {id: cesta.prespuestoCs.id}) }}" target="_blank">
                                                    {{ cesta.prespuestoCs.clientePe.direccionCl }}
                                                </a>
                                            {% endif %}
                                        </td>
                                        <td>{{ cesta.timestampCs ? cesta.timestampCs|date('Y-m-d H:i:s') : '' }}</td>
                                        <td>
                                            <a href="{{ path('cesta_tipopago', {'id': cesta.id}) }}" class="text-inverse pr-2"
                                               data-toggle="tooltip" title="Cambiar tipo pago">
                                                <i class="ti-exchange-vertical"></i>
                                            </a>
                                            <a class="text-inverse pr-2" data-toggle="tooltip" title="Borrar cesta"
                                               name="delete_detalle" id="{{ cesta.id }}">
                                                <i class="ti-trash"></i>
                                            </a>
                                            {% for detalle in cesta.getdetallecesta|slice(0, 1) %}
                                                <a href="{{ path('detallecesta_show', {'id': detalle.getId}) }}" class="text-inverse pr-2"
                                                   data-toggle="tooltip" title="Ver ticket">
                                                    <i class="ti-eye"></i>
                                                </a>
                                            {% endfor %}
                                            <a class="text-inverse pr-2" data-toggle="tooltip" title="Imprimir ticket"
                                               name="imprimirticket"
                                               data-url="{{ path('ticketpdf', {'id': cesta.id}) }}">
                                                <i class="ti-printer"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="8">No se encontraron tickets</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block jscustom %}
    <script src="{{ asset('dist/js/ConectorJavaScript.js') }}"></script>
    <script src="{{ asset('assets/extra-libs/datatables.net-bs4/js/dataTables.responsive.min.js') }}"></script>
    <script src="{{ asset('assets/libs/sweetalert2/dist/sweetalert2.all.min.js') }}"></script>
    <script src="{{ asset('assets/extra-libs/sweetalert2/sweet-alert.init.js') }}"></script>
    <script src="{{ asset('js/impresoraTickets.js') }}"></script>

    <script>
    $(document).ready(function () {

        // --- Inicialización DataTables ---
        $('#default_order').DataTable({
            order: [[1, 'desc'], [6, 'desc']]
        });
        $('#default_order2').DataTable({
            order: [[1, 'desc'], [6, 'desc']]
        });

        // --- Borrar cesta ---
        $(document).on('click', 'a[name="delete_detalle"]', async function () {
            const id = this.id;

            const swal = Swal.mixin({
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton:  'mr-2 btn btn-danger'
                },
                buttonsStyling: false
            });

            const result = await swal.fire({
                title: 'Borrado de tickets',
                text:  'Se va a borrar el ticket ' + id,
                icon:  'question',
                showCancelButton:  true,
                confirmButtonText: 'Adelante',
                cancelButtonText:  'Noooo',
                reverseButtons:    true
            });

            if (result.isConfirmed) delete_line(id);
        });

        function delete_line(id) {
            $.ajax({
                url:      '{{ path("cesta_delete_ajax") }}',
                type:     'POST',
                data:     { id },
                dataType: 'json',
                success: function () {
                    Swal.fire({
                        icon:  'success',
                        title: '¡Borrado correctamente!',
                        html:  'Se cerrará en breve',
                        timer: 2000,
                        showConfirmButton: false,
                        timerProgressBar:  true
                    }).then(() => location.reload());
                },
                error: (xhr, status) => alert(status)
            });
        }

        // --- Imprimir ticket ---
        $(document).on('click', 'a[name="imprimirticket"]', function () {
            $.ajax({
                url:      this.dataset.url,
                type:     'GET',
                data:     { tipopago: 'copia', importesnal: 0 },
                dataType: 'json',
                success:  r => console.log('Ticket ' + r.namepdf),
                error:    (xhr, status) => alert(status)
            });
        });

        // --- Cerrar señal / añadir pago ---
        $(document).on('click', 'a[name="cerrar_senal"]', async function () {
            const url     = this.dataset.url;
            const importe = this.dataset.importe;

            // Paso 1: importe a abonar
            const resultImporte = await Swal.fire({
                title: 'Pago ticket',
                html: `<h2>Importe a abonar</h2>
                       <input type="number" value="${importe}" step="1"
                              class="swal2-input" id="range-value">`,
                showCancelButton: true,
                focusConfirm:     false,
                preConfirm: () => document.getElementById('range-value').value
            });

            if (!resultImporte.isConfirmed) return;

            const senal = resultImporte.value;

            // Paso 2: método de pago
            const resultMetodo = await Swal.fire({
                title: 'Método de pago',
                text:  'Selecciona un método de pago',
                icon:  'warning',
                showCancelButton:  true,
                confirmButtonText: 'Tarjeta',
                cancelButtonText:  'Efectivo',
                reverseButtons:    true
            });

            if (resultMetodo.isConfirmed) {
                ticket_finalizar('Tarjeta', senal, url);
            } else if (resultMetodo.dismiss === Swal.DismissReason.cancel) {
                ticket_finalizar('Efectivo', senal, url);
            }
        });

        function ticket_finalizar(tipopago, importesnal, url) {
            $.ajax({
                url:      url,
                type:     'GET',
                data:     { tipopago, numticket: '', importe: 0, importesnal },
                dataType: 'json',
                success:  () => location.reload(),
                error:    (xhr, status) => alert(status)
            });
        }

    });
    </script>
{% endblock %}