<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tu estimación de reforma</title>
  <!--[if mso]>
  <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
  <![endif]-->
</head>
<body style="margin:0; padding:0; background-color:#f1f5f9; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; color:#1f2933;">

  <!-- Wrapper -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f1f5f9; padding: 40px 0;">
    <tr>
      <td align="center">

        <!-- Card principal -->
        <table width="600" cellpadding="0" cellspacing="0" border="0"
               style="max-width:600px; width:100%; background:#ffffff; border-radius:16px;
                      box-shadow:0 8px 30px rgba(0,0,0,0.08); overflow:hidden;">

          <!-- Header oscuro -->
          <tr>
            <td style="background: linear-gradient(135deg, #0f172a, #1e293b);
                       padding: 36px 40px; text-align:center;">
              <p style="margin:0 0 6px 0; font-size:13px; font-weight:600;
                         letter-spacing:0.1em; text-transform:uppercase;
                         color:rgba(255,255,255,0.6);">
                Pavimentos Gijón · Presupuesto online
              </p>
              <h1 style="margin:0; font-size:26px; font-weight:700; color:#ffffff; line-height:1.3;">
                Hola {{ nombre }}, aquí tienes<br>tu estimación de reforma
              </h1>
            </td>
          </tr>


          <!-- Estimación destacada -->
          <tr>
            <td style="padding: 40px 40px 0; text-align:center;">

              <p style="margin:0 0 8px; font-size:15px; color:#6b7280;">
                {% if tipo == 'ducha' %}
                  Cambio de bañera por ducha · Gijón
                {% else %}
                  Reforma integral de baño · Gijón
                {% endif %}
              </p>

              <!-- Rango de precio -->
              <div style="background:#f8fafc; border:2px solid #e5e7eb; border-radius:14px;
                          padding:28px 20px; margin: 16px 0 24px;">
                <p style="margin:0 0 6px; font-size:13px; color:#6b7280; font-weight:600;
                           text-transform:uppercase; letter-spacing:0.08em;">
                  Estimación orientativa
                </p>
                <p style="margin:0; font-size:42px; font-weight:800; color:#0f172a;
                           letter-spacing:-0.02em; line-height:1.1;">
                  {{ rangoTexto }}
                </p>
                <p style="margin:10px 0 0; font-size:13px; color:#9ca3af; line-height:1.5;">
                  Precio orientativo según tus respuestas.<br>
                  El presupuesto definitivo se confirma con visita técnica gratuita.
                </p>
              </div>

            </td>
          </tr>

          <!-- CTA principal -->
          <tr>
            <td style="padding: 0 40px 16px; text-align:center;">
              <a href="{{ urlPdf }}"
                 style="display:inline-block; background:#0f172a; color:#ffffff;
                        font-size:16px; font-weight:700; text-decoration:none;
                        padding:16px 36px; border-radius:10px;
                        letter-spacing:0.01em; line-height:1;">
                📄 Descargar mi presupuesto PDF
              </a>
              <p style="margin:12px 0 0; font-size:13px; color:#9ca3af;">
                El link es personal y estará disponible en cualquier momento.
              </p>
            </td>
          </tr>
                    

          <!-- Qué incluye -->
          <tr>
            <td style="padding: 0 40px 32px;">

              <p style="margin:0 0 16px; font-size:16px; font-weight:600; color:#1f2933;">
                ¿Qué suele incluir esta estimación?
              </p>

              {% if tipo == 'ducha' %}
                {% set items = [
                  '🛁 Retirada de la bañera y gestión de escombros',
                  '🚿 Suministro e instalación del plato de ducha',
                  '🪟 Mampara según el espacio disponible',
                  '🧱 Adaptación del alicatado existente',
                  '🔧 Fontanería y remates necesarios',
                ] %}
              {% else %}
                {% set items = [
                  '🏗️ Demolición y gestión de escombros',
                  '🧱 Alicatado completo de paredes y suelo',
                  '🚿 Instalación de plato de ducha o bañera',
                  '🪠 Sanitarios, mueble y grifería',
                  '🔧 Fontanería e instalación eléctrica',
                ] %}
              {% endif %}

              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                {% for item in items %}
                <tr>
                  <td style="padding: 8px 0; font-size:15px; color:#374151;
                              border-bottom:1px solid #f1f5f9; line-height:1.4;">
                    {{ item }}
                  </td>
                </tr>
                {% endfor %}
              </table>

            </td>
          </tr>



          <!-- Separador -->
          <tr>
            <td style="padding: 24px 40px;">
              <div style="border-top:1px solid #f1f5f9;"></div>
            </td>
          </tr>

          <!-- Visita gratuita -->
          <tr>
            <td style="padding: 0 40px 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="background:#f8fafc; border-radius:12px; padding:20px 24px;">
                <tr>
                  <td>
                    <p style="margin:0 0 6px; font-size:15px; font-weight:700; color:#1f2933;">
                      ¿Quieres confirmar el precio exacto?
                    </p>
                    <p style="margin:0 0 14px; font-size:14px; color:#6b7280; line-height:1.6;">
                      Podemos hacer una visita técnica gratuita en tu domicilio en Gijón,
                      normalmente en 24–48 h. Sin compromiso.
                    </p>
                    <p style="margin:0; font-size:15px; color:#1f2933;">
                      📞 <a href="tel:684608811" style="color:#0f172a; font-weight:600; text-decoration:none;">
                        684 608 811
                      </a>
                      &nbsp;·&nbsp;
                      ✉️ <a href="mailto:pavimentosgijon@gmail.com"
                            style="color:#0f172a; font-weight:600; text-decoration:none;">
                        pavimentosgijon@gmail.com
                      </a>
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f8fafc; padding:24px 40px; text-align:center;
                       border-top:1px solid #e5e7eb;">
              <p style="margin:0 0 4px; font-size:13px; color:#9ca3af;">
                <strong style="color:#6b7280;">Pavimentos Gijón</strong> ·
                Avenida Schultz N 28 Bajo, Gijón, Asturias
              </p>
              <p style="margin:0; font-size:12px; color:#9ca3af; line-height:1.6;">
                Has recibido este email porque solicitaste un presupuesto en
                <a href="https://www.pavimentosgijon.es" style="color:#6b7280;">pavimentosgijon.es</a>.<br>
                No compartimos tu email con terceros ni enviamos publicidad.
              </p>
            </td>
          </tr>

        </table>
        <!-- /Card -->

      </td>
    </tr>
  </table>

</body>
</html>