<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tu estimación de reforma</title>
</head>
<body style="margin:0; padding:0; background-color:#f1f5f9;
             font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; color:#1f2933;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0"
         style="background-color:#f1f5f9; padding:32px 0;">
    <tr>
      <td class="text-center">

        <table width="600" cellpadding="0" cellspacing="0" border="0"
               style="max-width:600px; width:100%; background:#ffffff;
                      border-radius:16px; box-shadow:0 8px 30px rgba(0,0,0,0.08);
                      overflow:hidden;">

          <!-- HEADER -->
          <tr>
            <td style="background:linear-gradient(135deg,#0f172a,#1e293b);
                       padding:32px 40px; text-align:center;">
              <p style="margin:0 0 6px; font-size:12px; font-weight:600;
                         letter-spacing:0.12em; text-transform:uppercase;
                         color:rgba(255,255,255,0.55);">
                Pavimentos Gijón · Presupuesto online
              </p>
              <h1 style="margin:0; font-size:22px; font-weight:700;
                          color:#ffffff; line-height:1.35;">
                Hola {{ nombre }}, aquí tienes tu estimación
              </h1>
            </td>
          </tr>

          <!-- PRECIO + CTA juntos, visibles sin scroll -->
          <tr>
            <td style="padding:36px 40px 28px; text-align:center;">

              <p style="margin:0 0 6px; font-size:13px; color:#6b7280;">
                {% if tipo == 'ducha' %}Cambio de bañera por ducha · Gijón
                {% else %}Reforma integral de baño · Gijón{% endif %}
              </p>

              <p style="margin:0 0 4px; font-size:13px; font-weight:600;
                         color:#6b7280; text-transform:uppercase; letter-spacing:0.08em;">
                Tu estimación orientativa
              </p>
              <p style="margin:0 0 8px; font-size:48px; font-weight:800;
                         color:#0f172a; letter-spacing:-0.02em; line-height:1;">
                {{ rangoTexto }}
              </p>
              <p style="margin:0 0 28px; font-size:13px; color:#9ca3af;">
                Precio según tus respuestas · Visita técnica gratuita para confirmar
              </p>

              <!-- CTA justo después del precio -->
              <a href="{{ urlPdf }}"
                 style="display:inline-block; background:#0f172a; color:#ffffff;
                        font-size:17px; font-weight:700; text-decoration:none;
                        padding:18px 40px; border-radius:10px; line-height:1;">
                📄 Descargar mi presupuesto PDF
              </a>

              <p style="margin:14px 0 0; font-size:12px; color:#9ca3af;">
                Link personal · Disponible en cualquier momento
              </p>

            </td>
          </tr>

          <!-- SEPARADOR -->
          <tr>
            <td style="padding:0 40px;">
              <div style="border-top:1px solid #f1f5f9;"></div>
            </td>
          </tr>

          <!-- QUÉ INCLUYE — para los que quieren más info -->
          <tr>
            <td style="padding:24px 40px 28px;">
              <p style="margin:0 0 14px; font-size:15px; font-weight:600; color:#1f2933;">
                ¿Qué suele incluir esta estimación?
              </p>

              {% if tipo == 'ducha' %}
                {% set items = [
                  '🛁 Retirada de la bañera y gestión de escombros',
                  '🚿 Suministro e instalación del plato de ducha',
                  '🪟 Mampara según el espacio disponible',
                  '🧱 Adaptación del alicatado existente',
                  '🔧 Fontanería y remates necesarios',
                ] %}
              {% else %}
                {% set items = [
                  '🏗️ Demolición y gestión de escombros',
                  '🧱 Alicatado completo de paredes y suelo',
                  '🚿 Instalación de plato de ducha o bañera',
                  '🪠 Sanitarios, mueble y grifería',
                  '🔧 Fontanería e instalación eléctrica',
                ] %}
              {% endif %}

              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                {% for item in items %}
                <tr>
                  <td style="padding:7px 0; font-size:14px; color:#374151;
                              border-bottom:1px solid #f8fafc; line-height:1.4;">
                    {{ item }}
                  </td>
                </tr>
                {% endfor %}
              </table>
            </td>
          </tr>

          <!-- VISITA GRATUITA -->
          <tr>
            <td style="padding:0 40px 32px;">
              <table width="100%" cellpadding="16" cellspacing="0" border="0"
                     style="background:#f8fafc; border-radius:10px;">
                <tr>
                  <td>
                    <p style="margin:0 0 6px; font-size:14px; font-weight:700; color:#1f2933;">
                      ¿Quieres el precio exacto?
                    </p>
                    <p style="margin:0 0 10px; font-size:13px; color:#6b7280; line-height:1.6;">
                      Visita técnica gratuita en tu domicilio en Gijón, en 24–48 h. Sin compromiso.
                    </p>
                    <p style="margin:0; font-size:14px;">
                      📞 <a href="tel:684608811"
                            style="color:#0f172a; font-weight:700; text-decoration:none;">
                        684 608 811
                      </a>
                      &nbsp;·&nbsp;
                      ✉️ <a href="mailto:pavimentosgijon@gmail.com"
                            style="color:#0f172a; font-weight:700; text-decoration:none;">
                        pavimentosgijon@gmail.com
                      </a>
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background:#f8fafc; padding:20px 40px; text-align:center;
                       border-top:1px solid #e5e7eb;">
              <p style="margin:0 0 4px; font-size:12px; color:#9ca3af;">
                <strong style="color:#6b7280;">Pavimentos Gijón</strong> ·
                Avenida Schultz N 28 Bajo, Gijón
              </p>
              <p style="margin:0; font-size:11px; color:#9ca3af; line-height:1.6;">
                Recibiste este email porque solicitaste un presupuesto en
                <a href="https://www.pavimentosgijon.es" style="color:#9ca3af;">pavimentosgijon.es</a>.
                No compartimos tu email con terceros.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
