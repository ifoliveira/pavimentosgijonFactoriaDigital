{% block stylesheets %}
<script>
document.addEventListener('DOMContentLoaded', function () {

  const toggle = document.querySelector('.menu-toggle');
  const mobileNav = document.querySelector('.mobile-nav');

  if (!toggle || !mobileNav) return;

  toggle.addEventListener('click', function () {
    mobileNav.classList.toggle('open');

    // Bloquear scroll cuando esté abierto
    document.body.classList.toggle('nav-open');
  });

  // Cerrar al pulsar cualquier enlace
  mobileNav.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', function () {
      mobileNav.classList.remove('open');
      document.body.classList.remove('nav-open');
    });
  });

});
</script>


<script async src="https://www.googletagmanager.com/gtag/js?id=G-Q9J4NFZXEG"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-Q9J4NFZXEG');
</script>

<script>
  function gtag_report_conversion() {
    if (typeof gtag !== 'undefined') {
            gtag('event', 'conversion', {
            'send_to': 'AW-17884247583/qCT9COHY0OsbEJ_s789C',
            'value': 1.0,
            'currency': 'EUR'
            });
        }
    }
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const isOpen = item.classList.contains('open');

        // Solo uno abierto a la vez (quita esto si quieres varios abiertos)
        document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
        document.querySelectorAll('.faq-q[aria-expanded="true"]').forEach(b => b.setAttribute('aria-expanded', 'false'));

        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>

<script>

let scrollEvents = {
    25: false,
    50: false,
    75: false,
    100: false
};

window.addEventListener('scroll', function () {

    let scrollTop = window.scrollY;
    let docHeight = document.body.scrollHeight - window.innerHeight;

    let scrollPercent = Math.round((scrollTop / docHeight) * 100);

    function sendEvent(percent) {

        fetch('/track-event', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                evento: 'scroll_' + percent,
                url: window.location.pathname
            })
        });

    }

    if (scrollPercent >= 25 && !scrollEvents[25]) {
        scrollEvents[25] = true;
        sendEvent(25);
    }

    if (scrollPercent >= 50 && !scrollEvents[50]) {
        scrollEvents[50] = true;
        sendEvent(50);
    }

    if (scrollPercent >= 75 && !scrollEvents[75]) {
        scrollEvents[75] = true;
        sendEvent(75);
    }

    if (scrollPercent >= 100 && !scrollEvents[100]) {
        scrollEvents[100] = true;
        sendEvent(100);
    }

});

</script>

{% endblock %}

</body>
</html>

