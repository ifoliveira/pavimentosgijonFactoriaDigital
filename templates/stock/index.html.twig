{% extends 'base.html.twig' %}

{% block title %}Stock{% endblock %}
{% block cabecera %}Stock{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Stock actual</li>{% endblock %}

{% block body %}
{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
{% endfor %}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="border-bottom title-part-padding">
                <h4 class="card-title mb-0">Stock actual</h4>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table id="multi_control" class="table table-striped table-bordered display" style="width:100%">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Referencia</th>
                                <th class="text-end">Cantidad</th>
                                <th class="text-end">Coste medio</th>
                                <th class="text-end">Valor stock</th>
                                <th>Producto asociado</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            {% for item in stock %}
                                {% set cantidad = item.cantidadStock|default(0) %}
                                {% set valor = item.valorStock|default(0) %}
                                {% set costeMedio = item.costeMedio|default(0) %}

                                <tr>
                                    <td>
                                        <span class="font-medium">
                                            {{ item.descripcion ?: 'Producto sin descripción' }}
                                        </span>
                                    </td>

                                    <td>
                                        {{ item.referenciaProveedor ?: '-' }}
                                    </td>

                                    <td class="text-end">
                                        {{ cantidad|number_format(2, ',', '.') }}
                                    </td>

                                    <td class="text-end">
                                        {{ costeMedio|number_format(2, ',', '.') }} €
                                    </td>

                                    <td class="text-end fw-semibold">
                                        {{ valor|number_format(2, ',', '.') }} €
                                    </td>
                                    <td>
                                        <form method="post"
                                            action="{{ path('stock_asociar_producto') }}"
                                            class="d-flex gap-1 align-items-center">

                                            <input type="hidden" name="_token" value="{{ csrf_token('stock_asociar_producto') }}">

                                            <input type="hidden" name="descripcion" value="{{ item.descripcion }}">
                                            <input type="hidden" name="referenciaProveedor" value="{{ item.referenciaProveedor }}">
                                            <input type="hidden" name="facturaProveedorId" value="{{ item.facturaProveedorId|default('') }}">

                                            <select name="productoId" class="form-select form-select-sm" style="min-width: 220px;">
                                                <option value="">Sin asociar</option>

                                                {% for producto in productos %}
                                                    <option value="{{ producto.id }}"
                                                        {% if item.productoId is defined and item.productoId == producto.id %}selected{% endif %}>
                                                        {{ producto.descripcionPd }}
                                                    </option>
                                                {% endfor %}
                                            </select>

                                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                                OK
                                            </button>
                                        </form>
                                    </td>                                    

                                    <td>
                                        {% if cantidad > 0 %}
                                            <span class="badge bg-success">En stock</span>
                                        {% elseif cantidad == 0 %}
                                            <span class="badge bg-secondary">Sin stock</span>
                                        {% else %}
                                            <span class="badge bg-danger">Stock negativo</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if item.facturaProveedorId %}
                                            <a href="{{ path('factura_proveedor_pdf', { id: item.facturaProveedorId }) }}"
                                            class="text-inverse pr-2"
                                            target="_blank"
                                            title="Ver factura proveedor">
                                                <i class="ti-file"></i>
                                            </a>
                                        {% else %}
                                            <span class="text-muted" title="Sin factura asociada">
                                                <i class="ti-file"></i>
                                            </span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="8" class="text-muted text-center p-4">
                                        No hay movimientos de stock registrados.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>

                        <tfoot>
                            <tr>
                                <th>Producto</th>
                                <th>Referencia</th>
                                <th class="text-end">Cantidad</th>
                                <th class="text-end">Coste medio</th>
                                <th class="text-end">Valor stock</th>
                                <th>Producto asociado</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block jscustom %}
    <script src="{{ asset('assets/extra-libs/datatables.net-bs4/js/dataTables.responsive.min.js') }}"></script>

    <script>
        $(document).ready(function () {
            $('#multi_control').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.10.16/i18n/Spanish.json'
                },
                order: [[0, 'asc']]
            });
        });
    </script>
{% endblock %}