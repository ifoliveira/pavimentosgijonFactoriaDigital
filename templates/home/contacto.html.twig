{% extends 'layouts/base_public.html.twig' %}

{% block title %}Contacto con Pavimentos Gijón. Reformamos tu baño{% endblock %}
{% block meta_description %}Contáctanos para renovar tu baño. Especialistas en reformas de baño en Gijón desde hace más de 30 años.{% endblock %}
{% block og_title %}Contacta con Pavimentos Gijón{% endblock %}
{% block og_description %}Pregúntanos o ven a visitarnos. Especialistas en reformas de baño en Gijón.{% endblock %}

{% block body %}

<section class="hero-decision">
  <div class="container">

    <h1>Contacta con nosotros<br>Pregúntanos o ven a visitarnos</h1>

    <p class="hero-sub">
      Av. de Schultz 28 Bajo, Gijón ·
      985 391 326 · 684 608 811 ·
      buzon@pavimentosgijon.es
    </p>

    <div class="hero-actions">
      <a class="btn btn-primary"
         href="https://api.whatsapp.com/send/?phone=684608811" target="_blank">
        💬 Escríbenos por WhatsApp
      </a>

      <a class="btn btn-secondary" href="{{ path('iapresupuesto') }}">
        🧮 Calcular presupuesto online
      </a>
    </div>

  </div>

  <div class="resenas-hero">
    <div class="review-highlight">
      <p>
        <span>✅ Respuesta rápida</span>
        <span>✅ Presupuesto sin compromiso</span>
        <span>✅ Especialistas en Gijón</span>
      </p>
      <p>Más de 30 años reformando baños en Gijón.</p>
    </div>
  </div>

</section>



<section class="seo-text">

  <div class="container">

    <h2>Cómo contactar con nosotros</h2>

    <div class="contact-box-main">

      <div class="contact-box">
        <div class="icon"><i class="bi bi-geo-alt"></i></div>
        <h4>Visítanos en</h4>
        <p>Avenida de Schultz 28 Bajo, Gijón, 33209 Asturias</p>
      </div>

      <div class="contact-box">
        <div class="icon"><i class="bi bi-envelope"></i></div>
        <h4>Email</h4>
        <p><a href="mailto:buzon@pavimentosgijon.es">buzon@pavimentosgijon.es</a></p>
      </div>

      <div class="contact-box">
        <div class="icon"><i class="bi bi-telephone"></i></div>
        <h4>Llámanos</h4>
        <p><a href="tel:985391326">985 391 326</a> — <a href="tel:684608811">684 608 811</a></p>
      </div>

      <div class="contact-box">
        <div class="icon"><i class="bi bi-whatsapp"></i></div>
        <h4>WhatsApp</h4>
        <p>
          <a href="https://api.whatsapp.com/send/?phone=684608811" target="_blank">
            684 608 811
          </a>
        </p>
      </div>

    </div>

  </div>

</section>



<section class="home-image">

  <div class="container">

    <h2>Dónde estamos</h2>

    <div class="map-box">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2892.4075655057027!2d-5.667858823397168!3d43.535545460031926!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd367c8a9e991bb9%3A0x586b22167b19addc!2sAzulejos%20y%20Pavimentos%20Gijon!5e0!3m2!1ses!2ses!4v1705528892095!5m2!1ses!2ses"
        width="100%" height="400" style="border:0;"
        allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>

  </div>

</section>

{% endblock %}