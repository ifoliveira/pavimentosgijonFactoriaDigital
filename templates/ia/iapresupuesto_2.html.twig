{% extends 'layouts/base_public.html.twig' %}

{% block title %}Presupuesto online de reforma de baño en Gijón | Precio inmediato{% endblock %}
{% block meta_description %}Calcula el precio de tu reforma de baño en Gijón en 2 minutos. Cambio de bañera por ducha o reforma integral. Presupuesto orientativo al instante.{% endblock %}
{% block og_title %}Presupuesto reforma de baño en Gijón{% endblock %}
{% block og_description %}Cuéntanos qué necesitas y obtén un precio orientativo inmediato. Sin compromiso, sin teléfono.{% endblock %}

{% block body %}

{# ══════════════════════════════════════════════════════════════
   SECCIÓN PRINCIPAL
   Flujo de vistas: selector → chat → galeria → datos → (result)
   Ninguna usa position:fixed ni modales. Todo en el flujo normal.
══════════════════════════════════════════════════════════════ #}
<section class="presupuesto-main">
  <div class="container">

    {# ════════════════════════════════
       VISTA 1 — Selector A / B
    ════════════════════════════════ #}
    <div id="view-selector">

      <p class="wizard-eyebrow">Presupuesto online · Gijón</p>
      <h1 class="wizard-question" style="font-size: clamp(24px, 5vw, 34px);">¿Qué reforma necesitas?</h1>
      <p class="wizard-hint">Elige y responde unas preguntas rápidas. Precio orientativo al instante.</p>

      <div class="choice-grid">

        <button class="choice-card" onclick="iniciarChat('ducha')">
          <span class="choice-icon">🛁</span>
          <strong>Cambiar bañera por ducha</strong>
          <span class="choice-desc">Plato de ducha moderno. Obra en 2–3 días.</span>
          <span class="choice-price">Desde 2.000 €</span>
        </button>

        <button class="choice-card" onclick="iniciarChat('baño_completo')">
          <span class="choice-icon">🏠</span>
          <strong>Reforma integral de baño</strong>
          <span class="choice-desc">Renovación completa: suelo, paredes, sanitarios.</span>
          <span class="choice-price">Desde 6.000 €</span>
        </button>

      </div>

      <div class="presupuesto-social">
        <span><span class="stars-inline">★★★★☆</span> <strong>4,3</strong> en reseñas</span>
        <span>✅ Sin teléfono</span>
        <span>✅ Precio claro</span>
        <span>✅ 30 años en Gijón</span>
      </div>

    </div>

    {# ════════════════════════════════
       VISTA 2 — Chat wizard
    ════════════════════════════════ #}
    <div id="view-chat" style="display:none;">

      <div class="progress-wrap">
        <div class="progress-track">
          <div class="progress-fill" id="progressFill" style="width:0%"></div>
        </div>
        <span class="progress-label" id="progressLabel">Iniciando…</span>
      </div>

      <div class="chat-history" id="chatHistory"></div>

      <div class="chat-input-wrap" id="inputTextWrap" style="display:none;">
        <input
          type="text"
          id="userInput"
          class="chat-free-input"
          placeholder="Escribe tu respuesta…"
          autocomplete="off"
          inputmode="text"
        />
        <button class="chat-send-btn" id="sendBtn" onclick="enviarRespuesta()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </div>

      <div class="chat-options-wrap" id="optionsWrap" style="display:none;"></div>

      <button class="btn-back" onclick="resetChat()">← Cambiar tipo de reforma</button>
    </div>

    {# ════════════════════════════════
       VISTA 3 — Galería mientras calcula
       Reemplaza completamente el modal del carrusel.
       Es una vista normal en el flujo de página.
    ════════════════════════════════ #}
    <div id="view-galeria" style="display:none;">

      <div class="galeria-header">
        <p class="wizard-eyebrow">Un momento…</p>
        <h2 class="wizard-question" style="font-size: clamp(20px, 4vw, 28px);">Preparando tu presupuesto</h2>
        <p class="wizard-hint" id="galeria-subtexto">Calculando materiales, mano de obra y medidas…</p>
      </div>

      {# Carrusel de fotos reales #}
      <div class="galeria-carrusel" id="galeriaCarrusel">

        <div class="galeria-slide active">
          <img src="{{ asset('img/bano_homogeneo_4.jpg') }}" alt="Reforma real de baño en Gijón">
          <div class="galeria-slide-texto">Reforma real · Gijón</div>
        </div>

        <div class="galeria-slide">
          <img src="{{ asset('img/bano_homogeneo_1.jpg') }}" alt="Plato de ducha antideslizante">
          <div class="galeria-slide-texto">Plato de ducha antideslizante</div>
        </div>

        <div class="galeria-slide">
          <img src="{{ asset('img/bano_homogeneo_2.jpg') }}" alt="Reforma baño completo">
          <div class="galeria-slide-texto">Reforma baño completo</div>
        </div>

        <div class="galeria-slide">
          <img src="{{ asset('img/bano_homogeneo_3.jpg') }}" alt="Reforma integral de baño">
          <div class="galeria-slide-texto">Reforma integral de baño</div>
        </div>

      </div>

      {# Indicadores de slide (dots) #}
      <div class="galeria-dots" id="galeriaDots">
        <span class="galeria-dot active"></span>
        <span class="galeria-dot"></span>
        <span class="galeria-dot"></span>
        <span class="galeria-dot"></span>
      </div>

      {# Barra de progreso ficticia #}
      <div class="galeria-progress-wrap">
        <div class="galeria-progress-bar" id="galeriaProgressBar"></div>
      </div>
      <p class="galeria-progress-label" id="galeriaProgressLabel">Analizando medidas…</p>

      {# Botón oculto — aparece cuando el cálculo termina #}
      <div id="galeria-cta" style="display:none;">
        <p class="galeria-listo-text">✅ ¡Tu presupuesto está listo!</p>
        <button class="btn btn-primary galeria-btn" onclick="mostrarVistaDatos()">
          📩 Recibir mi estimación y PDF
        </button>
      </div>

    </div>

    {# ════════════════════════════════
       VISTA 4 — Datos para el PDF
       Reemplaza el modal pdf-modal.
       Vista limpia, sin fixed, funciona en todos los móviles.
    ════════════════════════════════ #}
    <div id="view-datos" style="display:none;">

      <div class="datos-card">
        <p class="wizard-eyebrow">Último paso</p>
        <h2 class="wizard-question" style="font-size: clamp(22px, 5vw, 30px);">¿Dónde te enviamos tu estimación?</h2>
        <p class="wizard-hint">Te enviamos la estimación de precio y el link para descargar el PDF completo. Sin publicidad.</p>

        <div class="datos-form">

          <div class="pdf-field">
            <label for="pdf-nombre">Tu nombre</label>
            <input type="text" id="pdf-nombre" placeholder="Ej. María García"
                   autocomplete="name" inputmode="text" />
            <span class="field-error" id="error-nombre"></span>
          </div>

          <div class="pdf-field">
            <label for="pdf-email">Tu email</label>
            <input type="email" id="pdf-email" placeholder="correo@ejemplo.com"
                   autocomplete="email" inputmode="email" />
            <span class="field-error" id="error-email"></span>
          </div>

          <div id="pdf-descargando" style="display:none; text-align:center; padding:12px 0; color:#6b7280; font-size:15px;">
            ⏳ Generando tu PDF…
          </div>

          <button id="pdf-descargar" class="btn btn-primary datos-submit">
            📩 Enviarme la estimación por email
          </button>

          <button class="btn-back" onclick="mostrarVistaGaleria()">← Volver</button>

        </div>

        <p style="margin-top:20px; font-size:13px; color:#9ca3af; text-align:center;">
          🔒 Datos privados · No compartimos tu email · PDF gratuito
        </p>
      </div>

    </div>

  </div>{# /container #}
</section>

{# ══════════════════════════════════════════════
   FAQ
══════════════════════════════════════════════ #}
<section class="home-faq" id="seccionFaq">
  <div class="container">
    <div class="faq-head">
      <h2>Preguntas frecuentes</h2>
      <p>Todo lo que necesitas saber antes de pedir presupuesto.</p>
    </div>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-q" aria-expanded="false">
          ¿El presupuesto que me da aquí es el definitivo?
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-a">
          <p>Es orientativo. El precio definitivo lo confirmamos tras una visita técnica gratuita en tu domicilio en Gijón, normalmente en 24–48 h.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-q" aria-expanded="false">
          ¿Tengo que dar mi teléfono para obtener el presupuesto?
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-a">
          <p>No. El presupuesto orientativo es completamente anónimo. Solo si quieres el PDF detallado o la visita te pediremos contacto.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-q" aria-expanded="false">
          ¿En cuánto tiempo puede empezar la obra?
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-a">
          <p>Normalmente podemos empezar en 2-4 semanas desde la confirmación del presupuesto definitivo. Aunque depende de la complejidad de la obra y los materiales elegidos</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ═══════════════════════════════════════════════════════════
//  ESTADO GLOBAL
// ═══════════════════════════════════════════════════════════
const RUTA_VOLVER = "{{ path('platoducha') }}";

let state = {
  tipo:               null,
  paso:               0,
  jsonActual:         {},
  esperandoRespuesta: false,
  totalPasosEstimado: 8,
};

// Control carrusel galería
let galeriaTimer        = null;
let galeriaSlideActual  = 0;
let pgCarruselCompleto  = false;
let calculoTerminado    = false;

// Textos que van rotando en la barra de progreso ficticia
const TEXTOS_PROGRESO = [
  'Analizando medidas…',
  'Calculando superficie de azulejo…',
  'Estimando mampara y plato de ducha…',
  'Calculando horas de obra…',
  'Ajustando precio final…',
];

const LABELS = {
  medida_platoducha:   'Medidas bañera',
  medida_bano:         'Medidas del baño',
  entre_paredes:       'Entre dos paredes',
  zona_azulejos:       'Zona de azulejos',
  reposicion_azulejos: 'Reposición azulejos',
  mantener_escayola:   'Mantener escayola',
  accion_grifo:        'Cambiar grifo',
  tipo_griferia:       'Tipo de grifería',
  tipo_mampara:        'Mampara',
  banera_o_ducha:      'Bañera o ducha',
  bide_o_higienico:    'Bidé / higiénico',
  mueble_bano:         'Mueble de baño',
};

// ═══════════════════════════════════════════════════════════
//  NAVEGACIÓN ENTRE VISTAS
// ═══════════════════════════════════════════════════════════
function mostrarVista(id) {
  // Cambiar la vista
  ['view-selector','view-chat','view-galeria','view-datos'].forEach(v => {
    document.getElementById(v).style.display = (v === id) ? 'block' : 'none';
  });

  // FAQs solo visibles en el selector inicial
  const faq = document.getElementById('seccionFaq');
  if (faq) faq.style.display = (id === 'view-selector') ? '' : 'none';

  // Scroll al top de la página
  document.documentElement.scrollTop = 0;
  document.body.scrollTop = 0;
}

function mostrarVistaGaleria() { mostrarVista('view-galeria'); }
function mostrarVistaDatos()   {
  mostrarVista('view-datos');
  setTimeout(() => document.getElementById('pdf-nombre').focus(), 400);
}

// ═══════════════════════════════════════════════════════════
//  ARRANCAR CHAT
// ═══════════════════════════════════════════════════════════
function iniciarChat(tipo) {
  state = {
    tipo,
    paso: 0,
    jsonActual: {},
    esperandoRespuesta: false,
    totalPasosEstimado: tipo === 'ducha' ? 8 : 9,
  };
  limpiarHistorial();
  mostrarVista('view-chat');
  llamarAPI(null);
}

// ═══════════════════════════════════════════════════════════
//  LLAMADA API PASO A PASO
// ═══════════════════════════════════════════════════════════
async function llamarAPI(respuesta) {
  state.esperandoRespuesta = true;
  bloquearInput(true);

  try {
    mostrarTyping();

    const res = await fetch('/api/presupuesto/step', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        tipo:     state.tipo,
        paso:     state.paso,
        respuesta,
        json:     state.jsonActual,
      }),
    });

    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    await esperar(600);
    quitarTyping();

    state.jsonActual = data.json ?? state.jsonActual;

    if (data.fin) {
      finalizarChat();
    } else {
      state.paso = data.paso;
      actualizarProgreso(state.paso);
      mostrarBotBubble(data.pregunta);

      if (data.opciones && Object.keys(data.opciones).length > 0) {
        mostrarOpciones(data.opciones);
      } else {
        mostrarInputTexto();
      }
    }
  } catch (err) {
    quitarTyping();
    mostrarBotBubble('⚠️ Ha ocurrido un error. Por favor, recarga la página e inténtalo de nuevo.');
    console.error('API error:', err);
  } finally {
    state.esperandoRespuesta = false;
  }
}

// ═══════════════════════════════════════════════════════════
//  FINALIZAR CHAT → GALERÍA + CÁLCULO EN PARALELO
// ═══════════════════════════════════════════════════════════
async function finalizarChat() {
  if (typeof gtag_report_conversion === 'function') {
    setTimeout(gtag_report_conversion, 300);
  }

  // Resetear flags
  pgCarruselCompleto = false;
  calculoTerminado   = false;

  // Mostrar galería (la barra ficticia arranca aquí)
  mostrarVista('view-galeria');
  iniciarGaleria();
  iniciarBarraFicticia();

  // Cálculo real en paralelo
  try {
    const res = await fetch('/api/presupuesto/calculate', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tipo: state.tipo, json: state.jsonActual }),
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    await res.json(); // resultado disponible si lo necesitas
    calculoTerminado = true;
    mostrarBotonListoSiPuede();
  } catch (err) {
    console.error('Calculate error:', err);
    // Aunque falle el cálculo mostramos el botón igualmente
    calculoTerminado = true;
    mostrarBotonListoSiPuede();
  }
}

// Muestra el CTA solo cuando AMBAS condiciones se cumplen:
// carrusel ha dado una vuelta Y el cálculo ha terminado
function mostrarBotonListoSiPuede() {
  if (!calculoTerminado || !pgCarruselCompleto) return;

  detenerGaleria();
  document.getElementById('galeria-subtexto').textContent = '¡Listo! Tu presupuesto está calculado.';
  document.getElementById('galeriaProgressLabel').textContent = '✅ Cálculo completado';
  document.getElementById('galeriaProgressBar').style.width = '100%';
  document.getElementById('galeriaProgressBar').style.background = '#22c55e';

  const cta = document.getElementById('galeria-cta');
  cta.style.display = 'block';
  cta.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ═══════════════════════════════════════════════════════════
//  GALERÍA — carrusel de fotos
// ═══════════════════════════════════════════════════════════
function iniciarGaleria() {
  galeriaSlideActual = 0;
  const slides = document.querySelectorAll('#galeriaCarrusel .galeria-slide');
  const dots   = document.querySelectorAll('#galeriaDots .galeria-dot');
  let vueltas  = 0;

  slides.forEach(s => s.classList.remove('active'));
  dots.forEach(d => d.classList.remove('active'));
  slides[0].classList.add('active');
  dots[0].classList.add('active');

  detenerGaleria();

  galeriaTimer = setInterval(() => {
    slides[galeriaSlideActual].classList.remove('active');
    dots[galeriaSlideActual].classList.remove('active');

    galeriaSlideActual = (galeriaSlideActual + 1) % slides.length;
    if (galeriaSlideActual === 0) vueltas++;

    slides[galeriaSlideActual].classList.add('active');
    dots[galeriaSlideActual].classList.add('active');

    if (vueltas >= 1) {
      pgCarruselCompleto = true;
      mostrarBotonListoSiPuede();
    }
  }, 2800);
}

function detenerGaleria() {
  if (galeriaTimer) { clearInterval(galeriaTimer); galeriaTimer = null; }
}

// ═══════════════════════════════════════════════════════════
//  BARRA DE PROGRESO FICTICIA
// ═══════════════════════════════════════════════════════════
function iniciarBarraFicticia() {
  const bar   = document.getElementById('galeriaProgressBar');
  const label = document.getElementById('galeriaProgressLabel');
  let pct     = 0;
  let textoIdx = 0;

  bar.style.width      = '0%';
  bar.style.background = '';
  label.textContent    = TEXTOS_PROGRESO[0];
  document.getElementById('galeria-cta').style.display = 'none';

  const interval = setInterval(() => {
    // Avanza rápido hasta 85%, luego se frena esperando al cálculo real
    const incremento = pct < 60 ? 4 : pct < 85 ? 1.5 : 0.3;
    pct = Math.min(pct + incremento, 92);
    bar.style.width = pct + '%';

    // Rotar textos
    const nuevoIdx = Math.min(Math.floor(pct / 20), TEXTOS_PROGRESO.length - 1);
    if (nuevoIdx !== textoIdx) {
      textoIdx = nuevoIdx;
      label.textContent = TEXTOS_PROGRESO[textoIdx];
    }

    if (pct >= 92) clearInterval(interval);
  }, 180);
}

// ═══════════════════════════════════════════════════════════
//  ENVÍO POR EMAIL — ya no descarga blob
//  El servidor guarda el lead, genera token y envía el email
// ═══════════════════════════════════════════════════════════
async function descargarPdf() {
  const nombre = document.getElementById('pdf-nombre').value.trim();
  const email  = document.getElementById('pdf-email').value.trim();

  document.getElementById('error-nombre').textContent = '';
  document.getElementById('error-email').textContent  = '';

  let valid = true;
  if (!nombre) {
    document.getElementById('error-nombre').textContent = 'Este campo es obligatorio';
    valid = false;
  }
  if (!email || !email.includes('@')) {
    document.getElementById('error-email').textContent = 'Email no válido';
    valid = false;
  }
  if (!valid) return;

  const btnDescargar = document.getElementById('pdf-descargar');
  const descargando  = document.getElementById('pdf-descargando');

  btnDescargar.disabled     = true;
  descargando.style.display = 'block';
  descargando.textContent   = '⏳ Enviando tu estimación…';

  try {
    const res = await fetch('/api/presupuesto/pdf', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tipo: state.tipo, json: state.jsonActual, nombre, email }),
    });

    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    if (!data.ok) throw new Error('Respuesta ko del servidor');

    mostrarConfirmacionEmail(nombre, email);

  } catch (err) {
    descargando.style.display = 'none';
    btnDescargar.disabled = false;
    document.getElementById('error-email').textContent = '⚠️ Error al enviar. Inténtalo de nuevo.';
    console.error('Email error:', err);
  }
}

// Pantalla de confirmación tras enviar el email
function mostrarConfirmacionEmail(nombre, email) {
  const card = document.querySelector('.datos-card');
  card.innerHTML = `
    <div style="text-align:center; padding:20px 0;">
      <div style="font-size:56px; margin-bottom:20px;">📬</div>
      <p class="wizard-eyebrow">¡Listo!</p>
      <h2 class="wizard-question" style="font-size:clamp(20px,4vw,28px); margin-bottom:12px;">
        Te hemos enviado la estimación
      </h2>
      <p class="wizard-hint" style="margin-bottom:8px;">
        Revisa tu bandeja de entrada en <strong>${escaparHTML(email)}</strong>.<br>
        Si no aparece en unos minutos, comprueba la carpeta de spam.
      </p>
      <p style="font-size:14px; color:#9ca3af; margin-bottom:32px;">
        El email incluye tu estimación de precio y el link para descargar el PDF completo.
      </p>
      <a href="tel:684608811"
         style="display:inline-block; background:#1e293b; color:#fff;
                padding:14px 28px; border-radius:10px; font-weight:700;
                font-size:16px; text-decoration:none; margin-bottom:12px;">
        📞 Llamar ahora · 684 608 811
      </a><br>
      <button class="btn-back" onclick="resetChat()" style="margin-top:12px;">
        ← Calcular otro presupuesto
      </button>
    </div>
  `;
}

// ═══════════════════════════════════════════════════════════
//  HELPERS CHAT
// ═══════════════════════════════════════════════════════════
function enviarRespuesta() {
  if (state.esperandoRespuesta) return;
  const input = document.getElementById('userInput');
  const texto = input.value.trim();
  if (!texto) { input.focus(); return; }
  ocultarInputTexto();
  ocultarOpciones();
  mostrarUserBubble(texto);
  input.value = '';
  llamarAPI(texto);
}

function seleccionarOpcion(label, value) {
  if (state.esperandoRespuesta) return;
  document.querySelectorAll('.opt-btn').forEach(b => {
    b.disabled = true;
    if (b.dataset.value === value) b.classList.add('selected');
  });
  ocultarOpciones();
  mostrarUserBubble(label);
  llamarAPI(label);
}

function mostrarBotBubble(texto) {
  const history = document.getElementById('chatHistory');
  const wrap    = document.createElement('div');
  wrap.className = 'bubble-bot-wrap';
  wrap.innerHTML = `<div class="bubble-avatar">🧑‍🔧</div><div class="bubble-bot">${escaparHTML(texto)}</div>`;
  history.appendChild(wrap);
  scrollAlFinal();
}

function mostrarUserBubble(texto) {
  const history = document.getElementById('chatHistory');
  const wrap    = document.createElement('div');
  wrap.className = 'bubble-user-wrap';
  wrap.innerHTML = `<div class="bubble-user">${escaparHTML(texto)}</div>`;
  history.appendChild(wrap);
}

function mostrarTyping() {
  const history = document.getElementById('chatHistory');
  const wrap    = document.createElement('div');
  wrap.className = 'bubble-bot-wrap';
  wrap.id = 'typingBubble';
  wrap.innerHTML = `<div class="bubble-avatar">🧑‍🔧</div><div class="bubble-bot"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
  history.appendChild(wrap);
  scrollAlFinal();
}

function quitarTyping() {
  const el = document.getElementById('typingBubble');
  if (el) el.remove();
}

function mostrarOpciones(opciones) {
  const wrap = document.getElementById('optionsWrap');
  wrap.innerHTML = '';
  wrap.style.display = 'flex';
  for (const [value, opcion] of Object.entries(opciones)) {
    const label = typeof opcion === 'object' ? opcion.label : opcion;
    const btn   = document.createElement('button');
    btn.className     = 'opt-btn';
    btn.dataset.value = value;
    btn.textContent   = label;
    btn.onclick = () => seleccionarOpcion(label, value);
    wrap.appendChild(btn);
  }
  document.getElementById('inputTextWrap').style.display = 'none';
  scrollAlFinal();
}

function ocultarOpciones() {
  const wrap = document.getElementById('optionsWrap');
  wrap.style.display = 'none';
  wrap.innerHTML = '';
}

function mostrarInputTexto() {
  document.getElementById('inputTextWrap').style.display = 'flex';
  ocultarOpciones();
  bloquearInput(false);
  setTimeout(() => document.getElementById('userInput').focus(), 300);
  scrollAlFinal();
}

function ocultarInputTexto() {
  document.getElementById('inputTextWrap').style.display = 'none';
}

function bloquearInput(bloquear) {
  const input = document.getElementById('userInput');
  const btn   = document.getElementById('sendBtn');
  if (input) input.disabled = bloquear;
  if (btn)   btn.disabled   = bloquear;
}

function actualizarProgreso(paso) {
  const pct = Math.min(Math.round(((paso - 1) / state.totalPasosEstimado) * 100), 95);
  document.getElementById('progressFill').style.width  = pct + '%';
  document.getElementById('progressLabel').textContent = `Pregunta ${paso}`;
}

function scrollAlFinal() {
  const h = document.getElementById('chatHistory');
  if (h) h.scrollTop = h.scrollHeight;
  setTimeout(() => {
    const optWrap = document.getElementById('optionsWrap');
    const inpWrap = document.getElementById('inputTextWrap');
    const target  = (optWrap && optWrap.style.display !== 'none') ? optWrap : inpWrap;
    if (target && target.style.display !== 'none') {
      target.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }, 100);
}

function limpiarHistorial() {
  document.getElementById('chatHistory').innerHTML            = '';
  document.getElementById('optionsWrap').innerHTML           = '';
  document.getElementById('optionsWrap').style.display       = 'none';
  document.getElementById('inputTextWrap').style.display     = 'none';
  document.getElementById('progressFill').style.width        = '0%';
  document.getElementById('progressLabel').textContent       = 'Iniciando…';
}

function resetChat() {
  detenerGaleria();
  limpiarHistorial();
  mostrarVista('view-selector');
}

function escaparHTML(str) {
  return String(str)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
    .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function esperar(ms) { return new Promise(r => setTimeout(r, ms)); }

// ═══════════════════════════════════════════════════════════
//  LISTENERS
// ═══════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {

  // Enter en el chat
  document.getElementById('userInput').addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); enviarRespuesta(); }
  });

  // Botón descargar PDF
  document.getElementById('pdf-descargar').addEventListener('click', descargarPdf);

  // Enter en campos del formulario
  ['pdf-nombre', 'pdf-email'].forEach(id => {
    document.getElementById(id).addEventListener('keydown', e => {
      if (e.key === 'Enter') descargarPdf();
    });
  });

});
</script>
{% endblock %}
