{% extends 'base.html.twig' %}

{# ----------------------------------------------------------------
   CSS específico de esta página
---------------------------------------------------------------- #}
{% block stylesheets %}
    <link href="{{ asset('assets/libs/jquery-steps/jquery.steps.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/libs/jquery-steps/steps.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/libs/magnific-popup/dist/magnific-popup.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/libs/summernote/dist/summernote-bs4.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/extra-libs/prism/prism.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/libs/select2/dist/css/select2.min.css') }}" rel="stylesheet">
{% endblock %}

{% block title %}Resumen económico{% endblock %}
{% block cabecera %}Resumen económico{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Resumen económico</li>{% endblock %}

{% block body %}
    <div class="row">
        {% for presupuesto in presupuestos %}
            <div class="col-md-4 col-lg-4 col-xl-4">
                <div class="card text-center alert-dismissible fade show alert p-0 card-hover" role="alert">
                    <div class="card-body">
                        {# AVISO: no anidar <a> dentro de <a> — separados #}
                        <a href="{{ path('presupuestos_show', {'id': presupuesto.id}) }}" class="font-medium link">
                            {{ presupuesto.clientePe.direccionCl }} ({{ presupuesto.manoobraPe }})
                        </a>
                        <h5 class="card-title">
                            {{ presupuesto.clientePe.nombreCl }} - {{ presupuesto.clientePe.telefono1Cl }}
                        </h5>
                        {# AVISO: <td> fuera de tabla — reemplazado por span #}
                        <h5 class="card-text">
                            Pendiente:
                            <span class="float-right">
                                {{ (presupuesto.importetotPe + presupuesto.importemanoobra - presupuesto.ticket.TotalPagos - presupuesto.impmanoobraPagado) | format_currency('EUR', locale='es') }}
                            </span>
                        </h5>
                        <p class="card-text">
                            Total:
                            <span class="float-right">
                                {{ (presupuesto.importetotPe + presupuesto.importemanoobra) | format_currency('EUR', locale='es') }}
                            </span>
                        </p>
                        <p class="card-text">
                            Total Pagado:
                            <span class="float-right">
                                {{ (presupuesto.ticket.TotalPagos + presupuesto.impmanoobraPagado) | format_currency('EUR', locale='es') }}
                            </span>
                        </p>
                    </div>

                    <div class="card-body pt-0">
                        {% for economicpresu in presupuesto.economicpresus %}
                            {% if economicpresu.estadoEco == 1 and economicpresu.debehaberEco == 'D' %}
                                <b>{{ economicpresu.conceptoEco }} - Importe: {{ economicpresu.importeEco | format_currency('EUR', locale='es') }}</b><br>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <div class="d-flex justify-content-between px-3 pb-3">
                        <a href="#"
                           class="btn btn-light-warning text-secondary font-weight-medium d-block w-100 mx-1 btn-pagar-obrero"
                           data-pagos='{{ presupuesto.economicPagosPdtes | map(p => {id: p.id, concepto: p.conceptoEco, monto: p.importeEco}) | json_encode }}'
                           data-presupuesto="{{ presupuesto.id }}">
                            <i class="ti ti-money"></i> Pagos
                        </a>
                        <a href="#"
                           class="btn btn-light-primary text-secondary font-weight-medium d-block w-100 mx-1 btn-cobros"
                           data-presupuesto="{{ presupuesto.id }}">
                            Cobros
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}

{% block leftpart %}
    <div class="left-part bg-light dashboard-right-part fixed-left-part">
        <a class="ri-menu-fill ri-close-fill btn btn-success show-left-part d-block d-md-none" href="javascript:void(0)"></a>
        <div class="scrollable position-relative" style="height: calc(100vh - 50px)">
            {% for presupuesto in presupuestospdte %}
                <div class="alert alert-danger" role="alert">
                    <h4 class="alert-heading">Presupuesto con pagos pendientes!</h4>
                    <p>
                        El presupuesto
                        <a href="{{ path('presupuestos_show', {'id': presupuesto.id}) }}" class="font-medium link">
                            {{ presupuesto.clientePe.direccionCl }} ({{ presupuesto.manoobraPe }})
                        </a>
                        tiene pagos pendientes de obreros.
                    </p>
                    <hr>
                    {% for economicpresu in presupuesto.economicpresus %}
                        {% if economicpresu.estadoEco == 1 and economicpresu.debehaberEco == 'D' %}
                            <b>{{ economicpresu.conceptoEco }} - {{ economicpresu.importeEco | format_currency('EUR', locale='es') }}</b><br>
                        {% endif %}
                    {% endfor %}
                    <p class="mb-0">Por favor, revise y gestione los pagos pendientes.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}

{# ----------------------------------------------------------------
   JS específico de esta página
---------------------------------------------------------------- #}
{% block jscustom %}
    <script src="{{ asset('assets/libs/sweetalert2/dist/sweetalert2.all.min.js') }}"></script>
    <script src="{{ asset('assets/extra-libs/sweetalert2/sweet-alert.init.js') }}"></script>
    <script src="{{ asset('dist/js/pages/datatable/custom-datatable.js') }}"></script>
    <script src="{{ asset('dist/js/pages/datatable/datatable-api.init.js') }}"></script>

    <script>
        $(document).ready(function () {

            // --- Pagos a obreros ---
            document.querySelectorAll('.btn-pagar-obrero').forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();

                    const pagos = JSON.parse(this.dataset.pagos);
                    const presupuestoId = this.dataset.presupuesto;

                    let html = '<ul class="list-group">';
                    pagos.forEach(p => {
                        html += `<li class="list-group-item d-flex justify-content-between align-items-center">
                                    ${p.concepto}
                                    <button class="btn btn-sm btn-primary pagar-btn"
                                            data-id="${p.id}"
                                            data-monto="${p.monto}">
                                        Pagar ${p.monto}€
                                    </button>
                                 </li>`;
                    });
                    html += '</ul>';

                    Swal.fire({
                        title: 'Pagos Pendientes',
                        html: html,
                        showConfirmButton: false,
                        didOpen: () => {
                            Swal.getHtmlContainer().querySelectorAll('.pagar-btn').forEach(btn => {
                                btn.addEventListener('click', function () {
                                    const pagoId = this.dataset.id;
                                    const monto  = this.dataset.monto;

                                    Swal.fire({
                                        title: 'IMPORTE',
                                        html: `<h4>Importe a abonar</h4>
                                               <input type="number" value="${monto}" step="0.01"
                                                      class="swal2-input" id="importe-input"
                                                      style="text-align:center">`,
                                        showDenyButton:   true,
                                        showCancelButton: true,
                                        confirmButtonText: 'Tarjeta',
                                        denyButtonText:    'Efectivo',
                                        cancelButtonText:  'Cancelar',
                                        reverseButtons:    true
                                    }).then(result => {
                                        const importeFinal = Swal.getHtmlContainer()
                                                                  .querySelector('#importe-input').value;
                                        if (result.isConfirmed) {
                                            pagar_economic(pagoId, importeFinal, 'Tarjeta');
                                        } else if (result.isDenied) {
                                            pagar_economic(pagoId, importeFinal, 'Efectivo');
                                        }
                                    });
                                });
                            });
                        }
                    });
                });
            });

            // --- Cobros ---
            document.querySelectorAll('.btn-cobros').forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();

                    const presupuestoId = this.dataset.presupuesto;

                    Swal.fire({
                        title: 'Recibir Pago',
                        html: `<input type="number" class="swal2-input" id="importe-recibido"
                                      placeholder="Importe a recibir" step="0.01">`,
                        showDenyButton:   true,
                        showCancelButton: true,
                        confirmButtonText: 'Tarjeta',
                        denyButtonText:    'Efectivo',
                        cancelButtonText:  'Cancelar',
                        reverseButtons:    true
                    }).then(result => {
                        const importe     = Swal.getHtmlContainer().querySelector('#importe-recibido').value;
                        const metodoPago  = result.isConfirmed ? 'Tarjeta'
                                          : result.isDenied    ? 'Efectivo'
                                          : null;

                        if (!metodoPago) return;

                        fetch('/admin/presupuestos/pago/recibir/' + presupuestoId, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify({ importe, metodo: metodoPago })
                        })
                        .then(r => r.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire('Éxito', data.message, 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Error', data.message, 'error');
                            }
                        })
                        .catch(() => Swal.fire('Error', 'Fallo de red o servidor', 'error'));
                    });
                });
            });

            // --- Función AJAX pago obrero ---
            function pagar_economic(id, importe, modo) {
                $.ajax({
                    url:      '/admin/economicpresu/pagar/ajax',
                    type:     'GET',
                    data:     { importe, id, modo },
                    dataType: 'json',
                    success:  () => location.reload(),
                    error:    (xhr, status) => alert(status)
                });
            }

        });
    </script>
{% endblock %}