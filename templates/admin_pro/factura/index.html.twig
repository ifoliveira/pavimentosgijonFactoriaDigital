{% extends 'base.html.twig' %}

{% block title %}Tickets de venta{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Tickets de venta</h1>
            <div class="text-muted">
                Del {{ fechaDesde|date('d/m/Y') }}
                al {{ fechaHasta|date('d/m/Y') }}
            </div>
        </div>
    </div>

    {# FILTROS #}
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get"
                  action="{{ path('admin_factura_index') }}"
                  class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label for="anio" class="form-label">
                        Año
                    </label>

                    <select name="anio"
                            id="anio"
                            class="form-select">
                        {% for anioOpcion in aniosDisponibles %}
                            <option value="{{ anioOpcion }}"
                                {{ anioOpcion == anio ? 'selected' : '' }}>
                                {{ anioOpcion }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-4">
                    <label for="trimestre" class="form-label">
                        Trimestre
                    </label>

                    <select name="trimestre"
                            id="trimestre"
                            class="form-select">

                        <option value="1"
                            {{ trimestre == 1 ? 'selected' : '' }}>
                            Enero - Marzo
                        </option>

                        <option value="2"
                            {{ trimestre == 2 ? 'selected' : '' }}>
                            Abril - Junio
                        </option>

                        <option value="3"
                            {{ trimestre == 3 ? 'selected' : '' }}>
                            Julio - Septiembre
                        </option>

                        <option value="4"
                            {{ trimestre == 4 ? 'selected' : '' }}>
                            Octubre - Diciembre
                        </option>
                    </select>
                </div>

                <div class="col-md-3">
                    <button type="submit"
                            class="btn btn-primary w-100">
                        Mostrar tickets
                    </button>

   
                                   
                </div>

            </form>
        </div>
    </div>
 

    {# RESUMEN #}
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">
                        Número de tickets
                    </div>

                    <div class="fs-3 fw-bold">
                        {{ resumen.numeroFacturas    }}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">
                        Base imponible
                    </div>

                    <div class="fs-3 fw-bold">
                        {{ resumen.totalBase|number_format(2, ',', '.') }} €
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">
                        IVA
                    </div>

                    <div class="fs-3 fw-bold">
                        {{ resumen.totalIva|number_format(2, ',', '.') }} €
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">
                        Total vendido
                    </div>

                    <div class="fs-3 fw-bold">
                        {{ resumen.totalVentas|number_format(2, ',', '.') }} €
                    </div>
                </div>
            </div>
        </div>

    </div>

    {# TABLA DE TICKETS #}
    <div class="card border-0 shadow-sm">

    <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">

        <div>
            <div class="fw-semibold">
                Tickets del {{ trimestre }}.º trimestre de {{ anio }}
            </div>

            <div class="text-muted small">
                {{ facturas|length }} facturas incluidas en este periodo
            </div>
        </div>

        {% if facturas is not empty %}
            <div class="d-flex gap-2 flex-wrap">

                <a href="{{ path('admin_factura_pdf_trimestre', {
                    anio: anio,
                    trimestre: trimestre
                }) }}"
                class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-file-earmark-pdf me-1"></i>
                    Facturas PDF
                </a>

                <a href="{{ path('admin_factura_resumen_pdf', {
                    anio: anio,
                    trimestre: trimestre
                }) }}"
                class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-file-earmark-text me-1"></i>
                    Resumen PDF
                </a>

                <a href="{{ path('admin_factura_resumen_csv', {
                    anio: anio,
                    trimestre: trimestre
                }) }}"
                class="btn btn-sm btn-outline-success">
                    <i class="bi bi-file-earmark-spreadsheet me-1"></i>
                    CSV
                </a>

            </div>
        {% endif %}

    </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Número</th>
                        <th>Fecha</th>
                        <th>Referencia anterior</th>
                        <th>Forma de pago</th>
                        <th class="text-end">Base</th>
                        <th class="text-end">IVA</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Cobrado</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                {% for ticket in facturas %}

                    {% set primerCobro = ticket.cobros|first %}

                    <tr>
                        <td class="fw-semibold">
                            {{ ticket.numeroFormateado }}
                        </td>

                        <td>
                            {{ ticket.fechaEmision|date('d/m/Y') }}
                        </td>

                        <td>
                            {% if ticket.referenciaAnterior %}
                                {{ ticket.referenciaAnterior }}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>

                        <td>
                            {% if primerCobro %}
                                {{ primerCobro.metodo|capitalize }}
                            {% else %}
                                <span class="text-muted">
                                    Sin cobro
                                </span>
                            {% endif %}
                        </td>

                        <td class="text-end">
                            {{ ticket.baseImponible|number_format(2, ',', '.') }} €
                        </td>

                        <td class="text-end">
                            {{ ticket.totalIva|number_format(2, ',', '.') }} €
                        </td>

                        <td class="text-end fw-semibold">
                            {{ ticket.total|number_format(2, ',', '.') }} €
                        </td>

                        <td class="text-end">
                            {{ ticket.totalCobrado|number_format(2, ',', '.') }} €
                        </td>

                        <td>
                            {% if ticket.estadoCobro == 'cobrado' %}
                                <span class="badge bg-success">
                                    Cobrado
                                </span>
                            {% elseif ticket.estadoCobro == 'parcial' %}
                                <span class="badge bg-warning text-dark">
                                    Parcial
                                </span>
                            {% elseif ticket.estadoCobro == 'devuelto' %}
                                <span class="badge bg-danger">
                                    Devuelto
                                </span>
                            {% else %}
                                <span class="badge bg-secondary">
                                    Pendiente
                                </span>
                            {% endif %}
                        </td>

                        <td class="text-end">

                            <a href="{{ path('admin_factura_pdf', {id: ticket.id}) }}"
                            class="btn btn-sm btn-outline-danger"
                            target="_blank">
                                PDF
                            </a>                        
                            <a href="#"
                               class="btn btn-sm btn-outline-primary">
                                Ver
                            </a>
                        </td>
                    </tr>

                {% else %}
                    <tr>
                        <td colspan="10"
                            class="text-center text-muted py-5">
                            No hay tickets en este trimestre.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>

                {% if facturas is not empty %}
                    <tfoot class="table-light fw-semibold">
                        <tr>
                            <td colspan="4">
                                Total trimestre
                            </td>

                            <td class="text-end">
                                {{ resumen.totalBase|number_format(2, ',', '.') }} €
                            </td>

                            <td class="text-end">
                                {{ resumen.totalIva|number_format(2, ',', '.') }} €
                            </td>

                            <td class="text-end">
                                {{ resumen.totalVentas|number_format(2, ',', '.') }} €
                            </td>

                            <td class="text-end">
                                {{ resumen.totalCobrado|number_format(2, ',', '.') }} €
                            </td>

                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                {% endif %}

            </table>
        </div>
    </div>

</div>
{% endblock %}