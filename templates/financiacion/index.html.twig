{% extends 'base.html.twig' %}

{% block title %}Financiación{% endblock %}
{% block cabecera %}Financiación{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Financiación</li>{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/libs/jquery-steps/jquery.steps.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/libs/jquery-steps/steps.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/libs/magnific-popup/dist/magnific-popup.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/libs/summernote/dist/summernote-bs4.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-body">
            <div class="col-sm-12 col-lg-12">
                <div class="card">

                    {{ form_start(form) }}
                        <div class="form-group mb-0 text-left">
                            <button type="submit" class="btn btn-info waves-effect waves-light">
                                {{ button_label|default('Calcular') }}
                            </button>
                        </div>
                    {{ form_end(form) }}

                    {% for i in 2..4 %}
                        {% if coste[i] > totalabonar[i] %}
                            <h4 class="card-title mt-5 mb-3">{{ tipo[i] }}</h4>
                            <h6>nº N/A</h6>
                        {% else %}
                            <h4 class="card-title mt-5 mb-3">{{ tipo[i] }}</h4>
                            <h6>nº {{ coste[i]|number_format(2, '.', ',') }}</h6>
                        {% endif %}

                        <div class="row">

                            {# Tarjeta: importe mensual #}
                            <div class="col-sm-12 col-md-6 col-xl-3">
                                <div class="card">
                                    <div class="card-body">
                                        <div class="d-flex flex-row">
                                            <div class="round align-self-center round-success">
                                                <i data-feather="credit-card" class="feather-sm"></i>
                                            </div>
                                            <div class="ms-3 align-self-center">
                                                {% if coste[i] > totalabonar[i] or mensualidad[i] == 9999 %}
                                                    <h4 class="mb-0">N/A</h4>
                                                    <span class="text-muted">Importe mensual</span>
                                                </div>
                                                <div class="ms-auto align-self-center">
                                                    <h2 class="font-weight-medium mb-0">N/A</h2>
                                                {% else %}
                                                    <h4 class="mb-0">{{ meses }} meses</h4>
                                                    <span class="text-muted">Importe mensual</span>
                                                </div>
                                                <div class="ms-auto align-self-center">
                                                    <h2 class="font-weight-medium mb-0">
                                                        {{ mensualidad[i]|format_currency('EUR', locale='es') }}
                                                    </h2>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            {# Tarjeta: total abonado #}
                            <div class="col-sm-12 col-md-6 col-xl-3">
                                <div class="card">
                                    <div class="card-body">
                                        <div class="d-flex flex-row">
                                            <div class="round align-self-center round-info">
                                                <i data-feather="users" class="feather-sm"></i>
                                            </div>
                                            <div class="ms-3 align-self-center">
                                                <h4 class="mb-0">Total</h4>
                                                <span class="text-muted">Total abonado</span>
                                            </div>
                                            <div class="ms-auto align-self-center">
                                                {% if coste[i] > totalabonar[i] or mensualidad[i] == 9999 %}
                                                    <h2 class="font-weight-medium mb-0">N/A</h2>
                                                {% else %}
                                                    <h2 class="font-weight-medium mb-0">
                                                        {{ totalabonar[i]|format_currency('EUR', locale='es') }}
                                                    </h2>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    {% endfor %}

                </div>
            </div>
        </div>
    </div>
{% endblock %}

{# No hay JS específico en esta página #}
{% block jscustom %}{% endblock %}