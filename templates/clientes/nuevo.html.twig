{% extends 'base.html.twig' %}
{% block title %}Nuevo Cliente{% endblock %}
{% block body %}
<div class="container mt-4">

    {% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endfor %}

    <h4 class="mb-1 fw-normal">Alta de cliente</h4>
    <p class="text-muted small mb-4">Nuevo cliente</p>

    {{ form_start(form) }}

    <div class="card mb-3">
        <div class="card-body">
            <p class="text-uppercase text-muted small fw-semibold mb-3" style="letter-spacing:.06em;">Datos personales</p>
            <div class="row g-3">
                <div class="col-md-6">{{ form_row(form.nombreCl) }}</div>
                <div class="col-md-6">{{ form_row(form.apellidosCl) }}</div>
                <div class="col-md-4">{{ form_row(form.dni) }}</div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <p class="text-uppercase text-muted small fw-semibold mb-3" style="letter-spacing:.06em;">Contacto y ubicación</p>
            <div class="row g-3">
                <div class="col-md-6">{{ form_row(form.telefono1Cl) }}</div>
                <div class="col-md-6">{{ form_row(form.telefono2Cl) }}</div>
                <div class="col-12">{{ form_row(form.emailCl) }}</div>
                <div class="col-md-4">{{ form_row(form.ciudadCl) }}</div>
                <div class="col-md-8">{{ form_row(form.direccionCl) }}</div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a href="{{ path('clientes_nuevo') }}" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-dark px-4">Dar de alta</button>
    </div>

    {{ form_end(form) }}

</div>
{% endblock %}