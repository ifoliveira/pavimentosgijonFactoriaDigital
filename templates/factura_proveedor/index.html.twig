{# templates/factura_proveedor/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Facturas de proveedor{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# ------------------------------------------------------------------ #}
    {# CABECERA                                                           #}
    {# ------------------------------------------------------------------ #}

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Facturas de proveedor</h1>

            <p class="text-muted mb-0">
                Registro de compras, gastos y facturas importadas.
            </p>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ path('factura_proveedor_subir') }}"
               class="btn btn-primary">
                <i class="bi bi-upload me-1"></i>
                Subir factura
            </a>
        </div>

        <div class="d-flex flex-wrap gap-2">

            <a href="{{ path('factura_proveedor_exportar_pdfs', {
                anio: anioSeleccionado,
                trimestre: trimestreSeleccionado,
                recargo: filtroRecargo
            }) }}"
            class="btn btn-outline-danger">
                PDF facturas
            </a>

            <a href="{{ path('factura_proveedor_exportar_listado', {
                anio: anioSeleccionado,
                trimestre: trimestreSeleccionado,
                recargo: filtroRecargo
            }) }}"
            class="btn btn-outline-secondary">
                Listado PDF
            </a>

            <a href="{{ path('factura_proveedor_exportar_csv', {
                anio: anioSeleccionado,
                trimestre: trimestreSeleccionado,
                recargo: filtroRecargo
            }) }}"
            class="btn btn-outline-success">
                Resumen CSV
            </a>

            <a href="{{ path('factura_proveedor_subir') }}"
            class="btn btn-primary">
                Subir factura
            </a>

        </div>    
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get"
                action="{{ path('factura_proveedor_index') }}"
                class="row g-3 align-items-end">

                <div class="col-12 col-md-3">
                    <label for="filtro-anio" class="form-label">
                        Año
                    </label>

                    <select name="anio"
                            id="filtro-anio"
                            class="form-select">
                        {% for anio in aniosDisponibles %}
                            <option value="{{ anio }}"
                                    {{ anio == anioSeleccionado ? 'selected' : '' }}>
                                {{ anio }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-12 col-md-4">
                    <label for="filtro-trimestre" class="form-label">
                        Trimestre
                    </label>

                    <select name="trimestre"
                            id="filtro-trimestre"
                            class="form-select">
                        <option value="0"
                                {{ trimestreSeleccionado == 0 ? 'selected' : '' }}>
                            Todo el año
                        </option>

                        <option value="1"
                                {{ trimestreSeleccionado == 1 ? 'selected' : '' }}>
                            1.º trimestre · Enero a marzo
                        </option>

                        <option value="2"
                                {{ trimestreSeleccionado == 2 ? 'selected' : '' }}>
                            2.º trimestre · Abril a junio
                        </option>

                        <option value="3"
                                {{ trimestreSeleccionado == 3 ? 'selected' : '' }}>
                            3.º trimestre · Julio a septiembre
                        </option>

                        <option value="4"
                                {{ trimestreSeleccionado == 4 ? 'selected' : '' }}>
                            4.º trimestre · Octubre a diciembre
                        </option>
                    </select>
                </div>

                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-primary">
                        Aplicar filtro
                    </button>
                </div>

                <div class="col-12 col-md-auto">
                    <a href="{{ path('factura_proveedor_index') }}"
                    class="btn btn-outline-secondary">
                        Limpiar
                    </a>
                </div>
                <div class="col-12 col-md-3">
                    <label for="filtro-recargo" class="form-label">
                        Recargo de equivalencia
                    </label>

                    <select name="recargo"
                            id="filtro-recargo"
                            class="form-select">

                        <option value="todas"
                                {{ filtroRecargo == 'todas' ? 'selected' : '' }}>
                            Todas
                        </option>

                        <option value="si"
                                {{ filtroRecargo == 'si' ? 'selected' : '' }}>
                            Con recargo de equivalencia
                        </option>

                        <option value="no"
                                {{ filtroRecargo == 'no' ? 'selected' : '' }}>
                            Sin recargo de equivalencia
                        </option>

                    </select>
                </div>
            </form>
        </div>
    </div>

    {# ------------------------------------------------------------------ #}
    {# RESUMEN                                                            #}
    {# ------------------------------------------------------------------ #}

    {% set totalFacturas = facturas|length %}
    {% set totalImporte = 0 %}
    {% set totalBase = 0 %}
    {% set totalIva = 0 %}
    {% set totalRecargo = 0 %}
    {% set pendientesRevision = 0 %}
    {% set pendientesAsignacion = 0 %}

    {% for factura in facturas %}
        {% set totalImporte = totalImporte + factura.totalFactura|default(0) %}
        {% set totalBase = totalBase + factura.totalBase|default(0) %}
        {% set totalIva = totalIva + factura.totalIva|default(0) %}
        {% set totalRecargo = totalRecargo + factura.totalRecargoEquivalencia|default(0) %}

        {% if factura.estadoAsignacion == 'revision' %}
            {% set pendientesRevision = pendientesRevision + 1 %}
        {% endif %}

        {% if factura.estadoAsignacion in ['pendiente', 'parcial'] %}
            {% set pendientesAsignacion = pendientesAsignacion + 1 %}
        {% endif %}
    {% endfor %}

    <div class="row g-3 mb-4">

        <div class="col-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        Facturas
                    </div>

                    <div class="h4 mb-0">
                        {{ totalFacturas }}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        Base imponible
                    </div>

                    <div class="h5 mb-0">
                        {{ totalBase|number_format(2, ',', '.') }} €
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        IVA
                    </div>

                    <div class="h5 mb-0">
                        {{ totalIva|number_format(2, ',', '.') }} €
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        Recargo equivalencia
                    </div>

                    <div class="h5 mb-0">
                        {{ totalRecargo|number_format(2, ',', '.') }} €
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        Total facturado
                    </div>

                    <div class="h5 mb-0 fw-bold">
                        {{ totalImporte|number_format(2, ',', '.') }} €
                    </div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        Pendientes
                    </div>

                    <div class="d-flex gap-2 align-items-center">
                        {% if pendientesRevision > 0 %}
                            <span class="badge bg-warning text-dark">
                                {{ pendientesRevision }} revisión
                            </span>
                        {% endif %}

                        {% if pendientesAsignacion > 0 %}
                            <span class="badge bg-primary">
                                {{ pendientesAsignacion }} asignar
                            </span>
                        {% endif %}

                        {% if pendientesRevision == 0 and pendientesAsignacion == 0 %}
                            <span class="badge bg-success">
                                Todo al día
                            </span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

    </div>

    {# ------------------------------------------------------------------ #}
    {# LISTADO                                                            #}
    {# ------------------------------------------------------------------ #}

    <div class="card border-0 shadow-sm">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-0">Listado de facturas</h2>

                <div class="small text-muted">
                    Comprueba, asigna y consulta las facturas recibidas
                </div>
            </div>

            <span class="badge bg-light text-dark border">
                {{ totalFacturas }} registros
            </span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Proveedor / factura</th>
                        <th class="text-end">Base</th>
                        <th class="text-end">IVA</th>
                        <th class="text-end">R.E.</th>
                        <th class="text-end">Total</th>
                        <th>Fiscalidad</th>
                        <th>Estado</th>
                        <th class="text-center">Líneas</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                {% for factura in facturas %}

                    {% set rutaPrincipal = 'factura_proveedor_show' %}
                    {% set textoPrincipal = 'Ver factura' %}
                    {% set clasePrincipal = 'btn-outline-primary' %}

                    {% if factura.estadoAsignacion == 'revision' %}
                        {% set rutaPrincipal = 'factura_proveedor_revisar' %}
                        {% set textoPrincipal = 'Revisar' %}
                        {% set clasePrincipal = 'btn-warning' %}
                    {% elseif factura.estadoAsignacion in ['pendiente', 'parcial'] %}
                        {% set rutaPrincipal = 'factura_proveedor_asignar' %}
                        {% set textoPrincipal = 'Asignar' %}
                        {% set clasePrincipal = 'btn-primary' %}
                    {% endif %}

                    <tr>

                        <td class="text-nowrap">
                            {% if factura.fechaFactura %}
                                <div class="fw-semibold">
                                    {{ factura.fechaFactura|date('d/m/Y') }}
                                </div>

                                <div class="small text-muted">
                                    {{ factura.fechaFactura|date('Y') }}
                                </div>
                            {% else %}
                                <span class="text-muted">Sin fecha</span>
                            {% endif %}
                        </td>

                        <td>
                            <a href="{{ path(rutaPrincipal, {id: factura.id}) }}"
                               class="text-decoration-none text-dark">
                                <div class="fw-semibold">
                                    {{ factura.proveedorNombre ?: 'Proveedor sin identificar' }}
                                </div>

                                <div class="small text-muted">
                                    {% if factura.numeroFactura %}
                                        Factura {{ factura.numeroFactura }}
                                    {% else %}
                                        Sin número de factura
                                    {% endif %}
                                </div>
                            </a>
                        </td>

                        <td class="text-end text-nowrap">
                            {{ factura.totalBase|default(0)|number_format(2, ',', '.') }} €
                        </td>

                        <td class="text-end text-nowrap">
                            {{ factura.totalIva|default(0)|number_format(2, ',', '.') }} €
                        </td>

                        <td class="text-end text-nowrap">
                            {% if factura.tieneRecargoEquivalencia %}
                                <span class="fw-semibold">
                                    {{ factura.totalRecargoEquivalencia|default(0)|number_format(2, ',', '.') }} €
                                </span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>

                        <td class="text-end text-nowrap">
                            <span class="fw-bold">
                                {{ factura.totalFactura|default(0)|number_format(2, ',', '.') }} €
                            </span>
                        </td>

                        <td>
                            {% if factura.tieneRecargoEquivalencia %}
                                <span class="badge bg-info text-dark">
                                    Con recargo
                                </span>
                            {% else %}
                                <span class="badge bg-light text-dark border">
                                    IVA general
                                </span>
                            {% endif %}
                        </td>

                        <td>
                            {% if factura.estadoAsignacion == 'revision' %}
                                <span class="badge bg-warning text-dark">
                                    En revisión
                                </span>

                            {% elseif factura.estadoAsignacion == 'pendiente' %}
                                <span class="badge bg-info text-dark">
                                    Pendiente asignar
                                </span>

                            {% elseif factura.estadoAsignacion == 'parcial' %}
                                <span class="badge bg-primary">
                                    Asignación parcial
                                </span>

                            {% elseif factura.estadoAsignacion == 'asignada' %}
                                <span class="badge bg-success">
                                    Asignada
                                </span>

                            {% elseif factura.estadoAsignacion == 'revisada' %}
                                <span class="badge bg-dark">
                                    Revisada
                                </span>

                            {% else %}
                                <span class="badge bg-secondary">
                                    {{ factura.estadoAsignacion }}
                                </span>
                            {% endif %}
                        </td>

                        <td class="text-center">
                            <span class="badge bg-light text-dark border">
                                {{ factura.lineas|length }}
                            </span>
                        </td>

                        <td class="text-end text-nowrap">
                                <div class="btn-group btn-group-sm">

                                    <a href="{{ path('factura_proveedor_revisar', {id: factura.id}) }}"
                                    class="btn btn-outline-warning">
                                        Revisar
                                    </a>

                                    <a href="{{ path('factura_proveedor_asignar', {id: factura.id}) }}"
                                    class="btn btn-primary">
                                        Asignar
                                    </a>

                                    <a href="{{ path('factura_proveedor_pdf', {id: factura.id}) }}"
                                    class="btn btn-outline-secondary"
                                    target="_blank">
                                        PDF
                                    </a>

                                </div>
                        </td>

                    </tr>

                {% else %}
                    <tr>
                        <td colspan="10"
                            class="text-center py-5">

                            <div class="text-muted mb-3">
                                Todavía no hay facturas de proveedor.
                            </div>

                            <a href="{{ path('factura_proveedor_subir') }}"
                               class="btn btn-primary">
                                Subir primera factura
                            </a>

                        </td>
                    </tr>
                {% endfor %}
                </tbody>

            </table>
        </div>

    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const anio = document.getElementById('filtro-anio');
    const trimestre = document.getElementById('filtro-trimestre');
    const recargo = document.getElementById('filtro-recargo');

    recargo?.addEventListener('change', () => recargo.form.submit());    

    anio?.addEventListener('change', () => anio.form.submit());
    trimestre?.addEventListener('change', () => trimestre.form.submit());
});
</script>
{% endblock %}


