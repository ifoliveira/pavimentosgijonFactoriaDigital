{% extends 'base.html.twig' %}

{% block title %}Revisar factura proveedor{% endblock %}
{% block stylesheets %}
    {{ parent() }}
        <style>
            .factura-lineas-table {
                table-layout: fixed;
                min-width: 980px;
            }

            .factura-lineas-table input[type="text"] {
                width: 100%;
                min-width: 0;
            }

            .factura-lineas-table .col-descripcion {
                width: 34%;
            }

            .factura-lineas-table .col-num {
                width: 75px;
            }

            .factura-lineas-table .col-money {
                width: 105px;
            }

            .factura-lineas-table .col-iva {
                width: 70px;
            }

            .factura-lineas-table .col-re {
                width: 55px;
            }

            .factura-lineas-table .col-estado {
                width: 95px;
            }

            .factura-lineas-table .col-acciones {
                width: 125px;
            }

            .factura-lineas-table td,
            .factura-lineas-table th {
                vertical-align: middle;
            }
        </style>

{% endblock %}
{% block body %}
<div class="container-fluid py-4">

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Revisar factura proveedor</h1>
            <p class="text-muted mb-0">
                {{ factura.proveedorNombre ?: 'Proveedor desconocido' }}
                {% if factura.numeroFactura %}
                    · Factura {{ factura.numeroFactura }}
                {% endif %}
            </p>
        </div>

        <div class="text-end">
            <div class="small text-muted">Total factura</div>
            <div class="h4 mb-0">
                {{ factura.totalFactura|default(0)|number_format(2, ',', '.') }} €
            </div>

            <span class="badge bg-warning text-dark mt-2">
                {{ factura.estadoAsignacion }}
            </span>
        </div>
    </div>

    <form method="post">
        <input type="hidden"
            name="_token"
            value="{{ csrf_token('revisar_factura_proveedor_' ~ factura.id) }}">

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="h5 mb-0">Datos de la factura</h2>
                    <div class="small text-muted">
                        Revisa la cabecera detectada por el OCR
                    </div>
                </div>

                {% if factura.tieneRecargoEquivalencia %}
                    <span class="badge bg-info text-dark">
                        Con recargo de equivalencia
                    </span>
                {% else %}
                    <span class="badge bg-light text-dark border">
                        Sin recargo de equivalencia
                    </span>
                {% endif %}
            </div>

            <div class="card-body">
                <div class="row g-3">

                    <div class="col-12 col-md-4">
                        <label class="form-label">
                            Proveedor
                        </label>

                        <input type="text"
                            name="factura[proveedorNombre]"
                            value="{{ factura.proveedorNombre }}"
                            class="form-control"
                            autocomplete="off">
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label">
                            Número de factura
                        </label>

                        <input type="text"
                            name="factura[numeroFactura]"
                            value="{{ factura.numeroFactura }}"
                            class="form-control"
                            autocomplete="off">
                    </div>

                    <div class="col-12 col-md-2">
                        <label class="form-label">
                            Fecha
                        </label>

                        <input type="date"
                            name="factura[fechaFactura]"
                            value="{{ factura.fechaFactura ? factura.fechaFactura|date('Y-m-d') : '' }}"
                            class="form-control">
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label d-block">
                            Fiscalidad
                        </label>

                        <div class="form-check form-switch mt-2">
                            <input type="checkbox"
                                name="factura[tieneRecargoEquivalencia]"
                                value="1"
                                class="form-check-input"
                                id="factura-tiene-re"
                                {{ factura.tieneRecargoEquivalencia ? 'checked' : '' }}>

                            <label class="form-check-label"
                                for="factura-tiene-re">
                                Recargo de equivalencia
                            </label>
                        </div>
                    </div>

                    <div class="col-12">
                        <hr class="my-1">
                    </div>

                    <div class="col-12 col-sm-3">
                        <label class="form-label">
                            Base imponible
                        </label>

                        <div class="input-group">
                            <input type="text"
                                inputmode="decimal"
                                name="factura[totalBase]"
                                value="{{ factura.totalBase }}"
                                class="form-control text-end"
                                id="factura-total-base">

                            <span class="input-group-text">€</span>
                        </div>
                    </div>

                    <div class="col-12 col-sm-3">
                        <label class="form-label">
                            IVA
                        </label>

                        <div class="input-group">
                            <input type="text"
                                inputmode="decimal"
                                name="factura[totalIva]"
                                value="{{ factura.totalIva }}"
                                class="form-control text-end"
                                id="factura-total-iva">

                            <span class="input-group-text">€</span>
                        </div>
                    </div>
                    <div class="col-12 col-sm-3">
                        <label class="form-label">
                            Recargo de equivalencia
                        </label>

                        <div class="input-group">
                            <input type="text"
                                inputmode="decimal"
                                name="factura[totalRecargoEquivalencia]"
                                value="{{ factura.totalRecargoEquivalencia }}"
                                class="form-control text-end"
                                id="factura-total-recargo"
                                {{ factura.tieneRecargoEquivalencia ? '' : 'disabled' }}>

                            <span class="input-group-text">€</span>
                        </div>
                    </div>
                    <div class="col-12 col-sm-3">
                        <label class="form-label fw-semibold">
                            Total factura
                        </label>

                        <div class="input-group">
                            <input type="text"
                                inputmode="decimal"
                                name="factura[totalFactura]"
                                value="{{ factura.totalFactura }}"
                                class="form-control text-end fw-semibold"
                                id="factura-total-factura">

                            <span class="input-group-text">€</span>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <div class="row g-4">
            <a href="{{ path('factura_proveedor_asignar', {id: factura.id}) }}"
            class="btn btn-primary">
                ➡️ Continuar a asignación
            </a>
            {# 🟦 PDF IZQUIERDA #}
            <div class="col-12 col-xl-5">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h2 class="h5 mb-0">PDF original</h2>
                    </div>

                    <div class="card-body p-0" style="height: 75vh;">
                        {% if factura.rutaPdf %}
                            <iframe
                                src="{{ path('factura_proveedor_pdf', {id: factura.id}) }}"
                                style="width:100%; height:100%; border:0;">
                            </iframe>
                        {% else %}
                            <div class="p-4 text-muted">
                                No hay PDF disponible.
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# 🟩 TABLA DERECHA #}
            <div class="col-12 col-xl-7">

                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h2 class="h5 mb-0">Líneas detectadas</h2>
                        <div class="small text-muted">
                            Corrige los datos antes de confirmar la factura
                        </div>
                    </div>

                    <div class="card-body p-0">

                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 factura-lineas-table">
                                <thead class="table-light">
                                    <tr>
                                        <th>Descripción</th>
                                        <th class="text-end col-num">Cant.</th>
                                        <th class="text-end col-money">P. unit.</th>
                                        <th class="text-end col-money">Bruto</th>
                                        <th class="text-end col-iva">IVA %</th>
                                        <th class="text-center col-re">R.E.</th>
                                        <th class="text-end col-money">Total</th>
                                        <th class="col-estado">Estado</th>
                                        <th class="text-end col-acciones">Acciones</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    {% for linea in factura.lineas %}
                                        {% set disabled = linea.estado == 'ignorada' ? 'disabled' : '' %}

                                        <tr class="{{ linea.estado == 'ignorada' ? 'table-secondary opacity-75' : '' }}" data-linea>
                                            <td class="col-descripcion">
                                                <input type="text"
                                                    name="lineas[{{ linea.id }}][descripcion]"
                                                    value="{{ linea.descripcion }}"
                                                    class="form-control form-control-sm"
                                                    {{ disabled }}>
                                            </td>

                                            <td>
                                                <input type="text"
                                                    inputmode="decimal"
                                                    name="lineas[{{ linea.id }}][cantidad]"
                                                    value="{{ linea.cantidad }}"
                                                    class="form-control form-control-sm text-end"
                                                    {{ disabled }}>
                                            </td>

                                            <td>
                                                <input type="text"
                                                    inputmode="decimal"
                                                    name="lineas[{{ linea.id }}][precioUnitario]"
                                                    value="{{ linea.precioUnitario }}"
                                                    class="form-control form-control-sm text-end"
                                                    {{ disabled }}>
                                            </td>

                                            <td>
                                                <input type="text"
                                                    inputmode="decimal"
                                                    name="lineas[{{ linea.id }}][importeBruto]"
                                                    value="{{ linea.importeBruto|default(linea.base) }}"
                                                    class="form-control form-control-sm text-end js-bruto"
                                                    {{ disabled }}>
                                            </td>

                                            <td>
                                                <input type="text"
                                                    inputmode="decimal"
                                                    name="lineas[{{ linea.id }}][porcentajeIva]"
                                                    value="{{ linea.porcentajeIva|default(21) }}"
                                                    class="form-control form-control-sm text-end js-iva-pct"
                                                    {{ disabled }}>
                                            </td>

                                            <td class="text-center">
                                                <span class="js-re-indicador">
                                                    {% if factura.tieneRecargoEquivalencia %}
                                                        <span class="badge bg-info text-dark">Sí</span>
                                                    {% else %}
                                                        <span class="badge bg-light text-dark border">No</span>
                                                    {% endif %}
                                                </span>

                                                <input type="hidden"
                                                    name="lineas[{{ linea.id }}][porcentajeRecargoEquivalencia]"
                                                    value="{{ linea.porcentajeRecargoEquivalencia|default(5.2) }}"
                                                    class="js-re-pct">
                                            </td>

                                            <td class="text-end fw-semibold">
                                                <span class="js-total-linea">
                                                    {{ linea.total|default(0)|number_format(2, ',', '.') }}
                                                </span> €
                                            </td>

                                            <td>
                                                {% if linea.estado == 'revision' %}
                                                    <span class="badge bg-warning text-dark">Revisión</span>
                                                {% elseif linea.estado == 'pendiente' %}
                                                    <span class="badge bg-primary">Confirmada</span>
                                                {% elseif linea.estado == 'ignorada' %}
                                                    <span class="badge bg-secondary">Ignorada</span>
                                                {% elseif linea.estado == 'asignada' %}
                                                    <span class="badge bg-success">Asignada</span>
                                                {% else %}
                                                    <span class="badge bg-light text-dark">{{ linea.estado }}</span>
                                                {% endif %}
                                            </td>

                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <button type="submit"
                                                            name="accion"
                                                            value="confirmar_linea"
                                                            class="btn btn-success"
                                                            onclick="this.form.linea_id.value='{{ linea.id }}'">
                                                        OK
                                                    </button>

                                                    <button type="submit"
                                                            name="accion"
                                                            value="ignorar_linea"
                                                            class="btn btn-outline-danger"
                                                            onclick="this.form.linea_id.value='{{ linea.id }}'; return confirm('¿Ignorar esta línea?');">
                                                        Quitar
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="9" class="p-4 text-muted">
                                                No hay líneas detectadas.
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>

                                <tfoot class="table-light">
                                    <tr>
                                        <th colspan="6" class="text-end">Total líneas activas</th>
                                        <th class="text-end" id="total-lineas">0,00 €</th>
                                        <th></th>
                                        <th></th>
                                    </tr>
                                    <tr>
                                        <th colspan="6" class="text-end">Total factura OCR</th>
                                        <th class="text-end">
                                            {{ factura.totalFactura|default(0)|number_format(2, ',', '.') }} €
                                        </th>
                                        <th></th>
                                        <th></th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                    <div class="card-footer bg-white d-flex justify-content-between align-items-center">

                        <div class="small text-muted">
                            Guarda los cambios antes de confirmar
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" name="accion" value="guardar" class="btn btn-outline-primary">
                                Guardar
                            </button>

                            <button type="submit" name="accion" value="confirmar"
                                    class="btn btn-success"
                                    onclick="return confirm('¿Confirmar factura?');">
                                Confirmar factura
                            </button>
                        </div>

                    </div>

                </div>

            </div>

        </div>
        <input type="hidden" name="linea_id" value="">
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const totalEl = document.getElementById('total-lineas');



    function recalcularFila(tr) {
        const brutoEl = tr.querySelector('.js-bruto');
        const ivaPctEl = tr.querySelector('.js-iva-pct');
        const rePctEl = tr.querySelector('.js-re-pct');
        const totalLineaEl = tr.querySelector('.js-total-linea');

        if (!brutoEl || !ivaPctEl || !totalLineaEl) {
            return 0;
        }

        const bruto = numero(brutoEl.value);
        const ivaPct = numero(ivaPctEl.value);

        const facturaReCheck = document.getElementById('factura-tiene-re');

        let rePct = 0;

        if (facturaReCheck && facturaReCheck.checked && rePctEl) {
            rePct = numero(rePctEl.value);
        }

        const iva = bruto * ivaPct / 100;
        const recargo = bruto * rePct / 100;
        const total = bruto + iva + recargo;

        totalLineaEl.textContent = euro(total);

        return total;
    }

    function recalcularTodo() {
        let total = 0;

        document.querySelectorAll('tr[data-linea]').forEach(tr => {
            if (tr.classList.contains('table-secondary')) {
                return;
            }

            total += recalcularFila(tr);
        });

        totalEl.textContent = euro(total) + ' €';
    }

    function numero(valor) {
        if (!valor) {
            return 0;
        }

        valor = valor.toString().trim();

        // Si viene en formato español: 1.234,56
        if (valor.includes(',') && valor.includes('.')) {
            return parseFloat(valor.replace(/\./g, '').replace(',', '.')) || 0;
        }

        // Si viene en formato español simple: 12,50
        if (valor.includes(',')) {
            return parseFloat(valor.replace(',', '.')) || 0;
        }

        // Si viene en formato normal: 12.50
        return parseFloat(valor) || 0;
    }

    function euro(valor) {
        return valor.toLocaleString('es-ES', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    function actualizarIndicadoresRecargo() {
        const check = document.getElementById(
            'factura-tiene-re'
        );

        const tieneRecargo = check && check.checked;

        document
            .querySelectorAll('.js-re-indicador')
            .forEach(indicador => {
                indicador.innerHTML = tieneRecargo
                    ? '<span class="badge bg-info text-dark">Sí</span>'
                    : '<span class="badge bg-light text-dark border">No</span>';
            });
    }    

    document.querySelectorAll(
        '.js-bruto, .js-iva-pct, .js-re-pct'
    ).forEach(el => {
        el.addEventListener('input', recalcularTodo);
        el.addEventListener('change', recalcularTodo);
    });

    const facturaReCheck = document.getElementById(
        'factura-tiene-re'
    );

    if (facturaReCheck) {
        facturaReCheck.addEventListener('change', () => {
            actualizarIndicadoresRecargo();
            recalcularTodo();
        });
    }

    const recargoCheck = document.getElementById('factura-tiene-re');
    const recargoImporte = document.getElementById('factura-total-recargo');

    function actualizarCampoRecargo() {
        if (!recargoCheck || !recargoImporte) {
            return;
        }

        recargoImporte.disabled = !recargoCheck.checked;

        if (!recargoCheck.checked) {
            recargoImporte.value = '0.00';
        }
    }

    recargoCheck?.addEventListener('change', actualizarCampoRecargo);

actualizarCampoRecargo();

    actualizarIndicadoresRecargo();
    recalcularTodo();
});
</script>

{% endblock %}