<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">

    <style>
        @page {
            margin: 18px 22px;
        }

        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 9px;
            color: #222;
        }

        h1 {
            margin: 0 0 4px;
            font-size: 18px;
        }

        .subtitulo {
            margin-bottom: 18px;
            color: #666;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 6px;
            border-bottom: 1px solid #ddd;
        }

        th {
            background: #f0f0f0;
            text-align: left;
        }

        .numero {
            text-align: right;
            white-space: nowrap;
        }

        .centrado {
            text-align: center;
        }

        tfoot th,
        tfoot td {
            border-top: 2px solid #555;
            border-bottom: 0;
            font-weight: bold;
        }
    </style>
</head>

<body>

{% set totalBase = 0 %}
{% set totalIva = 0 %}
{% set totalRecargo = 0 %}
{% set totalFactura = 0 %}

{% for factura in facturas %}
    {% set totalBase = totalBase + factura.totalBase|default(0) %}
    {% set totalIva = totalIva + factura.totalIva|default(0) %}
    {% set totalRecargo = totalRecargo + factura.totalRecargoEquivalencia|default(0) %}
    {% set totalFactura = totalFactura + factura.totalFactura|default(0) %}
{% endfor %}

<h1>Facturas de proveedor</h1>

<div class="subtitulo">
    Año {{ anio }}

    {% if trimestre > 0 %}
        · {{ trimestre }}.º trimestre
    {% else %}
        · Año completo
    {% endif %}

    {% if filtroRecargo == 'si' %}
        · Con recargo de equivalencia
    {% elseif filtroRecargo == 'no' %}
        · Sin recargo de equivalencia
    {% else %}
        · Todas las facturas
    {% endif %}
</div>

<table>
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Proveedor</th>
            <th>N.º factura</th>
            <th class="numero">Base</th>
            <th class="numero">IVA</th>
            <th class="numero">R.E.</th>
            <th class="numero">Total</th>
            <th class="centrado">R.E.</th>
        </tr>
    </thead>

    <tbody>
    {% for factura in facturas %}
        <tr>
            <td>
                {{ factura.fechaFactura
                    ? factura.fechaFactura|date('d/m/Y')
                    : '-' }}
            </td>

            <td>
                {{ factura.proveedorNombre ?: 'Sin proveedor' }}
            </td>

            <td>
                {{ factura.numeroFactura ?: '-' }}
            </td>

            <td class="numero">
                {{ factura.totalBase|default(0)|number_format(2, ',', '.') }} €
            </td>

            <td class="numero">
                {{ factura.totalIva|default(0)|number_format(2, ',', '.') }} €
            </td>

            <td class="numero">
                {{ factura.totalRecargoEquivalencia|default(0)|number_format(2, ',', '.') }} €
            </td>

            <td class="numero">
                {{ factura.totalFactura|default(0)|number_format(2, ',', '.') }} €
            </td>

            <td class="centrado">
                {{ factura.tieneRecargoEquivalencia ? 'Sí' : 'No' }}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="8" class="centrado">
                No hay facturas para estos filtros.
            </td>
        </tr>
    {% endfor %}
    </tbody>

    <tfoot>
        <tr>
            <th colspan="3">
                Totales · {{ facturas|length }} facturas
            </th>

            <td class="numero">
                {{ totalBase|number_format(2, ',', '.') }} €
            </td>

            <td class="numero">
                {{ totalIva|number_format(2, ',', '.') }} €
            </td>

            <td class="numero">
                {{ totalRecargo|number_format(2, ',', '.') }} €
            </td>

            <td class="numero">
                {{ totalFactura|number_format(2, ',', '.') }} €
            </td>

            <td></td>
        </tr>
    </tfoot>
</table>

</body>
</html>