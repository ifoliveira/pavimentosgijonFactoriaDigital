{% extends 'base.html.twig' %}

{% block body %}
<div class="container-fluid py-4">

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Asignar costes a obra</h1>
            <p class="text-muted mb-0">
                {{ factura.proveedorNombre }} · {{ factura.numeroFactura }}
            </p>
        </div>

        <a href="{{ path('factura_proveedor_revisar', {id: factura.id}) }}" class="btn btn-outline-secondary">
            Volver a revisar
        </a>
    </div>

    <form method="post">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Descripción</th>
                                <th class="text-end">Cant.</th>
                                <th class="text-end">Asignada</th>
                                <th class="text-end">Disponible</th>
                                <th class="text-end">Total línea</th>
                                <th class="text-end">Cant. a asignar</th>
                                <th>Destino</th>
                                <th>Proyecto</th>
                            </tr>
                        </thead>

                        <tbody>
                        {% for linea in factura.lineas %}
                            {% if linea.estado in ['pendiente', 'parcial'] %}

                                {% set cantidadAsignada = 0 %}
                                {% for asignacion in linea.asignaciones %}
                                    {% set cantidadAsignada = cantidadAsignada + asignacion.cantidad %}
                                {% endfor %}

                                {% set cantidadLinea = linea.cantidad|default(1) %}
                                {% set cantidadDisponible = cantidadLinea - cantidadAsignada %}

                                <tr>
                                    <td style="min-width:320px;">
                                        <div class="fw-semibold">{{ linea.descripcion }}</div>

                                        {% if linea.estado == 'parcial' %}
                                            <span class="badge bg-warning text-dark mt-1">Parcial</span>
                                        {% else %}
                                            <span class="badge bg-primary mt-1">Pendiente</span>
                                        {% endif %}
                                    </td>

                                    <td class="text-end">
                                        {{ cantidadLinea|number_format(2, ',', '.') }}
                                    </td>

                                    <td class="text-end">
                                        {{ cantidadAsignada|number_format(2, ',', '.') }}
                                    </td>

                                    <td class="text-end fw-semibold">
                                        {{ cantidadDisponible|number_format(2, ',', '.') }}
                                    </td>

                                    <td class="text-end">
                                        {{ linea.total|default(0)|number_format(2, ',', '.') }} €
                                    </td>

                                    <td style="width:130px;">
                                        <input type="number"
                                               step="0.01"
                                               min="0"
                                               max="{{ cantidadDisponible }}"
                                               name="lineas[{{ linea.id }}][cantidad_asignada]"
                                               value="{{ cantidadDisponible }}"
                                               class="form-control form-control-sm text-end">
                                    </td>

                                    <td style="width:170px;">
                                        <select name="lineas[{{ linea.id }}][tipo_destino]"
                                                class="form-select form-select-sm">
                                            <option value="">Seleccionar</option>
                                            <option value="obra">Obra</option>
                                            <option value="general">Gasto general</option>
                                            <option value="stock">Stock / tienda</option>
                                            <option value="ignorar">Ignorar</option>
                                        </select>
                                    </td>

                                    <td style="min-width:260px;">
                                        <select name="lineas[{{ linea.id }}][proyecto_id]"
                                                class="form-select form-select-sm">
                                            <option value="">Sin proyecto</option>

                                            {% for proyecto in proyectos %}
                                                <option value="{{ proyecto.id }}">
                                                    {{ proyecto.nombre }}
                                                    {% if proyecto.cliente %}
                                                        - {{ proyecto.cliente.nombreCl }} {{ proyecto.cliente.apellidosCl }}
                                                    {% endif %}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </td>
                                </tr>

                                {% if linea.asignaciones|length > 0 %}
                                    <tr class="table-light">
                                        <td colspan="8" class="small text-muted">
                                            <strong>Asignaciones ya realizadas:</strong>
                                            {% for asignacion in linea.asignaciones %}
                                                <span class="badge bg-secondary me-1">
                                                    {{ asignacion.cantidad|number_format(2, ',', '.') }}
                                                    uds ·
                                                    {{ asignacion.importe|number_format(2, ',', '.') }} €
                                                    · {{ asignacion.tipoDestino }}
                                                    {% if asignacion.proyecto %}
                                                        · {{ asignacion.proyecto.nombre }}
                                                    {% endif %}
                                                </span>
                                            {% endfor %}
                                        </td>
                                    </tr>
                                {% endif %}

                            {% endif %}
                        {% else %}
                            <tr>
                                <td colspan="8" class="p-4 text-muted">
                                    No hay líneas pendientes de asignar.
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-white d-flex justify-content-end">
                <button type="submit" class="btn btn-success"
                        onclick="return confirm('¿Guardar asignaciones y generar gastos de proyecto?');">
                    Guardar asignación y generar gastos
                </button>
            </div>
        </div>
    </form>
</div>
{% endblock %}