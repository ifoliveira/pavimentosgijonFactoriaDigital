{% extends 'base.html.twig' %}

{% block title %}Nuevo Ticket{% endblock %}
{% block cabecera %}Ticket nuevo{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Ticket</li>{% endblock %}

{# Solo prism es específico de esta página — dataTables ya viene de la base #}
{% block stylesheets %}
    <link href="{{ asset('assets/extra-libs/prism/prism.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="row">

        {# Lista de productos #}
        <div class="col-md-9 col-lg-9">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Productos</h4>
                    <h6 class="card-subtitle">Para añadir productos seleccionar en la lista {{ cestaId }}</h6>
                    <div class="table-responsive">
                        <table id="tbprod" class="table table-striped table-bordered text-inputs-searching">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th>Precio</th>
                                    <th>PVP</th>
                                    <th>Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for producto in productos %}
                                    <tr>
                                        <td>{{ producto.id }}</td>
                                        <td>{{ producto.tipoPdId }}</td>
                                        <td>{{ producto.descripcionPd }}</td>

                                        <td class="text-right" data-order="{{ producto.precioPd }}">
                                            {{ producto.precioPd | format_currency('EUR', locale='es') }}
                                        </td>
                                        <td class="text-right" data-order="{{ producto.pvpPd }}">
                                            {{ producto.pvpPd | format_currency('EUR', locale='es') }}
                                        </td>
                                        <td data-order="{{ producto.stockPd }}">{{ producto.stockPd }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6">No se encontraron productos</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th>Id</th>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th>Precio</th>
                                    <th>PVP</th>
                                    <th>Stock</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        {# Panel lateral: cesta y acciones #}
        <div class="col-md-3 col-lg-3">
            <div class="card">
                <div class="card-body" id="loop"
                     data-cesta="{{ cestaId }}"
                     data-dirtk="{{ ticketsDir }}">
                    {% include 'productos/loop.html.twig' %}
                </div>
                <div class="card-body">
                    <button class="btn btn-success" id="Checkout">Generar ticket</button>
                    <button class="btn btn-secondary btn-outline" id="Cancelar_Cesta">Borrar ticket</button>
                </div>
            </div>
        </div>

    </div>
{% endblock %}

{% block jscustom %}
    {# Conector impresora térmica #}
    <script src="{{ asset('dist/js/ConectorJavaScript.js') }}"></script>

    {# DataTables responsive — el core ya viene de la base #}
    <script src="{{ asset('assets/extra-libs/datatables.net-bs4/js/dataTables.responsive.min.js') }}"></script>
    <script src="{{ asset('dist/js/pages/datatable/datatable-api.init.js') }}"></script>
    <script src="{{ asset('assets/libs/sweetalert2/dist/sweetalert2.all.min.js') }}"></script>

    <script>
        $(document).ready(function () {

            const table      = $('#tbprod').DataTable();
            const selector   = document.querySelector('#loop');
            const cestaId    = selector.dataset.cesta;

            // --------------------------------------------------------
            // Insertar producto al hacer clic en una fila
            // --------------------------------------------------------
            $('#tbprod').on('click', 'tbody tr[role="row"]', function () {
                const rowData    = table.row(this).data();
                const $cells     = $(table.row(this).node()).children('td');
                
                // Leer directamente del data-order — ya es numérico, sin parsear
                const pvp        = parseFloat($cells.eq(4).data('order'));
                const precio     = parseFloat($cells.eq(3).data('order'));
                const descripcion = rowData[2];

                Swal.fire({
                    showCancelButton:  true,
                    confirmButtonText: 'Añadir producto',
                    cancelButtonText:  'Cancelar',
                    title: 'Cantidad y PVP',
                    html: `
                        <h2>${descripcion}</h2>
                        <input type="text"   value=""      class="swal2-input" id="range-value0" style="text-align:center" placeholder="Texto libre">
                        <h2>Cantidad</h2>
                        <input type="number" value="1"     step="1"   class="swal2-input" id="range-value"  style="text-align:center">
                        <h2>PVP</h2>
                        <input type="number" value="${pvp}"   step="1"   class="swal2-input" id="range-value2" style="text-align:right"> €
                        <h2>Coste</h2>
                        <input type="number" value="${precio}" step="1"  class="swal2-input" id="range-value3" style="text-align:right"> €
                        <h2>Descuento</h2>
                        <input type="number" value="0"     step="1"   class="swal2-input" id="range-value4" style="text-align:right"> %
                    `
                }).then(result => {
                    if (!result.value) return;

                    const cont = Swal.getHtmlContainer();
                    insert_line(
                        rowData,
                        cont.querySelector('#range-value').value,
                        cont.querySelector('#range-value2').value,
                        cont.querySelector('#range-value3').value,
                        cestaId,
                        cont.querySelector('#range-value0').value,
                        cont.querySelector('#range-value4').value
                    );
                });
            });

            function insert_line(producto, cantidad, importe, coste, cesta, texto, descuento) {
                $.ajax({
                    url:      '{{ path("detallecesta_new") }}',
                    type:     'GET',
                    data:     { producto, cantidad, importe, coste, cesta, texto, descuento },
                    dataType: 'json',
                    success:  r => $('#loop').html(r.template),
                    error:    (xhr, status) => alert(status)
                });
            }

            // --------------------------------------------------------
            // Sumar / restar unidades
            // --------------------------------------------------------
            $(document).on('click', 'i[name="plus-minus"]', function () {
                const id       = this.dataset.id;  // ✅ en vez de this.id
                let cantidad   = parseInt(this.dataset.cantidad);
                cantidad += this.classList.contains('fa-minus-circle') ? -1 : 1;

                if (cantidad === 0) {
                    delete_line(id);
                } else {
                    actualiza_line(id, cantidad);
                }
            });            

            function actualiza_line(id, cantidad) {
                $.ajax({
                    url:      '../detallecesta/plusminus/ajax',
                    type:     'GET',
                    data:     { cantidad, id },
                    dataType: 'json',
                    success:  r => $('#loop').html(r.template),
                    error:    (xhr, status) => alert(status)
                });
            }

            // --------------------------------------------------------
            // Eliminar producto
            // --------------------------------------------------------
            $(document).on('click', 'i[name="delete_detalle"]', function () {
                delete_line(this.dataset.id);  // ✅ en vez de this.id
            });

            function delete_line(id) {
                $.ajax({
                    url:      '{{ path("detallecesta_delete") }}',
                    type:     'GET',
                    data:     { id },
                    dataType: 'json',
                    success: function (r) {
                        $('#loop').html(r.template);
                        document.querySelector("span[name='cantidad']").innerText = r.cantidad;
                    },
                    error: (xhr, status) => alert(status)
                });
            }

            // --------------------------------------------------------
            // Borrar cesta completa
            // --------------------------------------------------------
            $(document).on('click', '#Cancelar_Cesta', function () {
                $.ajax({
                    url:      '{{ path("delete_logico", {id: cestaId}) }}',
                    type:     'GET',
                    dataType: 'json',
                    success:  () => location.reload(),
                    error:    (xhr, status) => alert(status)
                });
            });

            // --------------------------------------------------------
            // Finalizar ticket (Checkout)
            // --------------------------------------------------------
            function abrirNuevoTab(url) {
                window.open(url, '_blank').focus();
            }

            $(document).on('click', '#Checkout', async function (e) {
                e.preventDefault();
                e.stopPropagation();

                // Paso 1: ¿Es señal?
                const { value: accept } = await Swal.fire({
                    showCancelButton:  true,
                    cancelButtonText:  'Cancelar',
                    title: 'SEÑAL',
                    input: 'checkbox',
                    inputValue: 0,
                    inputPlaceholder:  '¿Es el pago de una señal?',
                    confirmButtonText: 'Continuar <i class="fa fa-arrow-right"></i>'
                });

                if (accept === undefined) return;

                let senal = 0;

                // Paso 2: importe señal (solo si marcó señal)
                if (accept) {
                    const totalTicket  = parseFloat(document.querySelector('#imptotal').dataset.importe) || 0;
                    const señalBruta    = totalTicket * 0.40;
                    const señalSugerida  = Math.ceil(señalBruta / 10) * 10;                 
                    await Swal.fire({
                        title: 'Importe Señal',
                        html: `<h2>Importe señal</h2>
                               <input type="number" value="${señalSugerida}" step="1"
                                      class="swal2-input" id="range-value"
                                      style="text-align:right"> €`
                    }).then(result => {
                        if (result.value) {
                            senal = Swal.getHtmlContainer().querySelector('#range-value').value;
                        }
                    });
                }

                // Paso 3: método de pago
                const swal = Swal.mixin({
                    customClass: {
                        confirmButton: 'btn btn-success mx-2',
                        denyButton:    'btn btn-danger mx-2',
                        cancelButton:  'btn btn-secondary mx-2'
                    },
                    buttonsStyling: false
                });

                await swal.fire({
                    title: 'Método de pago',
                    text:  'Selecciona un método de pago',
                    icon:  'warning',
                    showDenyButton:    true,
                    showCancelButton:  true,
                    confirmButtonText: 'Tarjeta',
                    denyButtonText:    'Efectivo',
                    cancelButtonText:  'Cancelar',
                    reverseButtons:    true
                }).then(result => {
                    if (result.isConfirmed) {
                        ticket_pdf('Tarjeta', senal);
                    } else if (result.isDenied) {
                        ticket_pdf('Efectivo', senal);
                    }
                });
            });

            // --------------------------------------------------------
            // Generar PDF e imprimir
            // --------------------------------------------------------
            function ticket_pdf(tipopago, importesnal) {
                $.ajax({
                    url:      '{{ path("ticketpdf", {id: cestaId}) }}',
                    type:     'GET',
                    data:     { tipopago, importesnal },
                    dataType: 'json',
                    success: function (r) {
                        ticket_script4(tipopago, importesnal);
                        ticket_finalizar(tipopago, r.namepdf, r.importe, r.importesnal);
                        abrirNuevoTab('/Tickets/' + r.namepdf);
                    },
                    error: (xhr, status) => alert(status)
                });
            }

            function ticket_finalizar(tipopago, numticket, importe, importesnal) {
                $.ajax({
                    url:      '{{ path("cestas_finalizar", {id: cestaId}) }}',
                    type:     'GET',
                    data:     { tipopago, numticket, importe, importesnal },
                    dataType: 'json',
                    success:  () => location.reload(),
                    error:    (xhr, status) => alert(status)
                });
            }

            // --------------------------------------------------------
            // Impresión ESC/POS directa (fetch al agente local)
            // --------------------------------------------------------
            function ticket_script4(tipopago, importesnal) {
                const entryInfoObjects = Array.from(
                    document.querySelectorAll('[data-entry-info]')
                ).map(el => JSON.parse(el.dataset.entryInfo));

                const ANCHO_IMPORTE = 9;
                let total  = 0;
                let ticket = '';

                ticket += '\x1B@\n';
                ticket += '\x1Ba\x01';
                ticket += 'P A V I M E N T O S   G I J O N \n';
                ticket += 'C.I.F. 53543499-M\n';
                ticket += 'Avda. Schultz Nº 28 Bajo\n';
                ticket += 'Tel: 985 391 326\n';
                ticket += 'WhatsApp: 684 608 811\n';
                ticket += 'www.pavimentosgijon.es\n\n';
                ticket += '----------------------------------------------\n';
                ticket += 'FACTURA SIMPLIFICADA\n';
                ticket += '----------------------------------------------\n\n';

                entryInfoObjects[0].forEach(grupo => {
                    grupo.forEach(element => {
                        const parcial     = element.cantidad * element.precio;
                        total            += parcial;
                        const cantidad    = element.cantidad.toString().padStart(2, '0');
                        const descripcion = element.descripcion.substr(0, 28).padEnd(28);
                        const importe     = parcial.toLocaleString('de-DE', {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2
                        }).padStart(ANCHO_IMPORTE);
                        ticket += ` ${cantidad} ${descripcion} ${importe} EUR\n`;
                    });
                });

                const iva    = total * 0.21 / 1.21;
                const ivaStr = iva.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).padStart(ANCHO_IMPORTE);
                const totStr = total.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).padStart(ANCHO_IMPORTE);

                ticket += '----------------------------------------------\n';
                ticket += ` IVA 21%:`.padEnd(33) + ivaStr + ' EUR\n';
                ticket += '\x1BE\x01';
                ticket += ` TOTAL:`.padEnd(33) + totStr + ' EUR\n';
                ticket += '\x1BE\x00';
                ticket += '\n\x1Ba\x01';
                ticket += 'Gracias por su compra\n\n';
                ticket += '\n------------------------------------------\n';
                ticket += '¿Pensando en reformar tu baño?\n\n';
                ticket += '✔ Cambio de bañera por ducha\n';
                ticket += '✔ Reforma integral de baño\n';
                ticket += '✔ Mamparas y muebles de baño\n\n';
                ticket += 'Pide tu presupuesto online en:\n';
                ticket += 'www.pavimentosgijon.es\n';
                ticket += 'Rápido y sin compromiso\n';
                ticket += 'Escanea el QR y calcula tu presupuesto YA\n';
                ticket += escposQR('https://www.pavimentosgijon.es/presupuestoInmediato');
                ticket += '\x1DVA0';

                fetch('http://127.0.0.1:3000/print', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Token': 'tpv-secreto-123'
                    },
                    body: JSON.stringify({ ticket })
                })
                .then(r => r.json())
                .then(r => console.log('Ticket impreso', r))
                .catch(err => alert('Error al imprimir: ' + err));
            }

            function escposQR(text) {
                const data = new TextEncoder().encode(text);
                const len  = data.length + 3;
                const pL   = len & 0xff;
                const pH   = (len >> 8) & 0xff;

                return '\x1D(k\x04\x00\x31\x41\x32\x00'
                     + '\x1D(k\x03\x00\x31\x43\x06'
                     + '\x1D(k\x03\x00\x31\x45\x31'
                     + '\x1D(k' + String.fromCharCode(pL, pH) + '\x31\x50\x30' + text
                     + '\x1D(k\x03\x00\x31\x51\x30';
            }

        }); 
    </script>
{% endblock %}