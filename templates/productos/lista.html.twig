{% extends 'base.html.twig' %}

{% block title %}Productos{% endblock %}
{% block cabecera %}Productos{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Productos</li>{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('assets/extra-libs/prism/prism.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Productos</h4>
                    <div class="table-responsive">
                        <table id="default_order" class="table table-striped table-bordered display" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th>Precio</th>
                                    <th>PVP</th>
                                    <th>Stock</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for producto in productos %}
                                    <tr>
                                        <td>{{ producto.id }}</td>
                                        <td>{{ producto.tipoPdId }}</td>
                                        <td>{{ producto.descripcionPd }}</td>
                                        <td class="text-right" data-order="{{ producto.precioPd }}">
                                            {{ producto.precioPd|format_currency('EUR', locale='es') }}
                                        </td>
                                        <td class="text-right" data-order="{{ producto.pvpPd }}">
                                            {{ producto.pvpPd|format_currency('EUR', locale='es') }}
                                        </td>
                                        <td>{{ producto.stockPd }}</td>
                                        <td>
                                            <a href="{{ path('productos_edit', {'id': producto.id}) }}"
                                               class="text-inverse pr-2" data-toggle="tooltip" title="Editar">
                                                <i class="ti-pencil"></i>
                                            </a>
                                            <a class="text-inverse pr-2" data-toggle="tooltip"
                                               title="{{ producto.obsoleto ? 'Marcar activo' : 'Marcar obsoleto' }}"
                                               name="marcar_obsoleto" data-id="{{ producto.id }}">
                                                <i class="{{ producto.obsoleto ? 'ti-eye' : 'ti-trash' }}"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <a href="{{ path('productos_new') }}" class="btn btn-info mt-2">Nuevo producto</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block jscustom %}
    <script src="{{ asset('assets/extra-libs/datatables.net-bs4/js/dataTables.responsive.min.js') }}"></script>

    <script>
    $(document).ready(function () {

        $('#default_order').DataTable({
            order: [[0, 'desc']],
            language: {
                url: '//cdn.datatables.net/plug-ins/1.10.16/i18n/Spanish.json',
                emptyTable: 'No se encontraron productos'
            }
        });

        $(document).on('click', 'a[name="marcar_obsoleto"]', function () {
            const id = this.dataset.id;
            $.ajax({
                url:      '../productos/actualiza/obsoleto',
                type:     'GET',
                data:     { id },
                dataType: 'json',
                success:  () => location.reload(),
                error:    (xhr, status) => alert(status)
            });
        });

    });
    </script>
{% endblock %}