{% extends 'base.html.twig' %}

{% block title %}Documentos{% endblock %}
{% block cabecera %}Documentos{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Documentos</li>{% endblock %}

{% block body %}

    {% set tipoColores = {
        'presupuesto': 'primary',
        'factura':     'success',
        'ticket':      'warning'
    } %}

    {% set ecColores = {
        'borrador':   'secondary',
        'enviado':    'info',
        'aceptado':   'success',
        'rechazado':  'danger',
        'convertido': 'primary',
        'aplicado':   'warning'
    } %}

    {% set cobroColores = {
        'pendiente': 'warning',
        'parcial':   'info',
        'cobrado':   'success',
        'devuelto':  'danger'
    } %}

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="border-bottom title-part-padding d-flex justify-content-between align-items-center">
                    <h4 class="card-title mb-0">Documentos</h4>
                    <a href="{{ path('app_documento_nuevo') }}" class="btn btn-sm btn-primary">+ Nuevo</a>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="tabla_documentos" class="table table-striped table-bordered display" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Número</th>
                                    <th>Cliente / Dirección</th>
                                    <th>Importe</th>
                                    <th>Est. comercial</th>
                                    <th>Est. cobro</th>
                                    <th>Proyecto</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for doc in documentos %}
                                    {% set colorTipo   = tipoColores[doc.tipoDocumento]               ?? 'secondary' %}
                                    {% set colorEc     = ecColores[doc.estadoComercial]       ?? 'secondary' %}
                                    {% set colorCobro  = cobroColores[doc.estadoCobro]        ?? 'secondary' %}

                                    <tr>
                                        <td>
                                            <span class="badge bg-{{ colorTipo }}">{{ doc.tipoDocumento }}</span>
                                        </td>

                                        <td>{{ doc.numero ?? '—' }}</td>

                                        <td>
                                            {% if doc.cliente %}
                                                <a href="{{ path('app_documento_show', {id: doc.id}) }}" class="font-medium link">
                                                    {{ doc.cliente.direccionCl }} ({{ doc.cliente.nombreCl }}{% if doc.cliente.apellidosCl %} {{ doc.cliente.apellidosCl }}{% endif %})
                                                </a>
                                            {% else %}
                                                <span class="text-muted">Sin cliente</span>
                                            {% endif %}
                                        </td>

                                        <td class="text-end">
                                            {{ doc.total | format_currency('EUR', locale='es') }}
                                        </td>

                                        <td>
                                            <span class="badge bg-{{ colorEc }}">{{ doc.estadoComercial }}</span>
                                        </td>

                                        <td>
                                            {% if doc.tipoDocumento in ['factura', 'ticket'] %}
                                                <span class="badge bg-{{ colorCobro }}">{{ doc.estadoCobro }}</span>
                                            {% else %}
                                                <span class="text-muted">—</span>
                                            {% endif %}
                                        </td>

                                        <td>

                                        </td>

                                        <td class="text-nowrap">
                                            <a href="{{ path('app_documento_show', {id: doc.id}) }}"
                                               class="text-inverse pr-2" data-toggle="tooltip" title="Ver documento">
                                                <i class="ti-eye"></i>
                                            </a>

                                            {% if doc.tipoDocumento == 'presupuesto' and doc.estadoComercial in ['enviado', 'aceptado'] %}
                                                <a href="{{ path('documento_convertir', {id: doc.id}) }}"
                                                   class="text-inverse pr-2" data-toggle="tooltip" title="Convertir a factura">
                                                    <i class="ti-arrow-right"></i>
                                                </a>
                                            {% endif %}


                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Número</th>
                                    <th>Cliente / Dirección</th>
                                    <th>Importe</th>
                                    <th>Est. comercial</th>
                                    <th>Est. cobro</th>
                                    <th>Proyecto</th>
                                    <th>Acciones</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block jscustom %}
    <script>
    $(document).ready(function () {

        $('#tabla_documentos').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/1.10.16/i18n/Spanish.json'
            },
            order: [[1, 'desc']]
        });

        $(document).on('click', 'a[name="delete_documento"]', async function () {
            const id = this.dataset.id;

            const swal = Swal.mixin({
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton:  'mr-2 btn btn-danger'
                },
                buttonsStyling: false
            });

            const result = await swal.fire({
                title:             'Borrar documento',
                text:              'Se va a borrar el documento ' + id,
                icon:              'question',
                showCancelButton:  true,
                confirmButtonText: 'Adelante',
                cancelButtonText:  'Cancelar',
                reverseButtons:    true
            });

            if (result.isConfirmed) delete_documento(id);
        });


    });
    </script>
{% endblock %}