          <span class="input-group-text bg-light border-end-0">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
              <circle cx="5.5" cy="5.5" r="4" stroke="#888" stroke-width="1.2"/>
              <path d="M9 9l2.5 2.5" stroke="#888" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </span>
          <input type="text"
                 id="producto-search"
                 class="form-control form-control-sm border-start-0 ps-0"
                 placeholder="Buscar por nombre..."
                 autocomplete="off">
        </div>
      </div>

      <div id="resultados-busqueda" class="offcanvas-scroll-area">
        <div class="text-center text-muted py-4 small">
          Empieza a escribir para buscar productos
        </div>
      </div>

      <div class="border-top px-4 py-3">
        <button type="button"
                class="btn btn-sm btn-outline-secondary w-100"
                onclick="cambiarTipoLinea('servicio')">
          + Añadir línea de servicio
        </button>
      </div>
    </div>

    {# ── PRODUCTO: FASE 2 FORMULARIO ──────────────────────── #}
    <div id="fase-formulario-producto" class="d-none">
      <div class="px-4 py-3 border-bottom">
        <div id="producto-seleccionado-tag"
             class="alert alert-info alert-sm py-2 px-3 mb-0 d-flex align-items-center gap-2">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
            <path d="M2 7l3 3 6-6" stroke="#185FA5" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span id="producto-seleccionado-nombre" class="small fw-semibold flex-grow-1"></span>
          <button type="button" class="btn-close btn-close-sm" onclick="limpiarProducto()"></button>
        </div>
      </div>

      <div class="px-4 py-3 offcanvas-form-bg flex-grow-1">
        <div class="mb-3">
          <label class="form-label-upper">Descripción</label>
          <textarea name="descripcion"
                    id="f-descripcion"
                    class="form-control form-control-custom"
                    rows="2"
                    required></textarea>
        </div>

        <div class="row g-2 mb-3">
        <div class="col-4">
            <label class="form-label-upper">Cantidad</label>
            <input type="number"
                name="cantidad"
                id="f-cantidad"
                class="form-control form-control-custom text-end js-recalcular-linea"
                value="1"
                min="1"
                step="1"
                required>
        </div>
        <div class="col-4">
            <label class="form-label-upper">Precio s/IVA €</label>
            <input type="number"
                name="precioUnitario"
                id="f-precio"
                class="form-control form-control-custom text-end js-recalcular-linea"
                step="0.01"
                placeholder="0.00"
                required>
        </div>
        <div class="col-4">
            <label class="form-label-upper">Dto. %</label>
            <input type="number"
                name="descuento"
                id="f-descuento"
                class="form-control form-control-custom text-end js-recalcular-linea"
                value="0"
                min="0"
                max="100"
                step="1">
        </div>
        </div>

        <div class="row g-2 mb-3">
        <div class="col-6">
            <label class="form-label-upper">Precio c/IVA</label>
            <input type="text"
                id="f-precio-iva"
                class="form-control form-control-custom text-end bg-light"
                readonly>
        </div>
        <div class="col-6">
            <label class="form-label-upper">IVA aplicado</label>
            <input type="text"
                id="f-tipo-iva-producto"
                class="form-control form-control-custom text-end bg-light"
                value="21 %"
                readonly>
        </div>
        </div>

        <div class="rounded-3 border bg-white px-3 py-2">
        <div class="d-flex justify-content-between small mb-1">
            <span class="text-muted">Subtotal s/IVA</span>
            <strong id="subtotal-sin-iva-producto">0,00 €</strong>
        </div>
        <div class="d-flex justify-content-between small mb-1">
            <span class="text-muted">IVA</span>
            <strong id="importe-iva-producto">0,00 €</strong>
        </div>
        <div class="d-flex justify-content-between small">
            <span class="text-muted">Total c/IVA</span>
            <strong id="subtotal-preview-producto" class="text-primary">0,00 €</strong>
        </div>
        </div>
      </div>
    </div>



    {# ── SERVICIO ─────────────────────────────────────────── #}
    <div id="fase-formulario-servicio" class="d-none">
      <div class="px-4 py-3 offcanvas-form-bg flex-grow-1">
        <div class="mb-3">
          <label class="form-label-upper">Descripción</label>
          <textarea name="descripcion"
                    id="f-descripcion-servicio"
                    class="form-control form-control-custom"
                    rows="3"></textarea>
        </div>

        <div class="row g-2 mb-3">
        <div class="col-4">
            <label class="form-label-upper">Cantidad</label>
            <input type="number"
                name="cantidad"
                id="f-cantidad-servicio"
                class="form-control form-control-custom text-end js-recalcular-servicio"
                value="1"
                min="1"
                step="1">
        </div>
        <div class="col-4">
            <label class="form-label-upper">Precio s/IVA €</label>
            <input type="number"
                name="precioUnitario"
                id="f-precio-servicio"
                class="form-control form-control-custom text-end js-recalcular-servicio"
                step="0.01"
                placeholder="0.00">
        </div>
        <div class="col-4">
            <label class="form-label-upper">Dto. %</label>
            <input type="number"
                name="descuento"
                id="f-descuento-servicio"
                class="form-control form-control-custom text-end js-recalcular-servicio"
                value="0"
                min="0"
                max="100"
                step="0.01">
        </div>
        </div>

        <div class="row g-2 mb-3">
        <div class="col-6">
            <label class="form-label-upper">Precio c/IVA</label>
            <input type="text"
                id="f-precio-iva-servicio"
                class="form-control form-control-custom text-end bg-light"
                readonly>
        </div>
        <div class="col-6">
            <label class="form-label-upper">IVA aplicado</label>
            <input type="text"
                id="f-tipo-iva-servicio"
                class="form-control form-control-custom text-end bg-light"
                value="21 %"
                readonly>
        </div>
        </div>

        <div class="rounded-3 border bg-white px-3 py-2">
        <div class="d-flex justify-content-between small mb-1">
            <span class="text-muted">Subtotal s/IVA</span>
            <strong id="subtotal-sin-iva-servicio">0,00 €</strong>
        </div>
        <div class="d-flex justify-content-between small mb-1">
            <span class="text-muted">IVA</span>
            <strong id="importe-iva-servicio">0,00 €</strong>
        </div>
        <div class="d-flex justify-content-between small">
            <span class="text-muted">Total c/IVA</span>
            <strong id="subtotal-preview-servicio" class="text-primary">0,00 €</strong>
        </div>
        </div>
      </div>
    </div>

    {# ── COMENTARIO ───────────────────────────────────────── #}
    <div id="fase-formulario-comentario" class="d-none">
      <div class="px-4 py-3 offcanvas-form-bg flex-grow-1">
        <div class="mb-3">
          <label class="form-label-upper">Comentario</label>
          <textarea name="descripcion"
                    id="f-descripcion-comentario"
                    class="form-control form-control-custom"
                    rows="5"></textarea>
        </div>

        {# campos ocultos para que el controlador siga recibiendo lo mismo #}
        <input type="hidden" name="cantidad" id="f-cantidad-comentario" value="1">
        <input type="hidden" name="precioUnitario" id="f-precio-comentario" value="0">
        <input type="hidden" name="descuento" id="f-descuento-comentario" value="0">

        <div class="small text-muted">
          Esta línea no tendrá importe ni descuento.
        </div>
      </div>
    </div>

    <div class="offcanvas-footer border-top px-4 py-3 d-flex justify-content-end gap-2">
      <button type="button"
              class="btn btn-sm btn-modal-cancel"
              onclick="cancelarOffcanvasLinea()">
        Cancelar
      </button>
      <button type="submit"
              class="btn btn-sm btn-modal-save">
        Añadir línea
      </button>
    </div>
  </form>
</div>

    {# ── MANO DE OBRA: CONSTRUCTOR VISUAL ─────────────────────── #}
<div class="offcanvas offcanvas-end offcanvas-mano-obra"
     tabindex="-1"
     id="offcanvasManoObra"
     data-bs-backdrop="false"
     data-bs-scroll="true">

    <div class="mb-3 d-flex gap-2">
        <a href="{{ path('app_documento_mano_obra_preset', {id: documento.id, tipo: 'ducha'}) }}"
        class="btn btn-sm btn-outline-primary" onclick="return confirm('Esto sustituirá la mano de obra actual. ¿Continuar?');">
            🚿 Plato de ducha
        </a>

        <a href="{{ path('app_documento_mano_obra_preset', {id: documento.id, tipo: 'bano'}) }}"
        class="btn btn-sm btn-outline-primary">
            🛁 Baño completo
        </a>
    </div>     

    <form method="post"
          action="{{ path('app_documento_guardar_mano_obra', {id: documento.id}) }}"
          class="h-100 d-flex flex-column"
          id="form-mano-obra">

        <div class="offcanvas-header border-bottom px-4 pt-3 pb-3">
            <div class="w-100">
                <h5 class="offcanvas-title mb-0">Editar mano de obra</h5>
                <div class="text-muted small">
                    Selecciona los trabajos por categoría
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>

        {# aquí se generan automáticamente los hidden inputs #}
        <div id="mano-obra-hidden-inputs"></div>

        <div class="offcanvas-body p-0 d-flex">

            <div class="mo-sidebar border-end">
                <div class="mo-sidebar-title">Categorías</div>

                {% for tipo in tiposManoObra %}
                    {% set totalTextos = textosManoObra[tipo.id]|default([])|length %}
                    <button type="button"
                            class="mo-tab {% if loop.first %}active{% endif %}"
                            onclick="cambiarCategoria({{ tipo.id }})"
                            id="tab-{{ tipo.id }}">
                        <span>{{ tipo.tipoTm }}</span>
                        <span class="mo-tab-count" id="count-tipo-{{ tipo.id }}">0/{{ totalTextos }}</span>
                    </button>
                {% endfor %}
            </div>

            <div class="mo-content flex-grow-1">
                {% for tipo in tiposManoObra %}
                    {% set textos = textosManoObra[tipo.id]|default([]) %}

                    <div class="mo-panel {% if not loop.first %}d-none{% endif %}"
                         id="panel-{{ tipo.id }}">

                        <div class="mo-panel-head d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <div class="mo-panel-title">{{ tipo.tipoTm }}</div>
                                <div class="mo-panel-subtitle">
                                    Marca los trabajos que quieres incluir en esta categoría.
                                </div>
                            </div>

                            {% if textos|length > 0 %}
                                <div class="d-flex gap-2">
                                    <button type="button"
                                            class="btn btn-sm btn-light"
                                            onclick="seleccionarTodoTipo({{ tipo.id }})">
                                        Seleccionar todo
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-light"
                                            onclick="limpiarTipo({{ tipo.id }})">
                                        Limpiar
                                    </button>
                                </div>
                            {% endif %}
                        </div>

                        {% if textos|length > 0 %}
                            <div class="mo-grid">
                                {% for texto in textos %}
                                    {% set seleccionadosTipo = seleccionadosManoObra[tipo.id]|default([]) %}

                                    <div class="mo-card {% if texto.id in seleccionadosTipo %}active{% endif %}"
                                        data-id="{{ texto.id }}"
                                        data-tipo="{{ tipo.id }}"
                                        onclick="toggleTexto(this)">
                                        {{ texto.descripcionXo }}
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="mt-3">
                                <label class="form-label-upper">Texto adicional</label>

                                <textarea
                                    name="textoManual[{{ tipo.id }}]"
                                    class="form-control form-control-custom"
                                    rows="2"
                                    placeholder="Añadir detalle manual...">{{ textosManuales[tipo.id]|default('') }}</textarea>
                            </div>                            
                        {% else %}
                            <div class="mo-empty">
                                No hay textos definidos para esta categoría.
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>

        </div>

        <div class="offcanvas-footer px-4 py-3 d-flex justify-content-between align-items-center gap-2">
            <div class="small text-muted">
                <span id="mano-obra-total-seleccionados">0</span> textos seleccionados
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="offcanvas">
                    Cancelar
                </button>
                <button type="submit" class="btn btn-sm btn-modal-save">
                    Guardar
                </button>
            </div>
        </div>
    </form>
</div>
{% endblock %}
{% block jscustom %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    {% for message in app.flashes('success') %}
        Swal.fire({
            toast: true,
            position: 'top-end',
            icon: 'success',
            title: '{{ message|e('js') }}',
            showConfirmButton: false,
            timer: 2500,
            timerProgressBar: true
        });
    {% endfor %}

    {% if app.request.query.get('error') %}
        var modal = new bootstrap.Modal(document.getElementById('modalCabecera'));
        modal.show();
    {% endif %}

    let searchTimer = null;
    function abrirEdicion(id, tipo, descripcion, cantidad, precio, descuento, productoId, productoNombre) {
        // Marcar que estamos editando
        document.getElementById('hidden-linea-id').value = id;
        document.getElementById('offcanvas-title').textContent = 'Editar línea';
        document.getElementById('offcanvas-subtitle').textContent = 'Modifica los datos de la línea';
        document.querySelector('#form-linea [type="submit"]').textContent = 'Guardar cambios';

        // Seleccionar el tipo correcto
        cambiarTipoLinea(tipo);

        // Rellenar campos según tipo
        if (tipo === 'producto') {
            if (productoId) {
                seleccionarProducto(productoId, productoNombre, precio);
            } else {
                activarFaseFormulario();
            }
            document.getElementById('f-descripcion').value = descripcion;
            document.getElementById('f-cantidad').value = cantidad;
            document.getElementById('f-precio').value = precio;
            document.getElementById('f-descuento').value = descuento;
        } else if (tipo === 'servicio' || tipo === 'mano_obra') {
            document.getElementById('f-descripcion-servicio').value = descripcion;
            document.getElementById('f-cantidad-servicio').value = cantidad;
            document.getElementById('f-precio-servicio').value = precio;
            document.getElementById('f-descuento-servicio').value = descuento;
        } else if (tipo === 'comentario') {
            document.getElementById('f-descripcion-comentario').value = descripcion;
        }

        calcularSubtotal();
    }
    function activarBotonTipo(tipo) {
        document.querySelectorAll('.js-tipo-linea').forEach(btn => {
            btn.classList.remove('btn-primary', 'active');
            btn.classList.add('btn-outline-primary');
        });

        const btnActivo = document.getElementById('btn-tipo-' + tipo);
        btnActivo.classList.remove('btn-outline-primary');
        btnActivo.classList.add('btn-primary', 'active');
    }

    function ocultarTodasLasFases() {
        document.getElementById('fase-busqueda-producto').classList.add('d-none');
        document.getElementById('fase-formulario-producto').classList.add('d-none');
        document.getElementById('fase-formulario-servicio').classList.add('d-none');
        document.getElementById('fase-formulario-comentario').classList.add('d-none');
    }

    function limpiarNamesInactivos() {
        document.getElementById('f-descripcion').disabled = true;
        document.getElementById('f-cantidad').disabled = true;
        document.getElementById('f-precio').disabled = true;
        document.getElementById('f-descuento').disabled = true;

        document.getElementById('f-descripcion-servicio').disabled = true;
        document.getElementById('f-cantidad-servicio').disabled = true;
        document.getElementById('f-precio-servicio').disabled = true;
        document.getElementById('f-descuento-servicio').disabled = true;

        document.getElementById('f-descripcion-comentario').disabled = true;
        document.getElementById('f-cantidad-comentario').disabled = true;
        document.getElementById('f-precio-comentario').disabled = true;
        document.getElementById('f-descuento-comentario').disabled = true;

        document.getElementById('f-descripcion').required = false;
        document.getElementById('f-cantidad').required = false;
        document.getElementById('f-precio').required = false;

        document.getElementById('f-descripcion-servicio').required = false;
        document.getElementById('f-cantidad-servicio').required = false;
        document.getElementById('f-precio-servicio').required = false;

        document.getElementById('f-descripcion-comentario').required = false;
    }

    function cambiarTipoLinea(tipo) {
        document.getElementById('hidden-tipo-linea').value = tipo;
        activarBotonTipo(tipo);
        ocultarTodasLasFases();
        limpiarNamesInactivos();

        document.getElementById('hidden-producto-id').value = '';
        document.getElementById('producto-seleccionado-nombre').textContent = '';

        if (tipo === 'producto') {
            document.getElementById('fase-busqueda-producto').classList.remove('d-none');
            document.getElementById('offcanvas-subtitle').textContent = 'Busca un producto o añade una línea manual';

            document.getElementById('f-descripcion').disabled = false;
            document.getElementById('f-cantidad').disabled = false;
            document.getElementById('f-precio').disabled = false;
            document.getElementById('f-descuento').disabled = false;

            document.getElementById('f-descripcion').required = true;
            document.getElementById('f-cantidad').required = true;
            document.getElementById('f-precio').required = true;

            return;
        }

        if (tipo === 'servicio') {
            document.getElementById('fase-formulario-servicio').classList.remove('d-none');
            document.getElementById('offcanvas-subtitle').textContent = 'Añade una línea de servicio manual';

            document.getElementById('f-descripcion-servicio').disabled = false;
            document.getElementById('f-cantidad-servicio').disabled = false;
            document.getElementById('f-precio-servicio').disabled = false;
            document.getElementById('f-descuento-servicio').disabled = false;

            document.getElementById('f-descripcion-servicio').required = true;
            document.getElementById('f-cantidad-servicio').required = true;
            document.getElementById('f-precio-servicio').required = true;

            calcularSubtotalServicio();
            return;
        }

        if (tipo === 'comentario') {
            document.getElementById('fase-formulario-comentario').classList.remove('d-none');
            document.getElementById('offcanvas-subtitle').textContent = 'Añade una línea de comentario';

            document.getElementById('f-descripcion-comentario').disabled = false;
            document.getElementById('f-cantidad-comentario').disabled = false;
            document.getElementById('f-precio-comentario').disabled = false;
            document.getElementById('f-descuento-comentario').disabled = false;

            document.getElementById('f-descripcion-comentario').required = true;
        }
    }

    function seleccionarProducto(id, nombre, pvp) {
        document.getElementById('hidden-tipo-linea').value = 'producto';
        activarBotonTipo('producto');
        ocultarTodasLasFases();
        limpiarNamesInactivos();


        document.getElementById('hidden-producto-id').value = id;
        document.getElementById('producto-seleccionado-nombre').textContent = nombre;

        document.getElementById('f-descripcion').value = nombre;
        document.getElementById('f-precio').value = parseFloat(pvp).toFixed(2);

        document.getElementById('f-descripcion').disabled = false;
        document.getElementById('f-cantidad').disabled = false;
        document.getElementById('f-precio').disabled = false;
        document.getElementById('f-descuento').disabled = false;

        document.getElementById('f-descripcion').required = true;
        document.getElementById('f-cantidad').required = true;
        document.getElementById('f-precio').required = true;

        document.getElementById('fase-formulario-producto').classList.remove('d-none');
        document.getElementById('offcanvas-subtitle').textContent = 'Rellena los datos de la línea';

        calcularSubtotalProducto();
        actualizarPreviewProducto();
    }

    function limpiarProducto() {
        document.getElementById('hidden-producto-id').value = '';
        document.getElementById('producto-seleccionado-nombre').textContent = '';
        document.getElementById('f-descripcion').value = '';
        document.getElementById('f-precio').value = '';
        document.getElementById('f-descuento').value = '0';
        document.getElementById('subtotal-preview-producto').textContent = '';

        cambiarTipoLinea('producto');
    }

    function calcularSubtotalProducto() {
        const cant = parseFloat(document.getElementById('f-cantidad').value) || 0;
        const precio = parseFloat(document.getElementById('f-precio').value) || 0;
        const dto = parseFloat(document.getElementById('f-descuento').value) || 0;
        const sub = cant * precio * (1 - dto / 100);

        document.getElementById('subtotal-preview-producto').textContent = 'Subtotal: ' + sub.toFixed(2) + ' €';
    }

    function calcularSubtotalServicio() {
        const cant = parseFloat(document.getElementById('f-cantidad-servicio').value) || 0;
        const precio = parseFloat(document.getElementById('f-precio-servicio').value) || 0;
        const dto = parseFloat(document.getElementById('f-descuento-servicio').value) || 0;
        const sub = cant * precio * (1 - dto / 100);

        document.getElementById('subtotal-preview-servicio').textContent = 'Subtotal: ' + sub.toFixed(2) + ' €';
    }

    function buscarProductos(q) {
        fetch(`/admin/documento/productos/buscar?q=${encodeURIComponent(q)}`)
            .then(r => r.json())
            .then(data => renderResultados(data))
            .catch(() => {});
    }

    function renderResultados(productos) {
        const container = document.getElementById('resultados-busqueda');

        if (productos.length === 0) {
            container.innerHTML = '<div class="text-center text-muted py-4 small">Sin resultados. Prueba con la opción manual.</div>';
            return;
        }

        container.innerHTML = productos.map(p => {
            const stockHtml = p.stock === 0
                ? '<span class="text-danger">Sin stock</span>'
                : p.stock <= 5
                    ? `<span class="text-warning">Stock: ${p.stock}</span>`
                    : `<span class="text-success">Stock: ${p.stock}</span>`;

            return `
                <div class="resultado-item px-4 py-2 d-flex align-items-center gap-3"
                     onclick="seleccionarProducto(${p.id}, '${(p.nombre ?? '').replace(/'/g, "\\'")}', ${p.pvp})">
                    <div class="resultado-icono flex-shrink-0">
                        ${(p.tipo ?? '?').substring(0, 2).toUpperCase()}
                    </div>
                    <div class="flex-grow-1 min-w-0">
                        <div class="small fw-semibold text-truncate">${p.nombre ?? '—'}</div>
                        <div class="d-flex gap-2" style="font-size:11px;">
                            <span class="text-muted">${p.tipo ?? '—'}</span>
                            ${stockHtml}
                        </div>
                    </div>
                    <div class="small fw-semibold text-nowrap">${parseFloat(p.pvp).toFixed(2)} €</div>
                </div>
            `;
        }).join('');
    }

    function cancelarOffcanvasLinea() {
        const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('offcanvasLinea'));
        offcanvas?.hide();
    }

    function resetOffcanvasLinea() {
        document.getElementById('form-linea').reset();

        document.getElementById('hidden-producto-id').value = '';
        document.getElementById('hidden-tipo-linea').value = 'producto';
        document.getElementById('producto-search').value = '';
        document.getElementById('producto-seleccionado-nombre').textContent = '';

        document.getElementById('f-cantidad').value = '1';
        document.getElementById('f-descuento').value = '0';
        document.getElementById('f-cantidad-servicio').value = '1';
        document.getElementById('f-descuento-servicio').value = '0';

        document.getElementById('subtotal-preview-producto').textContent = '';
        document.getElementById('subtotal-preview-servicio').textContent = '';

        document.getElementById('resultados-busqueda').innerHTML =
            '<div class="text-center text-muted py-4 small">Empieza a escribir para buscar productos</div>';

        cambiarTipoLinea('producto');
    }
    /****************************************
    *      Nueva Mano de Obra             *
    *****************************************/

    function cambiarCategoria(id) {

        document.querySelectorAll('.mo-panel').forEach(p => p.classList.add('d-none'));
        document.getElementById('panel-' + id).classList.remove('d-none');

        document.querySelectorAll('.mo-tab').forEach(t => t.classList.remove('active'));
        document.getElementById('tab-' + id).classList.add('active');
    }

    function toggleTexto(el) {
        el.classList.toggle('active');
    } 

    function cambiarCategoria(id) {
        document.querySelectorAll('.mo-panel').forEach(p => p.classList.add('d-none'));
        const panel = document.getElementById('panel-' + id);
        if (panel) {
            panel.classList.remove('d-none');
        }

        document.querySelectorAll('.mo-tab').forEach(t => t.classList.remove('active'));
        const tab = document.getElementById('tab-' + id);
        if (tab) {
            tab.classList.add('active');
        }
    }

    function toggleTexto(el) {
        el.classList.toggle('active');
        refrescarInputsManoObra();
    }

    function seleccionarTodoTipo(tipoId) {
        document
            .querySelectorAll('.mo-card[data-tipo="' + tipoId + '"]')
            .forEach(card => card.classList.add('active'));

        refrescarInputsManoObra();
    }

    function limpiarTipo(tipoId) {
        document
            .querySelectorAll('.mo-card[data-tipo="' + tipoId + '"]')
            .forEach(card => card.classList.remove('active'));

        refrescarInputsManoObra();
    }

    function refrescarInputsManoObra() {
        const container = document.getElementById('mano-obra-hidden-inputs');
        container.innerHTML = '';

        const cardsActivas = document.querySelectorAll('.mo-card.active');
        let total = 0;
        const contadorPorTipo = {};

        cardsActivas.forEach((card, index) => {
            const textoId = card.dataset.id;
            const tipoId = card.dataset.tipo;

            const inputTexto = document.createElement('input');
            inputTexto.type = 'hidden';
            inputTexto.name = `selecciones[${tipoId}][]`;
            inputTexto.value = textoId;
            container.appendChild(inputTexto);

            total++;
            contadorPorTipo[tipoId] = (contadorPorTipo[tipoId] || 0) + 1;
        });

        document.querySelectorAll('[id^="count-tipo-"]').forEach(el => {
            const tipoId = el.id.replace('count-tipo-', '');
            const totalCategoria = el.textContent.split('/')[1] || '0';
            const seleccionados = contadorPorTipo[tipoId] || 0;
            el.textContent = `${seleccionados}/${totalCategoria}`;
        });

        const totalEl = document.getElementById('mano-obra-total-seleccionados');
        if (totalEl) {
            totalEl.textContent = total;
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        refrescarInputsManoObra();
    });

    document.addEventListener('DOMContentLoaded', function() {
        const offcanvasEl = document.getElementById('offcanvasLinea');
        document.body.appendChild(offcanvasEl);
        new bootstrap.Offcanvas(offcanvasEl);

        const backdrop = document.createElement('div');
        backdrop.className = 'offcanvas-manual-backdrop';
        backdrop.id = 'offcanvas-backdrop-manual';
        document.body.appendChild(backdrop);

        backdrop.addEventListener('click', function() {
            bootstrap.Offcanvas.getInstance(document.getElementById('offcanvasLinea'))?.hide();
        });

        document.getElementById('producto-search').addEventListener('input', function() {
            clearTimeout(searchTimer);
            const q = this.value.trim();

            if (q.length < 2) {
                document.getElementById('resultados-busqueda').innerHTML =
                    '<div class="text-center text-muted py-4 small">Empieza a escribir para buscar productos</div>';
                return;
            }

            searchTimer = setTimeout(() => buscarProductos(q), 280);
        });

        ['f-cantidad', 'f-precio', 'f-descuento'].forEach(id => {
            document.getElementById(id)?.addEventListener('input', calcularSubtotalProducto);
        });

        ['f-cantidad-servicio', 'f-precio-servicio', 'f-descuento-servicio'].forEach(id => {
            document.getElementById(id)?.addEventListener('input', calcularSubtotalServicio);
        });

        document.getElementById('offcanvasLinea').addEventListener('show.bs.offcanvas', function() {
            document.getElementById('offcanvas-backdrop-manual').style.display = 'block';
            document.getElementById('hidden-linea-id').value = '';
            document.getElementById('offcanvas-title').textContent = 'Añadir línea';
            document.getElementById('offcanvas-subtitle').textContent = 'Busca un producto o añade una línea manual';
            document.querySelector('#form-linea [type="submit"]').textContent = 'Añadir línea';            
            resetOffcanvasLinea();
        });

        document.getElementById('offcanvasLinea').addEventListener('hide.bs.offcanvas', function() {
            document.getElementById('offcanvas-backdrop-manual').style.display = 'none';
        });
    });

    $(document).on('click', 'a[name="delete_cobro"]', async function () {
        const id = this.dataset.id;

        const swal = Swal.mixin({
            customClass: {
                confirmButton: 'btn btn-success',
                cancelButton:  'mr-2 btn btn-danger'
            },
            buttonsStyling: false
        });

        const result = await swal.fire({
            title:             'Borrar cobro',
            text:              'Esta acción no se puede deshacer.',
            icon:              'question',
            showCancelButton:  true,
            confirmButtonText: 'Sí, borrar',
            cancelButtonText:  'Cancelar',
            reverseButtons:    true
        });

        if (result.isConfirmed) {
            $.ajax({
                url:      '{{ path("cobro_delete_ajax", {id: 0}) }}'.replace('/0/', '/' + id + '/'),
                type:     'GET',
                dataType: 'json',
                success: function () {
                    Swal.fire({
                        icon:              'success',
                        title:             '¡Cobro eliminado!',
                        timer:             1800,
                        showConfirmButton: false,
                        timerProgressBar:  true
                    }).then(() => location.reload());
                },
                error: (xhr) => alert('Error: ' + xhr.responseJSON?.error ?? 'desconocido')
            });
        }
    });

</script>


<script>
function formatearEuro(valor) {
    return new Intl.NumberFormat('es-ES', {
        style: 'currency',
        currency: 'EUR'
    }).format(valor || 0);
}

function redondear(valor) {
    return Math.round((valor + Number.EPSILON) * 100) / 100;
}

function calcularImportesLinea(cantidad, precioSinIva, descuento, tipoIva) {
    cantidad = parseFloat(cantidad) || 0;
    precioSinIva = parseFloat(precioSinIva) || 0;
    descuento = parseFloat(descuento) || 0;
    tipoIva = parseFloat(tipoIva) || 0;

    const brutoSinIva = cantidad * precioSinIva;
    const descuentoImporte = brutoSinIva * (descuento / 100);
    const subtotalSinIva = redondear(brutoSinIva - descuentoImporte);
    const importeIva = redondear(subtotalSinIva * (tipoIva / 100));
    const totalConIva = redondear(subtotalSinIva + importeIva);
    const precioConIva = redondear(precioSinIva * (1 + tipoIva / 100));

    return {
        precioConIva,
        subtotalSinIva,
        importeIva,
        totalConIva
    };
}

function actualizarPreviewProducto() {
    const cantidad = document.getElementById('f-cantidad')?.value;
    const precio = document.getElementById('f-precio')?.value;
    const descuento = document.getElementById('f-descuento')?.value;
    const tipoIva = 21;

    const datos = calcularImportesLinea(cantidad, precio, descuento, tipoIva);

    const precioIva = document.getElementById('f-precio-iva');
    const subtotalSinIva = document.getElementById('subtotal-sin-iva-producto');
    const importeIva = document.getElementById('importe-iva-producto');
    const totalConIva = document.getElementById('subtotal-preview-producto');

    if (precioIva) precioIva.value = formatearEuro(datos.precioConIva);
    if (subtotalSinIva) subtotalSinIva.textContent = formatearEuro(datos.subtotalSinIva);
    if (importeIva) importeIva.textContent = formatearEuro(datos.importeIva);
    if (totalConIva) totalConIva.textContent = formatearEuro(datos.totalConIva);
}

function actualizarPreviewServicio() {
    const cantidad = document.getElementById('f-cantidad-servicio')?.value;
    const precio = document.getElementById('f-precio-servicio')?.value;
    const descuento = document.getElementById('f-descuento-servicio')?.value;
    const tipoIva = 21;

    const datos = calcularImportesLinea(cantidad, precio, descuento, tipoIva);

    const precioIva = document.getElementById('f-precio-iva-servicio');
    const subtotalSinIva = document.getElementById('subtotal-sin-iva-servicio');
    const importeIva = document.getElementById('importe-iva-servicio');
    const totalConIva = document.getElementById('subtotal-preview-servicio');

    if (precioIva) precioIva.value = formatearEuro(datos.precioConIva);
    if (subtotalSinIva) subtotalSinIva.textContent = formatearEuro(datos.subtotalSinIva);
    if (importeIva) importeIva.textContent = formatearEuro(datos.importeIva);
    if (totalConIva) totalConIva.textContent = formatearEuro(datos.totalConIva);
}

document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.js-recalcular-linea').forEach(el => {
        el.addEventListener('input', actualizarPreviewProducto);
    });

    document.querySelectorAll('.js-recalcular-servicio').forEach(el => {
        el.addEventListener('input', actualizarPreviewServicio);
    });

    actualizarPreviewProducto();
    actualizarPreviewServicio();
});
</script>
