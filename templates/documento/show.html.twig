{% extends 'base.html.twig' %}

{% block cabecera %} Documentos {% endblock %}
{% block breadcrumb %} <li class="breadcrumb-item active">Documento</li>{% endblock %}
{% block title %}Documento{% endblock %}

{% block body %}

<div class="row mb-3">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-body">

                {# FILA 1: IDENTIDAD + ACCIONES #}
                <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
                    <div>
                        <h2 class="mb-0 fw-bold">
                            {{ documento.numeroFormateado ?? 'BORRADOR' }}
                        </h2>
                        <div class="text-muted small text-uppercase mt-1">
                            {{ documento.tipoDocumento }}
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-2 mt-md-0">
                            {% if acciones.puedeEditarCabecera %}
                                <button class="btn btn-sm btn-primary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalCabecera">
                                    Editar cabecera
                                </button>
                            {% endif %}

                           <!-- <button class="btn btn-sm btn-success">
                                Recalcular
                            </button> -->

                            
                            <a href="{{ path('app_documento_pdf', {id: documento.id, tpl: 'clasico'}) }}"
                                target="_blank"
                                class="btn btn-sm btn-outline-dark">
                                    PDF Imprimible
                            </a>                                
                            {% if acciones.puedeGenerarPdf %}                              
                            <a href="{{ path('app_documento_pdf', {id: documento.id, tpl: 'moderno'}) }}"
                                target="_blank"
                                class="btn btn-sm btn-outline-dark">
                                    PDF Email
                            </a>     

                            <a href="{{ path('app_documento_pdf', {id: documento.id, tpl: 'cliente'}) }}"
                                target="_blank"
                                class="btn btn-sm btn-outline-dark">
                                    PDF Cliente
                            </a> 

                            {% endif %}          

                            {% if acciones.puedeEntregar %}
                                <form method="post" action="{{ path('app_documento_entregar', {id: documento.id}) }}">
                                    <button class="btn btn-sm btn-success">Marcar como entregado</button>
                                </form>
                            {% endif %}

                            {% if acciones.puedeAceptar %}
                                <form method="post" action="{{ path('app_documento_aceptar', {id: documento.id}) }}">
                                    <button class="btn btn-sm btn-success">Aceptar</button>
                                </form>
                            {% endif %}

                            {% if acciones.puedeRechazar %}
                                <form method="post" action="{{ path('app_documento_rechazar', {id: documento.id}) }}">
                                    <button class="btn btn-sm btn-danger">Rechazar</button>
                                </form>
                            {% endif %}                                         

                    </div>
                </div>

                {# FILA 2: DATOS PRINCIPALES #}
                <div class="row g-3 align-items-start">

                    <div class="col-md-2">
                        <div class="small text-muted">Fecha</div>
                        <div class="fw-semibold">
                            {{ documento.fechaEmision ? documento.fechaEmision|date('d/m/Y') : '—' }}
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="small text-muted">Cliente</div>
                        <div class="fw-semibold">
                            {% if documento.cliente %}
                                {{ documento.cliente.nombreCl ?? documento.cliente }}
                            {% else %}
                                <span class="text-muted">Sin cliente</span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="small text-muted">Proyecto</div>
                        <div class="fw-semibold">
                            {% if documento.proyecto %}
                                {{ documento.proyecto.nombre }}
                            {% else %}
                                <span class="text-muted">Sin proyecto</span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="small text-muted mb-1">Estados</div>
                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge bg-secondary">
                                {{ documento.estadoComercial }}
                            </span>
                            <span class="badge bg-warning text-dark">
                                {{ documento.estadoCobro }}
                            </span>
                            <span class="badge bg-info text-dark">
                                {{ documento.estadoEjecucion }}
                            </span>
                        </div>
                    </div>

                    <div class="col-md-4 ms-auto">
                        <div class="d-flex gap-3 justify-content-end">

                            <div class="text-center px-3 border-end">
                                <div class="small text-muted">Base</div>
                                <div class="fw-semibold">
                                    {{ documento.baseImponible|number_format(2, ',', '.') }} €
                                </div>
                            </div>

                            <div class="text-center px-3 border-end">
                                <div class="small text-muted">IVA</div>
                                <div class="fw-semibold">
                                    {{ documento.totalIva|number_format(2, ',', '.') }} €
                                </div>
                            </div>

                            <div class="text-center ps-3">
                                <div class="small text-muted">Total</div>
                                <div class="fw-bold fs-5 text-primary">
                                    {{ documento.total|number_format(2, ',', '.') }} €
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
                {# FILA 3: NOTAS #}
                {% if documento.notas %}
                    <hr class="my-3">
                    <div>
                        <div class="small text-muted">Notas</div>
                        <div>
                            {{ documento.notas|nl2br }}
                        </div>
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
</div>
{# ── COBROS ── #}
{% if acciones.puedeRegistrarCobro %}
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="border-bottom title-part-padding d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Cobros</h4>
                {% if documento.estadoCobro != 'cobrado' %}
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalNuevoCobro">
                        + Registrar cobro
                    </button>
                {% endif %}
            </div>
            <div class="card-body">

                {# Resumen importes #}
                <div class="row mb-3 text-center">
                    <div class="col-4">
                        <div class="text-muted small">Total factura</div>
                        <div class="fw-bold">{{ documento.total | format_currency('EUR', locale='es') }}</div>
                    </div>
                    <div class="col-4">
                        <div class="text-muted small">Cobrado</div>
                        <div class="fw-bold text-success">{{ documento.totalCobrado | format_currency('EUR', locale='es') }}</div>
                    </div>
                    <div class="col-4">
                        <div class="text-muted small">Pendiente</div>
                        {% set pendiente = documento.total - documento.totalCobrado %}
                        <div class="fw-bold {{ pendiente > 0 ? 'text-danger' : 'text-success' }}">
                            {{ pendiente | format_currency('EUR', locale='es') }}
                        </div>
                    </div>
                </div>

                {# Tabla de cobros #}
                {% if documento.cobros is empty %}
                    <p class="text-muted">Sin cobros registrados.</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-sm table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Método</th>
                                    <th class="text-end">Importe bruto</th>
                                    <th class="text-end">% Recargo</th>
                                    <th class="text-end">Recargo</th>
                                    <th class="text-end">Neto</th>
                                    <th>Referencia</th>
                                    <th>Notas</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% set metodoColores = {
                                    'efectivo':      'success',
                                    'tarjeta':       'primary',
                                    'transferencia': 'info',
                                    'bizum':         'warning',
                                    'financiacion':  'secondary'
                                } %}
                                {% for cobro in documento.cobros %}
                                    <tr>
                                        <td class="text-nowrap">{{ cobro.fecha | date('d/m/Y') }}</td>
                                        <td>
                                            <span class="badge bg-{{ metodoColores[cobro.metodo] ?? 'secondary' }}">
                                                {{ cobro.metodo }}
                                            </span>
                                        </td>
                                        <td class="text-end">{{ cobro.importeBruto | format_currency('EUR', locale='es') }}</td>
                                        <td class="text-end">
                                            {% if cobro.porcentajeRecargo > 0 %}
                                                {{ cobro.porcentajeRecargo }}%
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            {% if cobro.importeRecargo > 0 %}
                                                {{ cobro.importeRecargo | format_currency('EUR', locale='es') }}
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td class="text-end">{{ cobro.importeNeto | format_currency('EUR', locale='es') }}</td>
                                        <td>{{ cobro.referencia ?? '—' }}</td>
                                        <td>{{ cobro.notas ?? '—' }}</td>
                                        <td>
                                            <a class="text-inverse" data-toggle="tooltip" title="Borrar cobro"
                                               name="delete_cobro" data-id="{{ cobro.id }}">
                                                <i class="ti-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{# ── MODAL NUEVO COBRO ── #}
<div class="modal fade" id="modalNuevoCobro" tabindex="-1" aria-labelledby="modalNuevoCobroLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalNuevoCobroLabel">Registrar cobro</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form method="post" action="{{ path('cobro_nuevo', {id: documento.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('cobro_nuevo_' ~ documento.id) }}">
                <div class="modal-body row g-3">

                    <div class="col-6">
                        <label class="form-label">Fecha <span class="text-danger">*</span></label>
                        <input type="date" name="fecha" class="form-control form-control-sm"
                               value="{{ "now" | date('Y-m-d') }}" required>
                    </div>

                    <div class="col-6">
                        <label class="form-label">Método <span class="text-danger">*</span></label>
                        <select name="metodo" class="form-select form-select-sm" required>
                            <option value="">— Selecciona —</option>
                            <option value="efectivo">Efectivo</option>
                            <option value="tarjeta">Tarjeta</option>
                            <option value="transferencia">Transferencia</option>
                            <option value="bizum">Bizum</option>
                            <option value="financiacion">Financiación</option>
                        </select>
                    </div>

                    <div class="col-6">
                        <label class="form-label">Importe bruto <span class="text-danger">*</span></label>
                        <div class="input-group input-group-sm">
                            <input type="number" name="importeBruto" class="form-control"
                                   step="0.01" min="0.01" required
                                   placeholder="{{ pendiente | number_format(2, '.', '') }}">
                            <span class="input-group-text">€</span>
                        </div>
                    </div>

                    <div class="col-6">
                        <label class="form-label">% Recargo</label>
                        <div class="input-group input-group-sm">
                            <input type="number" name="porcentajeRecargo" class="form-control"
                                   step="0.01" min="0" value="0">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>

                    <div class="col-6">
                        <label class="form-label">Importe recargo</label>
                        <div class="input-group input-group-sm">
                            <input type="number" name="importeRecargo" class="form-control"
                                   step="0.01" min="0" value="0">
                            <span class="input-group-text">€</span>
                        </div>
                    </div>

                    <div class="col-6">
                        <label class="form-label">Importe neto</label>
                        <div class="input-group input-group-sm">
                            <input type="number" name="importeNeto" class="form-control"
                                   step="0.01" min="0" value="0">
                            <span class="input-group-text">€</span>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Referencia</label>
                        <input type="text" name="referencia" class="form-control form-control-sm"
                               placeholder="Nº transferencia, VISA *1234, ref. financiera…">
                    </div>

                    <div class="col-12">
                        <label class="form-label">Notas</label>
                        <textarea name="notas" class="form-control form-control-sm" rows="2"></textarea>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-sm btn-primary">Guardar cobro</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}
{# TABLA DE LÍNEAS #}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
                    <div>
                        <h4 class="mb-0">Líneas del documento</h4>
                        <div class="text-muted small">
                            Productos, mano de obra y servicios
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-2 mt-md-0">
                        {% if acciones.puedeAnadirLinea %}                    
                        <button class="btn btn-sm btn-primary"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#offcanvasLinea">
                            Añadir línea
                        </button>
                        {% endif %}
                    </div>
                </div>

                {% if documento.lineas|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 60px;">#</th>
                                    <th style="width: 120px;">Tipo</th>
                                    <th>Descripción</th>
                                    <th class="text-end" style="width: 90px;">Cant.</th>
                                    <th style="width: 80px;">Unidad</th>
                                    <th class="text-end" style="width: 110px;">Precio</th>
                                    <th class="text-end" style="width: 90px;">Dto.</th>
                                    <th class="text-end" style="width: 90px;">IVA</th>
                                    <th class="text-end" style="width: 130px;">Subtotal</th>
                                    <th class="text-end" style="width: 160px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for linea in documento.lineas %}
                                    <tr>
                                        <td>{{ linea.posicion }}</td>
                                        <td>
                                            <span class="badge bg-light text-dark border">
                                                {{ linea.tipoLinea }}
                                            </span>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">
                                                {{ linea.descripcion }}
                                            </div>

                                            {% if linea.producto %}
                                                <div class="small text-muted">
                                                    Producto vinculado
                                                </div>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">{{ linea.cantidad|number_format(0, ',', '.') }}</td>
                                        <td>{{ linea.unidad }}</td>
                                        <td class="text-end">
                                            {{ linea.precioUnitario|number_format(2, ',', '.') }} €
                                        </td>
                                        <td class="text-end">
                                            {{ linea.descuento|number_format(2, ',', '.') }} %
                                        </td>
                                        <td class="text-end">
                                            {{ linea.tipoIva|number_format(2, ',', '.') }} %
                                        </td>
                                        <td class="text-end fw-semibold">
                                            {{ (linea.subtotal + linea.totalIva)|number_format(2, ',', '.') }} €
                                        </td>
                                        <td class="text-end">
                                            {% if acciones.puedeEditarLineas %}
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-primary btn-sm"
                                                            data-bs-toggle="offcanvas"
                                                            data-bs-target="#offcanvasLinea"
                                                            onclick="abrirEdicion(
                                                                {{ linea.id }},
                                                                '{{ linea.tipoLinea }}',
                                                                '{{ linea.descripcion|e('js') }}',
                                                                {{ linea.cantidad }},
                                                                {{ linea.precioUnitario }},
                                                                {{ linea.descuento }},
                                                                {{ linea.producto ? linea.producto.id : 'null' }},
                                                                '{{ linea.producto ? linea.producto.descripcionPd|e('js') : '' }}'
                                                            )">
                                                        Editar
                                                    </button>
                                                    <form method="post"
                                                        action="{{ path('app_documento_linea_eliminar', {id: linea.id}) }}"
                                                        class="d-inline"
                                                        onsubmit="return confirm('¿Seguro que quieres eliminar esta línea?');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('eliminar-linea-' ~ linea.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-danger">
                                                            Borrar
                                                        </button>
                                                    </form>
                                                </div>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="border rounded p-4 bg-light-subtle">
                        <div class="fw-semibold mb-1">Todavía no hay líneas</div>
                        <div class="text-muted small">
                            Empieza añadiendo un producto, una mano de obra o un servicio.
                        </div>

                    </div>
                {% endif %}
  
            </div>
         
        </div>
      
    </div>
    
</div>




{# ── MANO DE OBRA ── #}
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm border-0 card-mano-obra-resumen">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <div class="mano-obra-icon-wrap">
                                <i class="ti-write"></i>
                            </div>
                            <div>
                                <h4 class="mb-0">Mano de obra</h4>
                                <div class="text-muted small">
                                    Descripción técnica para presupuesto y control interno
                                </div>
                            </div>
                        </div>

                        {% set totalCategorias = documento.manoObra|length %}

                        {% if totalCategorias > 0 %}
                            <div class="text-muted small">
                                {{ totalCategorias }} categoría{{ totalCategorias > 1 ? 's' : '' }} configurada{{ totalCategorias > 1 ? 's' : '' }}
                            </div>
                        {% else %}
                            <div class="text-muted small">
                                Todavía no has configurado la mano de obra descriptiva
                            </div>
                        {% endif %}
                    </div>

                    <div class="d-flex gap-2">
                        <button
                            type="button"
                            class="btn btn-sm btn-primary"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#offcanvasManoObra">
                            Editar mano de obra
                        </button>
                    </div>
                </div>

                {% if documento.manoObra|length > 0 %}
                    <div class="mb-3 d-flex flex-wrap gap-2">
                        {% for mo in documento.manoObra %}
                            <span class="badge badge-mano-obra">
                                {{ mo.categoriaMo ? mo.categoriaMo.TipoTm : 'Sin categoría' }}
                            </span>
                        {% endfor %}
                    </div>

                    <div class="row g-3">
                        {% for mo in documento.manoObra %}
                            <div class="col-12 col-xl-6">
                                <div class="mano-obra-resumen-item h-100">
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                        <div class="fw-semibold">
                                            {{ mo.categoriaMo ? mo.categoriaMo.TipoTm : 'Sin categoría' }}
                                        </div>
                                        {% if mo.coste %}
                                            <div class="small text-muted text-nowrap">
                                                {{ mo.coste|format_currency('EUR', locale='es') }}
                                            </div>
                                        {% endif %}
                                    </div>

                                    <div class="mano-obra-texto-preview">

                                        {# ─── TEXTOS SELECCIONADOS ─── #}
                                        {% set hayLineas = false %}

                                        {% for sel in mo.seleccionesTexto %}
                                            {% if sel.textoManoObra and sel.textoManoObra.descripcionXo|trim != '' %}
                                                {% set hayLineas = true %}
                                                <div class="mano-obra-bullet-line">
                                                    <span class="mano-obra-bullet-dot"></span>
                                                    <span>{{ sel.textoManoObra.descripcionXo }}</span>
                                                </div>
                                            {% endif %}
                                        {% endfor %}

                                        {# ─── TEXTO MANUAL ADICIONAL ─── #}
                                        {% if mo.textoMo %}
                                            {% for linea in mo.textoMo|split(';') %}
                                                {% if linea|trim != '' %}
                                                    {% set hayLineas = true %}
                                                    <div class="mano-obra-bullet-line">
                                                        <span class="mano-obra-bullet-dot"></span>
                                                        <span>{{ linea|trim }}</span>
                                                    </div>
                                                {% endif %}
                                            {% endfor %}
                                        {% endif %}

                                        {# ─── VACÍO ─── #}
                                        {% if not hayLineas %}
                                            <span class="text-muted small">Sin descripción</span>
                                        {% endif %}

                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="mano-obra-empty-state">
                        <div class="mano-obra-empty-icon mb-3">
                            <i class="ti-layout-list-thumb"></i>
                        </div>
                        <div class="fw-semibold mb-1">Aún no hay mano de obra definida</div>
                        <div class="text-muted small mb-3">
                            Selecciona por categorías los trabajos que formarán parte de la propuesta.
                        </div>
                        <button
                            type="button"
                            class="btn btn-sm btn-primary"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#offcanvasManoObra">
                            Empezar ahora
                        </button>
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="modalCabecera" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content modal-cabecera">

      <div class="modal-stripe"></div>

      <div class="modal-header border-0 pb-3 pt-3 px-4">
        <div class="d-flex align-items-center gap-3">
          <div class="modal-icon-wrap">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 13.5V15h1.5l8.83-8.83-1.5-1.5L3 13.5zM14.71 4.04a.996.996 0 0 0 0-1.41l-1.34-1.34a.996.996 0 0 0-1.41 0l-1.05 1.05 2.75 2.75 1.05-1.05z" fill="#185FA5"/>
            </svg>
          </div>
          <div>
            <h5 class="modal-title mb-0">Editar cabecera</h5>
            <div class="modal-doc-ref">
              {{ documento.numeroFormateado ?? 'BORRADOR' }} · {{ documento.tipoDocumento }}
            </div>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <form method="post"
            action="{{ path('app_documento_guardar_cabecera', {id: documento.id}) }}">

        <div class="modal-body px-4 pt-3 pb-2">
          <div class="row g-3">

            <div class="col-md-4">
              <label class="form-label form-label-upper">Cliente</label>
              <select name="clienteId" class="form-select form-select-custom">
                <option value="">Sin cliente</option>
                {% for cliente in clientes %}
                  <option value="{{ cliente.id }}"
                    {% if documento.cliente and documento.cliente.id == cliente.id %}selected{% endif %}>
                    {{ cliente.nombreCl }}
                  </option>
                {% endfor %}
              </select>
            </div>

            <div class="col-md-4">
              <label class="form-label form-label-upper">Proyecto</label>
              <select name="proyectoId" class="form-select form-select-custom">
                <option value="">Sin proyecto</option>
                {% for proyecto in proyectos %}
                  <option value="{{ proyecto.id }}"
                    {% if documento.proyecto and documento.proyecto.id == proyecto.id %}selected{% endif %}>
                    {{ proyecto.nombre }}
                  </option>
                {% endfor %}
              </select>
            </div>

            <div class="col-md-4">
              <label class="form-label form-label-upper">Fecha emisión</label>
              <input type="date"
                     name="fechaEmision"
                     class="form-control form-control-custom"
                     value="{{ documento.fechaEmision ? documento.fechaEmision|date('Y-m-d') : '' }}">
            </div>

            <div class="col-12">
              <label class="form-label form-label-upper">Notas</label>
              <textarea name="notas"
                        rows="3"
                        class="form-control form-control-custom">{{ documento.notas }}</textarea>
            </div>

          </div>
        </div>

        <div class="modal-footer border-top px-4 py-3">
          <button type="button"
                  class="btn btn-sm btn-modal-cancel"
                  data-bs-dismiss="modal">Cancelar</button>
          <button type="submit"
                  class="btn btn-sm btn-modal-save">Guardar cambios
          </button>
      
        </div>

      </form>
    </div>
  </div>
</div>
{% endblock %}
{% block offcanvas %}
<div class="offcanvas offcanvas-end offcanvas-linea"
     tabindex="-1"
     id="offcanvasLinea"
     data-bs-backdrop="false"
     data-bs-scroll="true">

  <div class="offcanvas-stripe"></div>

  <div class="offcanvas-header border-bottom px-4 pt-3 pb-3">
    <div class="w-100">
      <h5 class="offcanvas-title mb-0" id="offcanvas-title">Añadir línea</h5>
      <div class="offcanvas-subtitle text-muted small mb-3" id="offcanvas-subtitle">
        Busca un producto o añade una línea manual
      </div>

      <div class="d-flex gap-2">
        <button type="button"
                class="btn btn-sm btn-primary flex-fill js-tipo-linea active"
                id="btn-tipo-producto"
                onclick="cambiarTipoLinea('producto')">
          Producto
        </button>
        <button type="button"
                class="btn btn-sm btn-outline-primary flex-fill js-tipo-linea"
                id="btn-tipo-servicio"
                onclick="cambiarTipoLinea('servicio')">
          Servicio
        </button>
        <button type="button"
                class="btn btn-sm btn-outline-primary flex-fill js-tipo-linea"
                id="btn-tipo-comentario"
                onclick="cambiarTipoLinea('comentario')">
          Comentario
        </button>
      </div>
    </div>

    <button type="button" class="btn-close ms-3" data-bs-dismiss="offcanvas"></button>
  </div>

  <form method="post"
        action="{{ path('app_documento_guardar_linea', {id: documento.id}) }}"
        id="form-linea">

    <input type="hidden" name="productoId" id="hidden-producto-id">
    <input type="hidden" name="tipoLinea" id="hidden-tipo-linea" value="producto">
    <input type="hidden" name="lineaId" id="hidden-linea-id" value="">

    {# ── PRODUCTO: FASE 1 BUSCADOR ───────────────────────── #}
    <div id="fase-busqueda-producto">
      <div class="px-4 py-3 border-bottom">
