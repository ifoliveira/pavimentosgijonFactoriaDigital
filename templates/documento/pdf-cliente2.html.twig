<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <style>
        @page { margin: 0; size: A4; }
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            margin: 0; padding: 0;
            width: 210mm;
            font-family: 'DejaVu Sans', sans-serif;
            font-size: 11px;
            color: #1a1a2e;
            background: #fff;
        }

        .page { width: 100%; }

        /* CABECERA */
        .header {
            background-color: #1e2530;
            padding: 22px 36px;
        }
        .header-table { width: 100%; border-collapse: collapse; }
        .logo-cell { width: 45%; vertical-align: middle; }
        .logo-cell img { max-height: 60px; max-width: 220px; }
        .empresa-cell { width: 55%; vertical-align: middle; text-align: right; }
        .empresa-nombre { font-size: 13px; font-weight: bold; color: #f0f2f5; margin-bottom: 4px; }
        .empresa-dato { font-size: 9px; color: #8a95a3; line-height: 1.7; }

        .stripe { height: 4px; background-color: #185FA5; }

        /* INFO DOCUMENTO + CLIENTE */
        .info-section { padding: 24px 36px 20px; }
        .info-table { width: 100%; border-collapse: collapse; }

        .doc-cell { width: 48%; vertical-align: top; }
        .doc-numero { font-size: 26px; font-weight: bold; color: #1e2530; }
        .doc-tipo { font-size: 10px; color: #8a95a3; text-transform: uppercase; letter-spacing: .08em; margin-top: 3px; }
        .doc-meta { margin-top: 12px; border-collapse: collapse; }
        .doc-meta-label { font-size: 9px; color: #8a95a3; text-transform: uppercase; letter-spacing: .06em; padding-right: 12px; padding-bottom: 5px; }
        .doc-meta-value { font-size: 11px; font-weight: bold; color: #1a1a2e; padding-bottom: 5px; }

        .sep-cell { width: 4%; }

        .cliente-cell { width: 48%; vertical-align: top; }
        .cliente-box {
            background-color: #f0f3f7;
            border-left: 3px solid #185FA5;
            padding: 14px 16px;
        }
        .cliente-label { font-size: 9px; color: #8a95a3; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 5px; }
        .cliente-nombre { font-size: 14px; font-weight: bold; color: #1e2530; margin-bottom: 3px; }
        .cliente-dato { font-size: 10px; color: #5a6475; line-height: 1.6; }

        /* NOTAS */
        .notas-section { padding: 0 36px 20px; }
        .notas-box {
            background-color: #fffbea;
            border-left: 3px solid #EF9F27;
            padding: 10px 14px;
            font-size: 10px;
            color: #5a4a00;
            line-height: 1.6;
        }

        /* BLOQUES DE TRABAJO */
        .trabajos-section { padding: 0 36px; }
        .trabajos-title {
            font-size: 10px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: #8a95a3;
            margin-bottom: 10px;
        }

        .bloque {
            border: 1px solid #e8ecf2;
            padding: 14px 16px;
            margin-bottom: 8px;
        }
        .bloque-table { width: 100%; border-collapse: collapse; }
        .bloque-icon-cell { width: 44px; vertical-align: top; padding-right: 14px; }
        .bloque-icon {
            width: 36px; height: 36px;
            display: block;
            background-color: #E6F1FB;
            text-align: center;
            line-height: 36px;
            font-size: 16px;
        }
        .bloque-icon.tipo-demolicion { background-color: #FAEEDA; }
        .bloque-icon.tipo-pavimento  { background-color: #E6F1FB; }
        .bloque-icon.tipo-rodapie    { background-color: #EEEDFE; }
        .bloque-icon.tipo-extra      { background-color: #EAF3DE; }

        .bloque-desc-cell { vertical-align: top; }
        .bloque-titulo { font-size: 12px; font-weight: bold; color: #1e2530; margin-bottom: 4px; }
        .bloque-detalle { font-size: 10px; color: #5a6475; line-height: 1.6; }

        /* TOTALES */
        .totales-section { padding: 20px 36px 0; }
        .totales-table { width: 100%; border-collapse: collapse; }
        .totales-spacer { width: 58%; }
        .totales-content { width: 42%; vertical-align: top; }
        .totales-inner { border-top: 2px solid #1e2530; padding-top: 12px; }
        .totales-row-table { width: 100%; border-collapse: collapse; }
        .t-label { font-size: 10px; color: #5a6475; padding-bottom: 5px; }
        .t-value { font-size: 11px; font-weight: bold; color: #1a1a2e; text-align: right; padding-bottom: 5px; }
        .t-divider { border: none; border-top: 1px solid #e8ecf2; margin: 6px 0; }
        .t-total-label { font-size: 14px; font-weight: bold; color: #1e2530; padding-top: 4px; }
        .t-total-value { font-size: 18px; font-weight: bold; color: #185FA5; text-align: right; padding-top: 4px; }

        /* CONDICIONES MANO DE OBRA */
        .mano-obra-section { margin-top: 20px; padding: 0 36px; }
        .mano-obra-inner { border: 1px solid #bbb; padding: 14px 16px; }
        .mano-obra-title { font-size: 10px; font-weight: bold; text-transform: uppercase; letter-spacing: .06em; color: #444; margin-bottom: 8px; }
        .mano-obra-subtitle { font-size: 10px; font-weight: bold; color: #111; border-bottom: 1px solid #bbb; padding-bottom: 3px; margin-top: 10px; margin-bottom: 6px; }
        .mano-obra-texto { font-size: 10px; color: #333; line-height: 1.6; margin-bottom: 8px; }

        /* PIE */
        .footer {
            margin-top: 36px;
            padding: 16px 36px;
            background-color: #f0f3f7;
            border-top: 2px solid #e8ecf2;
        }
        .footer-table { width: 100%; border-collapse: collapse; }
        .footer-legal { font-size: 8.5px; color: #8a95a3; line-height: 1.6; width: 65%; vertical-align: top; }
        .footer-contacto { font-size: 9px; color: #5a6475; text-align: right; vertical-align: top; line-height: 1.7; width: 35%; }
        .footer-contacto strong { color: #1e2530; }
    </style>
</head>
<body>
<div class="page">

    {# CABECERA #}
    <div class="header">
        <table class="header-table">
            <tr>
                <td class="logo-cell">
                    <img src="{{ logoPath }}" alt="Logo">
                </td>
                <td class="empresa-cell">
                    <div class="empresa-nombre">Pavimentos Gijón</div>
                    <div class="empresa-dato">
                        Av. Schultz nº 28 Bajo · Gijón<br>
                        NIF: 53543499M · Tel: 985 391 326<br>
                        buzon@pavimentosgijon.es
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <div class="stripe"></div>

    {# DATOS DOCUMENTO + CLIENTE #}
    <div class="info-section">
        <table class="info-table">
            <tr>
                <td class="doc-cell">
                    <div class="doc-numero">{{ documento.numeroFormateado ?? 'BORRADOR' }}</div>
                    <div class="doc-tipo">{{ documento.tipoDocumento }}</div>
                    <table class="doc-meta">
                        <tr>
                            <td class="doc-meta-label">Fecha emisión</td>
                            <td class="doc-meta-value">
                                {{ documento.fechaEmision ? documento.fechaEmision|date('d/m/Y') : '—' }}
                            </td>
                        </tr>
                        {% if documento.proyecto %}
                        <tr>
                            <td class="doc-meta-label">Proyecto</td>
                            <td class="doc-meta-value">{{ documento.proyecto.nombre }}</td>
                        </tr>
                        {% endif %}
                    </table>
                </td>

                <td class="sep-cell"></td>

                <td class="cliente-cell">
                    <div class="cliente-box">
                        <div class="cliente-label">Destinatario</div>
                        {% if documento.cliente %}
                            <div class="cliente-nombre">
                                {{ documento.cliente.nombreCl }} {{ documento.cliente.apellidosCl }}
                            </div>
                            {% if documento.cliente.direccionCl is defined and documento.cliente.direccionCl %}
                                <div class="cliente-dato">{{ documento.cliente.direccionCl }}</div>
                            {% endif %}
                            {% if documento.cliente.telefono1Cl is defined and documento.cliente.telefono1Cl %}
                                <div class="cliente-dato">Tel: {{ documento.cliente.telefono1Cl }}</div>
                            {% endif %}
                        {% else %}
                            <div class="cliente-nombre" style="color:#8a95a3;">Sin cliente asignado</div>
                        {% endif %}
                    </div>
                </td>
            </tr>
        </table>
    </div>

    {# NOTAS GENERALES #}
    {% if documento.notas %}
    <div class="notas-section">
        <div class="notas-box">{{ documento.notas }}</div>
    </div>
    {% endif %}

    {# BLOQUES DE TRABAJO — solo líneas que no sean comentarios #}
    <div class="trabajos-section">
        <div class="trabajos-title">Trabajos incluidos</div>

        {% for linea in documento.lineas %}
            {% if linea.tipoLinea != 'comentario' %}
            <div class="bloque">
                <table class="bloque-table">
                    <tr>
                        <td class="bloque-desc-cell">
                            <div class="bloque-titulo">{{ linea.descripcion }}</div>
                        </td>
                    </tr>
                </table>
            </div>
            {% endif %}
        {% endfor %}

    </div>

    {# TOTALES — solo base, IVA y total #}
    <div class="totales-section">
        <table class="totales-table">
            <tr>
                <td class="totales-spacer"></td>
                <td class="totales-content">
                    <div class="totales-inner">
                        <table class="totales-row-table">
                            <tr>
                                <td class="t-label">Base imponible</td>
                                <td class="t-value">
                                    {{ documento.baseImponible|number_format(2, ',', '.') }} €
                                </td>
                            </tr>
                            <tr>
                                <td class="t-label">IVA (21%)</td>
                                <td class="t-value">
                                    {{ documento.totalIva|number_format(2, ',', '.') }} €
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2"><hr class="t-divider"></td>
                            </tr>
                            <tr>
                                <td class="t-total-label">Total</td>
                                <td class="t-total-value">
                                    {{ documento.total|number_format(2, ',', '.') }} €
                                </td>
                            </tr>
                        </table>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    {# CONDICIONES MANO DE OBRA #}
    {% set hayManoObra = documento.manoObra
        |filter(mo => mo.lineasRender|length > 0)
        |length > 0 %}

    {% if hayManoObra %}
    <div class="mano-obra-section">
        <div class="mano-obra-inner">
            <div class="mano-obra-title">Condiciones de mano de obra</div>

            {% for mo in documento.manoObra %}
                {% set lineas = mo.lineasRender %}

                {% if lineas|length > 0 %}

                    <div class="mano-obra-subtitle">
                        {{ mo.categoriaMo.tipoTm }}
                    </div>

                    <div class="mano-obra-texto">
                        {% for linea in lineas %}
                            {{ linea }}{% if not loop.last %}<br>{% endif %}
                        {% endfor %}
                    </div>

                {% endif %}
            {% endfor %}

        </div>
    </div>
    {% endif %}

    {# PIE #}
    <div class="footer">
        <table class="footer-table">
            <tr>
                <td class="footer-legal">
                    Este documento tiene carácter de presupuesto y no constituye factura.<br>
                    Válido durante 30 días desde la fecha de emisión.<br>
                    Los precios incluyen IVA al tipo vigente indicado.
                </td>
                <td class="footer-contacto">
                    <strong>Pavimentos Gijón</strong><br>
                    985 391 326<br>
                    buzon@pavimentosgijon.es
                </td>
            </tr>
        </table>
    </div>

</div>
</body>
</html>