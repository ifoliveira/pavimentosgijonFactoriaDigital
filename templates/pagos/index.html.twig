{% extends 'base.html.twig' %}

{% block title %}Forecast{% endblock %}
{% block cabecera %}Forecast{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Forecast</li>{% endblock %}

{# Select2 CSS — faltaba completamente #}
{% block stylesheets %}
    <link href="{{ asset('assets/libs/select2/dist/css/select2.min.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

    {# Tabla de conciliaciones propuestas #}
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h3 class="card-title">Conciliaciones propuestas</h3>
                    <div class="table-responsive">
                        <table id="default_order" class="table table-striped table-bordered display" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Pago</th>
                                    <th>Banco</th>
                                    <th>Conciliar</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% set pagoshuerfanos = [] %}
                                {% set bancoshuerfanos = [] %}

                                {% for banco in bancos %}
                                    {% set bancoshuerfanos = [{
                                        id:   banco.id,
                                        text: banco.fechaBn|date('Y-m-d') ~ ' Importe : ' ~ banco.importeBn|format_currency('EUR', locale='es')
                                    }]|merge(bancoshuerfanos) %}
                                {% else %}
                                    {% set bancoshuerfanos = [{id: 1, text: 'Sin movimientos que conciliar'}] %}
                                {% endfor %}

                                {% for pago in pagos %}
                                    {% set encontrado = false %}
                                    {% for banco in bancos %}
                                        {% if pago.importePg == banco.importeBn %}
                                            <tr>
                                                <td>{{ pago.fechaPg ? pago.fechaPg|date('Y-m-d') : '' }} — {{ pago.importePg|format_currency('EUR', locale='es') }}</td>
                                                <td>{{ banco.fechaBn ? banco.fechaBn|date('Y-m-d') : '' }} — {{ pago.importePg|format_currency('EUR', locale='es') }} — {{ banco.conceptoBn }}</td>
                                                <td>
                                                    <a onclick="conciliarAjax({{ banco.id }}, 'conciliar/{{ pago.id }}')"
                                                    class="text-inverse pr-2" data-toggle="tooltip" title="Conciliar">
                                                        <i class="ti-link"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                            {% set encontrado = true %}
                                        {% endif %}
                                    {% endfor %}

                                    {% if not encontrado %}
                                        {% set pagoshuerfanos = [{
                                            id:   pago.id,
                                            text: pago.fechaPg|date('Y-m-d') ~ ' Importe : ' ~ pago.importePg|format_currency('EUR', locale='es')
                                        }]|merge(pagoshuerfanos) %}
                                        {# No generamos <tr> para pagos huérfanos — van al select #}
                                    {% endif %}
                                {% endfor %}

                                {# Datos para los selects — fuera del tbody #}
                            </tbody>
                        </table>
                        {# AVISO: los div con data-entry-info estaban dentro del tbody — HTML inválido #}
                        <div data-entry-info='{{ pagoshuerfanos|json_encode|raw }}'></div>
                        <div data-entry-info2='{{ bancoshuerfanos|json_encode|raw }}'></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Selects de conciliación manual #}
    <div class="row">
        <div class="col-md-6 col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Pagos pendientes de conciliar</h4>
                    <select class="form-control" id="select2-data-array" style="width:100%"></select>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Banco pendiente de conciliar</h4>
                    <select class="form-control" id="select3-data-array" style="width:100%"></select>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mt-2">
            <button type="button" class="btn btn-rounded btn-outline-success" onclick="conciliar()">Conciliar</button>
        </div>
    </div>

{% endblock %}

{% block jscustom %}
    {# Select2 — solo full, no cargar los dos #}
    <script src="{{ asset('assets/libs/select2/dist/js/select2.full.min.js') }}"></script>
    {# DataTables responsive #}
    <script src="{{ asset('assets/extra-libs/datatables.net-bs4/js/dataTables.responsive.min.js') }}"></script>

    <script>
    $(document).ready(function () {

        // --- DataTables ---
        $('#default_order').DataTable({
            order: [[2, 'asc']]
            // destroy ya no hace falta — datatable-basic.init.js eliminado de la base
        });

        // --- Leer datos para los selects ---
        const pagosData  = JSON.parse(
            document.querySelector('[data-entry-info]').dataset.entryInfo
        );
        const bancosData = JSON.parse(
            document.querySelector('[data-entry-info2]').dataset.entryInfo2
        );

        // --- Inicializar Select2 dentro del ready() ---
        $('#select2-data-array').select2({ data: pagosData });
        $('#select3-data-array').select2({ data: bancosData });

        // --- Conciliación manual desde los selects ---
        function conciliar() {
            const banco = document.getElementById('select3-data-array').value;
            const pago  = document.getElementById('select2-data-array').value;
            conciliarAjax(banco, `conciliar/${pago}`);
        }

        // Exponer para el onclick del HTML
        window.conciliar      = conciliar;
        window.conciliarAjax  = conciliarAjax;

        // --- AJAX conciliar ---
        function conciliarAjax(banco, url) {
            $.ajax({
                url:      url,
                type:     'GET',
                data:     { banco },
                dataType: 'json',
                success:  () => location.reload(),
                error:    (xhr, status, err) => alert(status + ': ' + err)
            });
        }

    });
    </script>
{% endblock %}