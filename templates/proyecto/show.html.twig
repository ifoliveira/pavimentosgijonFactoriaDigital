{% extends 'base.html.twig' %}

{% block title %}Proyecto {{ proyecto.nombre }}{% endblock %}

{% block body %}
<div class="container py-4">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">{{ proyecto.nombre }}</h1>
            <p class="text-muted mb-0">
                Cliente:
                {{ proyecto.cliente.nombreCl }}
                {% if proyecto.cliente.apellidosCl %}
                    {{ proyecto.cliente.apellidosCl }}
                {% endif %}
            </p>
        </div>

        <div class="d-flex gap-2">
            <button type="button"
                    class="btn btn-outline-primary"
                    id="btnNuevoGasto"
                    data-url="{{ path('app_proyecto_gasto_new', {id: proyecto.id}) }}">
                Añadir gasto
            </button>

            <button type="button"
                                class="btn btn-outline-primary"
                                data-bs-toggle="modal"
                                data-bs-target="#modalNuevoCobroProyecto">
                            + Registrar cobro
            </button>            

        </div>
    </div>


    {% set tienePresupuesto = false %}
    {% for documento in proyecto.documentos %}
        {% if documento.tipoDocumento == 'presupuesto' %}
            {% set tienePresupuesto = true %}
        {% endif %}
    {% endfor %}

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
            <span>Documentos del proyecto</span>

            {% if not tienePresupuesto %}
                <form method="post"
                      action="{{ path('app_proyecto_crear_presupuesto_inicial', {id: proyecto.id}) }}"
                      onsubmit="return confirm('Se creará un presupuesto inicial para este proyecto. ¿Continuar?');">
                    <button type="submit" class="btn btn-sm btn-primary">
                        Crear presupuesto inicial
                    </button>
                </form>
            {% else %}
                <button class="btn btn-sm btn-outline-secondary" disabled>
                    Presupuesto inicial ya creado
                </button>
            {% endif %}
        </div>

        <div class="card-body">
            {% if proyecto.documentos|length > 0 %}
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Número</th>
                            <th>Tipo</th>
                            <th>Fecha</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for documento in proyecto.documentos %}
                            <tr>
                                <td>
                                    <a href="{{ path('app_documento_show', {id: documento.id}) }}"
                                       class="text-decoration-none fw-semibold">
                                        {{ documento.numero ?? ('Documento #' ~ documento.id) }}
                                    </a>
                                </td>

                                <td>
                                    {% if documento.tipoDocumento|lower == 'presupuesto' %}
                                        <span class="badge bg-primary">Presupuesto</span>
                                    {% elseif documento.tipoDocumento|lower == 'factura' %}
                                        <span class="badge bg-success">Factura</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ documento.tipoDocumento }}</span>
                                    {% endif %}
                                </td>

                                <td>
                                    {% if documento.fechaDocumento is defined and documento.fechaDocumento %}
                                        {{ documento.fechaDocumento|date('d/m/Y') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>

                                <td class="text-end">{{ documento.total|number_format(2, ',', '.') }} €</td>

                                <td class="text-end">
                                    <a href="{{ path('app_documento_show', {id: documento.id}) }}"
                                       class="btn btn-sm btn-outline-primary">
                                        Ver
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="text-muted mb-0">Todavía no hay documentos asociados a este proyecto.</p>
            {% endif %}
        </div>
    </div>


    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Total presupuestado</div>
                    <div class="fs-5 fw-bold">{{ proyecto.totalPresupuestado|number_format(2, ',', '.') }} €</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Total facturado</div>
                    <div class="fs-5 fw-bold">{{ proyecto.totalFacturado|number_format(2, ',', '.') }} €</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Total cobrado</div>
                    <div class="fs-5 fw-bold">{{ proyecto.totalCobrado|number_format(2, ',', '.') }} €</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Pendiente</div>
                    <div class="fs-5 fw-bold">
                        {{ (proyecto.totalFacturado - proyecto.totalCobrado)|number_format(2, ',', '.') }} €
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">Datos del proyecto</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small">Fecha inicio</div>
                    <div>{{ proyecto.fechaInicio ? proyecto.fechaInicio|date('d/m/Y') : '—' }}</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Fecha fin prevista</div>
                    <div>{{ proyecto.fechaFinPrevista ? proyecto.fechaFinPrevista|date('d/m/Y') : '—' }}</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Creado</div>
                    <div>{{ proyecto.creadoEn ? proyecto.creadoEn|date('d/m/Y H:i') : '—' }}</div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">Notas</div>
                    <div>{{ proyecto.notas ?: 'Sin notas' }}</div>
                </div>
            </div>
        </div>
    </div>



    {# COBROS DEL PROYECTO #}
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
                        <div>
                            <h4 class="mb-0">Cobros del proyecto</h4>
                            <div class="text-muted small">
                                Pagos recibidos del cliente para esta operación completa
                            </div>
                        </div>

                        <button type="button"
                                class="btn btn-sm btn-primary mt-2 mt-md-0"
                                data-bs-toggle="modal"
                                data-bs-target="#modalNuevoCobroProyecto">
                            + Registrar cobro
                        </button>
                    </div>

                    <div class="row mb-3 text-center">
                        <div class="col-md-4">
                            <div class="text-muted small">Total proyecto</div>
                            <div class="fw-bold">
                                {{ proyecto.totalFacturado|format_currency('EUR', locale='es') }}
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="text-muted small">Cobrado</div>
                            <div class="fw-bold text-success">
                                {{ proyecto.totalCobrado|format_currency('EUR', locale='es') }}
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="text-muted small">Pendiente</div>
                            {% set pendiente = proyecto.pendienteCobro %}
                            <div class="fw-bold {{ pendiente > 0 ? 'text-danger' : 'text-success' }}">
                                {{ pendiente|format_currency('EUR', locale='es') }}
                            </div>
                        </div>
                    </div>

                    {% if proyecto.cobros is empty %}
                        <div class="border rounded p-4 bg-light-subtle">
                            <div class="fw-semibold mb-1">Sin cobros registrados</div>
                            <div class="text-muted small">
                                Registra aquí los pagos recibidos del cliente.
                            </div>
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Método</th>
                                        <th class="text-end">Importe bruto</th>
                                        <th class="text-end">% Recargo</th>
                                        <th class="text-end">Recargo</th>
                                        <th class="text-end">Neto</th>
                                        <th>Referencia</th>
                                        <th>Notas</th>
                                        <th class="text-end"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for cobro in proyecto.cobros %}
                                        <tr>
                                            <td>{{ cobro.fecha|date('d/m/Y') }}</td>
                                            <td>
                                                <span class="badge bg-secondary">
                                                    {{ cobro.metodo }}
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                {{ cobro.importeBruto|format_currency('EUR', locale='es') }}
                                            </td>
                                            <td class="text-end">
                                                {{ cobro.porcentajeRecargo }} %
                                            </td>
                                            <td class="text-end">
                                                {{ cobro.importeRecargo|format_currency('EUR', locale='es') }}
                                            </td>
                                            <td class="text-end">
                                                {{ cobro.importeNeto|format_currency('EUR', locale='es') }}
                                            </td>
                                            <td>{{ cobro.referencia ?? '—' }}</td>
                                            <td>{{ cobro.notas ?? '—' }}</td>
                                            <td class="text-end">
                                                <form method="post"
                                                    action="{{ path('proyecto_cobro_eliminar', {id: cobro.id}) }}"
                                                    onsubmit="return confirm('¿Seguro que quieres eliminar este cobro?');">
                                                    <input type="hidden"
                                                        name="_token"
                                                        value="{{ csrf_token('eliminar-proyecto-cobro-' ~ cobro.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        Borrar
                                                    </button>
                                                </form>
                                                <a href="{{ path('proyecto_cobro_justificante_pdf', {id: cobro.id}) }}"
                                                    target="_blank"
                                                    class="btn btn-sm btn-outline-dark">
                                                        Justificante
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalNuevoCobroProyecto" tabindex="-1" aria-labelledby="modalNuevoCobroProyectoLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" action="{{ path('proyecto_cobro_nuevo', {id: proyecto.id}) }}">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalNuevoCobroProyectoLabel">Registrar cobro del proyecto</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    </div>

                    <div class="modal-body row g-3">
                        <div class="col-6">
                            <label class="form-label">Fecha</label>
                            <input type="date"
                                name="fecha"
                                class="form-control form-control-sm"
                                value="{{ "now"|date('Y-m-d') }}"
                                required>
                        </div>

                        <div class="col-6">
                            <label class="form-label">Método</label>
                            <select name="metodo" class="form-select form-select-sm" required>
                                <option value="efectivo">Efectivo</option>
                                <option value="tarjeta">Tarjeta</option>
                                <option value="transferencia">Transferencia</option>
                                <option value="bizum">Bizum</option>
                                <option value="financiacion">Financiación</option>
                            </select>
                        </div>

                        <div class="col-6">
                            <label class="form-label">Importe bruto</label>
                            <div class="input-group input-group-sm">
                                <input type="number"
                                    name="importeBruto"
                                    class="form-control"
                                    step="0.01"
                                    min="0.01"
                                    required
                                    placeholder="{{ proyecto.pendienteCobro|number_format(2, '.', '') }}">
                                <span class="input-group-text">€</span>
                            </div>
                        </div>

                        <div class="col-6">
                            <label class="form-label">% Recargo</label>
                            <div class="input-group input-group-sm">
                                <input type="number"
                                    name="porcentajeRecargo"
                                    class="form-control"
                                    step="0.01"
                                    min="0"
                                    value="0">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>

                        <input type="hidden" name="importeRecargo" value="0">
                        <input type="hidden" name="importeNeto" value="0">

                        <div class="col-12">
                            <label class="form-label">Referencia</label>
                            <input type="text"
                                name="referencia"
                                class="form-control form-control-sm"
                                placeholder="Transferencia, VISA *1234, financiación...">
                        </div>

                        <div class="col-12">
                            <label class="form-label">Notas</label>
                            <textarea name="notas"
                                    class="form-control form-control-sm"
                                    rows="2"></textarea>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-sm btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit"
                                class="btn btn-sm btn-primary">
                            Guardar cobro
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>    

    {# GASTOS DEL PROYECTO #}
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
            <span>Gastos del proyecto</span>

            <button type="button"
                    class="btn btn-sm btn-outline-primary"
                    id="btnNuevoGastoSecundario"
                    data-url="{{ path('app_proyecto_gasto_new', {id: proyecto.id}) }}">
                Añadir gasto
            </button>
        </div>

        <div class="card-body">
            {% if proyecto.gastos is defined and proyecto.gastos|length > 0 %}
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Fecha prevista</th>
                                <th>Estado</th>
                                <th>Categoría</th>
                                <th>Concepto</th>
                                <th>Proveedor</th>
                                <th class="text-end">Previsto</th>
                                <th class="text-end">Real</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for gasto in proyecto.gastos %}
                                <tr>
                                    <td>
                                        {{ gasto.fechaPrevista ? gasto.fechaPrevista|date('d/m/Y') : '—' }}
                                    </td>

                                    <td>
                                        {% if gasto.estado == 'previsto' %}
                                            <span class="badge bg-secondary">Previsto</span>
                                        {% elseif gasto.estado == 'confirmado' %}
                                            <span class="badge bg-info text-dark">Confirmado</span>
                                        {% elseif gasto.estado == 'pagado' %}
                                            <span class="badge bg-success">Pagado</span>
                                        {% elseif gasto.estado == 'cancelado' %}
                                            <span class="badge bg-dark">Cancelado</span>
                                        {% else %}
                                            <span class="badge bg-light text-dark">{{ gasto.estado }}</span>
                                        {% endif %}
                                    </td>

                                    <td>{{ gasto.categoria ?: '—' }}</td>
                                    <td>{{ gasto.concepto }}</td>
                                    <td>{{ gasto.proveedor ?: '—' }}</td>

                                    <td class="text-end">
                                        {{ gasto.importePrevisto|number_format(2, ',', '.') }} €
                                    </td>

                                    <td class="text-end">
                                        {% if gasto.importeReal is not null %}
                                            {{ gasto.importeReal|number_format(2, ',', '.') }} €
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">

                                            {# Editar 
                                            <button type="button"
                                                    class="btn btn-outline-primary"
                                                    data-url="{{ path('app_proyecto_gasto_edit', {id: gasto.id}) }}">
                                                <i class="bi bi-pencil"></i>
                                            </button>#}

                                            {% if gasto.estado == 'previsto' %}

                                                <form method="post"
                                                    action="{{ path('app_proyecto_gasto_confirmar', {id: gasto.id}) }}">
                                                    <button class="btn btn-outline-info"
                                                            title="Confirmar">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                </form>

                                                <form method="post"
                                                    action="{{ path('app_proyecto_gasto_delete', {id: gasto.id}) }}"
                                                    onsubmit="return confirm('¿Eliminar gasto?');">
                                                    <button class="btn btn-outline-danger">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>

                                            {% elseif gasto.estado == 'confirmado' %}

                                                <form method="post"
                                                    action="{{ path('app_proyecto_gasto_pagado', {id: gasto.id}) }}">
                                                    <button class="btn btn-outline-success"
                                                            title="Marcar pagado">
                                                        <i class="bi bi-cash"></i>
                                                    </button>
                                                </form>

                                                <form method="post"
                                                    action="{{ path('app_proyecto_gasto_cancelar', {id: gasto.id}) }}">
                                                    <button class="btn btn-outline-dark"
                                                            title="Cancelar">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                </form>

                                            {% elseif gasto.estado == 'pagado' %}

                                                {% if gasto.bancoMovimiento %}
                                                    <a href="{{ path('admin_banco_movimiento_show', {id: gasto.bancoMovimiento.id}) }}"
                                                    class="btn btn-outline-secondary"
                                                    title="Ver movimiento">
                                                        <i class="bi bi-bank"></i>
                                                    </a>
                                                {% endif %}

                                            {% elseif gasto.estado == 'cancelado' %}

                                                <form method="post"
                                                    action="{{ path('app_proyecto_gasto_reactivar', {id: gasto.id}) }}">
                                                    <button class="btn btn-outline-warning">
                                                        <i class="bi bi-arrow-clockwise"></i>
                                                    </button>
                                                </form>

                                            {% endif %}

                                        </div>
                                    </td>                                    
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted mb-0">Todavía no hay gastos asociados a este proyecto.</p>
            {% endif %}
        </div>
    </div>
</div>

{# MODAL NUEVO GASTO #}
<div class="modal fade" id="modalProyectoGasto" tabindex="-1" aria-labelledby="modalProyectoGastoLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalProyectoGastoLabel">Nuevo gasto del proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body" id="modalProyectoGastoBody">
                <div class="text-muted">Cargando formulario...</div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const botonesNuevoGasto = document.querySelectorAll('#btnNuevoGasto, #btnNuevoGastoSecundario');
    const modalElement = document.getElementById('modalProyectoGasto');
    const modalBody = document.getElementById('modalProyectoGastoBody');

    if (!botonesNuevoGasto.length || !modalElement || !modalBody) {
        return;
    }

    botonesNuevoGasto.forEach(function (boton) {
        boton.addEventListener('click', async function () {
            const url = this.dataset.url;

            modalBody.innerHTML = '<div class="text-muted">Cargando formulario...</div>';

            let modalInstance = null;
            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                modalInstance = bootstrap.Modal.getInstance(modalElement);
                if (!modalInstance) {
                    modalInstance = new bootstrap.Modal(modalElement);
                }
                modalInstance.show();
            }

            try {
                const response = await fetch(url, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const html = await response.text();
                modalBody.innerHTML = html;

                bindProyectoGastoForm(url);
            } catch (error) {
                modalBody.innerHTML = '<div class="alert alert-danger mb-0">No se pudo cargar el formulario.</div>';
            }
        });
    });

    function bindProyectoGastoForm(url) {
        const form = document.getElementById('formProyectoGasto');
        if (!form) {
            return;
        }

        form.addEventListener('submit', async function (e) {
            e.preventDefault();

            const formData = new FormData(form);

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const contentType = response.headers.get('content-type') || '';

                if (contentType.includes('application/json')) {
                    const data = await response.json();

                    if (data.success) {
                        window.location.reload();
                        return;
                    }
                }

                const html = await response.text();
                modalBody.innerHTML = html;
                bindProyectoGastoForm(url);

            } catch (error) {
                modalBody.innerHTML = '<div class="alert alert-danger mb-0">Error al guardar el gasto.</div>';
            }
        });
    }
});
</script>
{% endblock %}