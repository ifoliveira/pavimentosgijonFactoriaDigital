{% extends 'base.html.twig' %}

{% block title %}Proyectos cerrados{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Proyectos cerrados</h1>
            <p class="text-muted mb-0">
                Histórico de obras finalizadas o completamente cobradas.
            </p>
        </div>

        <a href="{{ path('app_dashboard') }}"
           class="btn btn-outline-secondary">
            Volver al dashboard
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <h2 class="h5 mb-0">Listado de proyectos cerrados</h2>
        </div>

        <div class="card-body">

            {% if cerrados is empty %}
                <div class="alert alert-light border mb-0">
                    No hay proyectos cerrados.
                </div>
            {% else %}

                <div class="table-responsive">
                    <table class="table table-hover align-middle">

                        <thead>
                            <tr>
                                <th>Proyecto</th>
                                <th>Cliente</th>
                                <th>Factura</th>
                                <th>Fecha cierre</th>
                                <th class="text-end">Facturado</th>
                                <th class="text-end">Cobrado</th>
                                <th class="text-end">Coste</th>
                                <th class="text-end">Margen</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            {% for item in cerrados %}
                                {% set proyecto = item.proyecto %}
                                {% set factura = item.factura %}

                                <tr>
                                    <td>
                                        <div class="fw-semibold">
                                            {{ proyecto.nombre }}
                                        </div>
                                        <div class="small text-muted">
                                            Inicio:
                                            {{ proyecto.fechaInicio ? proyecto.fechaInicio|date('d/m/Y') : '-' }}
                                        </div>
                                    </td>

                                    <td>
                                        {% if proyecto.cliente %}
                                            {{ proyecto.cliente.nombreCl }} {{ proyecto.cliente.apellidosCl }}
                                        {% else %}
                                            <span class="text-muted">Sin cliente</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if factura %}
                                            <span class="fw-semibold">
                                                {{ factura.serie }}-{{ '%04d'|format(factura.numero) }}
                                            </span>
                                            <div class="small text-muted">
                                                {{ factura.estadoCobro }}
                                            </div>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if proyecto.fechaFinReal %}
                                            {{ proyecto.fechaFinReal|date('d/m/Y') }}
                                        {% else %}
                                            <span class="text-muted">Cobrada</span>
                                        {% endif %}
                                    </td>

                                    <td class="text-end fw-semibold">
                                        {{ proyecto.totalFacturado|default(0)|number_format(2, ',', '.') }} €
                                    </td>

                                    <td class="text-end text-success fw-semibold">
                                        {{ proyecto.totalCobrado|default(0)|number_format(2, ',', '.') }} €
                                    </td>

                                    <td class="text-end">
                                        {{ item.coste|default(0)|number_format(2, ',', '.') }} €
                                    </td>

                                    <td class="text-end fw-semibold {{ item.margen >= 0 ? 'text-success' : 'text-danger' }}">
                                        {{ item.margen|number_format(2, ',', '.') }} €
                                    </td>

                                    <td class="text-end">
                                        <a href="{{ path('app_proyecto_show', {id: proyecto.id}) }}"
                                           class="btn btn-sm btn-outline-primary">
                                            Ver
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>

                    </table>
                </div>

            {% endif %}

        </div>
    </div>

</div>
{% endblock %}