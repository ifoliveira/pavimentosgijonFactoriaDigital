{% extends 'base.html.twig' %}

{% block title %}Lista presupuestos{% endblock %}
{% block cabecera %}Presupuestos{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Lista presupuestos</li>{% endblock %}

{% block body %}

    {# Mapa de colores por estado #}
    {% set estadoColores = {
        4:  'primary',
        5:  'warning',
        6:  'warning',
        7:  'warning',
        8:  'danger',
        10: 'info',
        99: 'dark'
    } %}

    {# Contadores de estados — solo si se usan en el template #}
    {% set total      = 0 %}
    {% set medir      = 0 %}
    {% set pendientes = 0 %}
    {% set aceptados  = 0 %}
    {% set entregados = 0 %}

    {% for estado in estados %}
        {% if estado.estado > 6 %}
            {% set total = total + estado.cantidad %}
        {% endif %}
        {% if estado.estado == 4 %}
            {% set medir = estado.cantidad %}
        {% elseif estado.estado in [5, 6, 7] %}
            {% set pendientes = pendientes + estado.cantidad %}
        {% elseif estado.estado == 8 %}
            {% set entregados = estado.cantidad %}
        {% elseif estado.estado in [9, 10] %}
            {% set aceptados = aceptados + estado.cantidad %}
        {% endif %}
    {% endfor %}

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="border-bottom title-part-padding">
                    <h4 class="card-title mb-0">Presupuestos en curso</h4>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="multi_control" class="table table-striped table-bordered display" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Estado</th>
                                    <th>Id</th>
                                    <th>Fecha</th>
                                    <th>Importe total</th>
                                    <th>Importe restante</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for presupuesto in presupuestos %}
                                    {# Calcular pagado #}
                                    {% set pagado = 0 %}
                                    {% for pago in presupuesto.ticket.pagos %}
                                        {% set pagado = pagado + pago.importePg %}
                                    {% endfor %}

                                    {# Calcular mano de obra pendiente #}
                                    {% set manoobrapdte = 0 %}
                                    {% for economico in presupuesto.economicpresus %}
                                        {% if economico.aplicaEco == 'M' and economico.estadoEco == '1' %}
                                            {% set manoobrapdte = economico.importeEco %}
                                        {% endif %}
                                    {% endfor %}

                                    {% set color  = estadoColores[presupuesto.EstadoPe.id] ?? 'success' %}
                                    {% set activo = presupuesto.EstadoPe.id in [9, 10] %}

                                    <tr>
                                        <td>
                                            <span class="badge bg-{{ color }}">{{ presupuesto.EstadoPe }}</span>
                                        </td>
                                        <td>
                                            <a href="{{ path('presupuestos_show', {'id': presupuesto.id}) }}" class="font-medium link">
                                                {{ presupuesto.clientePe.direccionCl }}
                                                ({{ presupuesto.clientePe.nombreCl }} {{ presupuesto.clientePe.apellidosCl }} — {{ presupuesto.manoobraPe }})
                                            </a>
                                        </td>
                                        <td>{{ presupuesto.fechainiPe ? presupuesto.fechainiPe|date('Y-m-d') : '' }}</td>
                                        <td class="text-right">
                                            {{ (presupuesto.importetotPe + presupuesto.importemanoobra) | format_currency('EUR', locale='es') }}
                                        </td>
                                        <td class="text-right">
                                            {% if activo %}
                                                {{ (presupuesto.importetotPe + presupuesto.importemanoobra - pagado - (presupuesto.importemanoobra - manoobrapdte)) | format_currency('EUR', locale='es') }}
                                            {% else %}
                                                {{ 0 | format_currency('EUR', locale='es') }}
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a class="text-inverse pr-2" data-toggle="tooltip" title="Borrar presupuesto"
                                               name="delete_detalle" data-id="{{ presupuesto.id }}">
                                                <i class="ti-trash"></i>
                                            </a>
                                        </td>
                                    </tr>

                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th>Estado</th>
                                    <th>Id</th>
                                    <th>Fecha</th>
                                    <th>Importe total</th>
                                    <th>Importe restante</th>
                                    <th>Acciones</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block jscustom %}

    <script src="{{ asset('assets/extra-libs/datatables.net-bs4/js/dataTables.responsive.min.js') }}"></script>

    {# Botones export #}
    <script src="https://cdn.datatables.net/buttons/1.5.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/1.5.1/js/buttons.flash.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.32/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.32/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/1.5.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/1.5.1/js/buttons.print.min.js"></script>

    <script src="{{ asset('assets/libs/sweetalert2/dist/sweetalert2.all.min.js') }}"></script>

    <script>
    $(document).ready(function () {

        $('#multi_control').DataTable({
            dom: 'lfrtip',  // buscador arriba, tabla, info + paginación abajo
            language: {
                url: '//cdn.datatables.net/plug-ins/1.10.16/i18n/Spanish.json',
                emptyTable: 'No se encontraron presupuestos'
            }
        });

        $(document).on('click', 'a[name="delete_detalle"]', async function () {
            const id = this.dataset.id;

            const swal = Swal.mixin({
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton:  'mr-2 btn btn-danger'
                },
                buttonsStyling: false
            });

            const result = await swal.fire({
                title:             'Borrado de presupuesto',
                text:              'Se va a borrar el presupuesto ' + id,
                icon:              'question',
                showCancelButton:  true,
                confirmButtonText: 'Adelante',
                cancelButtonText:  'Noooo',
                reverseButtons:    true
            });

            if (result.isConfirmed) delete_line(id);
        });

        function delete_line(id) {
            $.ajax({
                url:      '{{ path("presupuesto_delete_ajax") }}',
                type:     'GET',
                data:     { id },
                dataType: 'json',
                success: function () {
                    Swal.fire({
                        icon:              'success',
                        title:             '¡Borrado correctamente!',
                        html:              'Se cerrará en breve',
                        timer:             2000,
                        showConfirmButton: false,
                        timerProgressBar:  true
                    }).then(() => location.reload());
                },
                error: (xhr, status) => alert(status)
            });
        }

    });
    </script>
{% endblock %}