{% extends 'base.html.twig' %}

{% block title %}Presupuestos rechazados{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="h3 mb-1">Presupuestos rechazados</h1>

            <p class="text-muted mb-0">
                Histórico comercial de presupuestos perdidos o descartados.
            </p>
        </div>

        <a href="{{ path('admin_comercial_presupuestos') }}"
           class="btn btn-outline-secondary">
            Volver al dashboard
        </a>

    </div>

    <div class="card border-0 shadow-sm">

        <div class="card-header bg-white">
            <h2 class="h5 mb-0">Listado de rechazados</h2>
        </div>

        <div class="card-body">

            {% if presupuestos is empty %}

                <div class="alert alert-light border mb-0">
                    No hay presupuestos rechazados.
                </div>

            {% else %}

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Presupuesto</th>
                                <th>Proyecto / cliente</th>
                                <th>Motivo</th>
                                <th>Nota</th>
                                <th class="text-end">Importe</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>

                            {% for presupuesto in presupuestos %}

                                <tr>

                                    <td style="min-width: 110px;">

                                        {% if presupuesto.fechaEmision %}
                                            {{ presupuesto.fechaEmision|date('d/m/Y') }}
                                        {% else %}
                                            -
                                        {% endif %}

                                    </td>

                                    <td style="min-width: 140px;">

                                        <div class="fw-semibold">

                                            {% if presupuesto.numero %}
                                                {{ presupuesto.serie }}-{{ '%04d'|format(presupuesto.numero) }}
                                            {% else %}
                                                BORRADOR
                                            {% endif %}

                                        </div>

                                        <div class="small text-muted">
                                            ID {{ presupuesto.id }}
                                        </div>

                                    </td>

                                    <td style="min-width: 260px;">

                                        <div class="fw-semibold">

                                            {% if presupuesto.proyecto %}
                                                {{ presupuesto.proyecto.nombre }}
                                            {% else %}
                                                Sin proyecto
                                            {% endif %}

                                        </div>

                                        <div class="small text-muted">

                                            {% if presupuesto.cliente %}
                                                {{ presupuesto.cliente.nombreCl }}
                                                {{ presupuesto.cliente.apellidosCl }}

                                            {% elseif presupuesto.proyecto and presupuesto.proyecto.cliente %}

                                                {{ presupuesto.proyecto.cliente.nombreCl }}
                                                {{ presupuesto.proyecto.cliente.apellidosCl }}

                                            {% else %}
                                                Sin cliente
                                            {% endif %}

                                        </div>

                                    </td>

                                    <td style="min-width: 170px;">

                                        {% if presupuesto.motivoPerdida %}

                                            {% if presupuesto.motivoPerdida == 'precio_alto' %}
                                                <span class="badge bg-danger">
                                                    Precio alto
                                                </span>

                                            {% elseif presupuesto.motivoPerdida == 'sin_respuesta' %}
                                                <span class="badge bg-secondary">
                                                    Sin respuesta
                                                </span>

                                            {% elseif presupuesto.motivoPerdida == 'lo_hace_otro' %}
                                                <span class="badge bg-dark">
                                                    Otra empresa
                                                </span>

                                            {% elseif presupuesto.motivoPerdida == 'aplazado' %}
                                                <span class="badge bg-warning text-dark">
                                                    Aplazado
                                                </span>

                                            {% else %}
                                                <span class="badge bg-light text-dark border">
                                                    Otro
                                                </span>

                                            {% endif %}

                                        {% else %}

                                            <span class="text-muted">
                                                Sin motivo
                                            </span>

                                        {% endif %}

                                    </td>

                                    <td style="min-width: 250px;">

                                        {% if presupuesto.notaComercial %}
                                            <div class="small">
                                                {{ presupuesto.notaComercial }}
                                            </div>
                                        {% else %}
                                            <span class="text-muted small">
                                                —
                                            </span>
                                        {% endif %}

                                    </td>

                                    <td class="text-end fw-semibold">
                                        {{ presupuesto.total|default(0)|number_format(2, ',', '.') }} €
                                    </td>

                                    <td class="text-end">

                                        <div class="d-flex justify-content-end gap-1 flex-wrap">

                                            <a href="{{ path('app_documento_show', {id: presupuesto.id}) }}"
                                               class="btn btn-sm btn-outline-primary">
                                                Ver
                                            </a>

                                            <form method="post"
                                                  action="{{ path('admin_comercial_presupuesto_estado', {id: presupuesto.id}) }}">

                                                <input type="hidden"
                                                       name="estado"
                                                       value="entregado">

                                                <button class="btn btn-sm btn-outline-success">
                                                    Recuperar
                                                </button>

                                            </form>

                                        </div>

                                    </td>

                                </tr>

                            {% endfor %}

                        </tbody>

                    </table>

                </div>

            {% endif %}

        </div>

    </div>

</div>
{% endblock %}